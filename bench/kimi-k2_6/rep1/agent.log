{"type":"tool_use","timestamp":1778753511823,"sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","part":{"type":"tool","tool":"read","callID":"read:5","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/core.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/core.sv</path>\n<type>file</type>\n<content>\n1: // rtl/core.sv\n2: //\n3: // Top-level wiring for the 5-stage in-order RV32IM core.\n4: //\n5: //  IF -> ID -> EX -> MEM -> WB\n6: //   |    |     ^\n7: //   |    +-----+    forward_unit drives EX-stage rs1/rs2 muxes\n8: //   |               from EX/MEM and MEM/WB\n9: //   +- stall <- hazard_unit (load-use)\n10: //\n11: // IO port names use the `io_*` Chisel-emit prefix so the existing\n12: // formal/wrapper_si.sv and test/cosim/main.cpp bindings carry through\n13: // byte-for-byte. RVFI port set is the single-channel set described in\n14: // CLAUDE.md invariant 1 under `nret: 1` (declared in core.yaml). The\n15: // orchestrator routes formal to wrapper_si.sv + checks_si.cfg and FPGA\n16: // synth to fpga/core_bench_si.sv for this core. There is no channel 1.\n17: //\n18: // Latency:        full pipeline; instruction n retires at MEM/WB on\n19: //                 cycle n+4 (no hazards) or later (load-use stall,\n20: //                 redirect).\n21: // RVFI fields:    all of them — driven from the MEM/WB register and\n22: //                 the WB-stage write-data mux.\n23: module core (\n24:   input  logic        clock,\n25:   input  logic        reset,\n26:   // imem\n27:   output logic [31:0] io_imemAddr,\n28:   input  logic [31:0] io_imemData,\n29:   // imem bus backpressure. Drive 1 for zero-wait single-cycle BRAM (the\n30:   // V0 default). Drive 0 to model bus stall — PC reg holds, IF/ID\n31:   // payload becomes a NOP, and a pipeline bubble propagates downstream.\n32:   // Used by test/cosim/vex_main.cpp's --istall mode to match VexRiscv's\n33:   // random ~22% backpressure model so CoreMark/MHz can be compared\n34:   // apples-to-apples with their published \"full no cache\" number.\n35:   input  logic        io_imemReady,\n36:   // dmem\n37:   output logic [31:0] io_dmemAddr,\n38:   input  logic [31:0] io_dmemRData,\n39:   output logic [31:0] io_dmemWData,\n40:   output logic [3:0]  io_dmemWEn,\n41:   output logic        io_dmemREn,\n42:   // dmem bus backpressure. Drive 1 for zero-wait. Drive 0 to model\n43:   // dStall — when there is a memory op in EX/MEM, the entire pipeline\n44:   // freezes back to MEM; MEM/WB captures a bubble; the LOAD/STORE waits\n45:   // until the bus delivers.\n46:   input  logic        io_dmemReady,\n47:   // RVFI — single-channel retirement port set (NRET=1 contract,\n48:   // declared via `nret: 1` in core.yaml). Channel 0 is the sole\n49:   // retirement channel. See CLAUDE.md invariant 1 for the full contract.\n50:   output logic        io_rvfi_valid_0,\n51:   output logic [63:0] io_rvfi_order_0,\n52:   output logic [31:0] io_rvfi_insn_0,\n53:   output logic        io_rvfi_trap_0,\n54:   output logic        io_rvfi_halt_0,\n55:   output logic        io_rvfi_intr_0,\n56:   output logic [1:0]  io_rvfi_mode_0,\n57:   output logic [1:0]  io_rvfi_ixl_0,\n58:   output logic [4:0]  io_rvfi_rs1_addr_0,\n59:   output logic [31:0] io_rvfi_rs1_rdata_0,\n60:   output logic [4:0]  io_rvfi_rs2_addr_0,\n61:   output logic [31:0] io_rvfi_rs2_rdata_0,\n62:   output logic [4:0]  io_rvfi_rd_addr_0,\n63:   output logic [31:0] io_rvfi_rd_wdata_0,\n64:   output logic [31:0] io_rvfi_pc_rdata_0,\n65:   output logic [31:0] io_rvfi_pc_wdata_0,\n66:   output logic [31:0] io_rvfi_mem_addr_0,\n67:   output logic [3:0]  io_rvfi_mem_rmask_0,\n68:   output logic [3:0]  io_rvfi_mem_wmask_0,\n69:   output logic [31:0] io_rvfi_mem_rdata_0,\n70:   output logic [31:0] io_rvfi_mem_wdata_0\n71: );\n72: \n73:   // ── Inter-stage wires ──────────────────────────────────────────────────\n74:   if_id_t  if_id_w;\n75:   id_ex_t  id_ex_w;\n76:   ex_mem_t ex_mem_w;\n77:   mem_wb_t mem_wb_w;\n78: \n79:   // hazard / forward\n80:   logic       stall_if, stall_id, flush_if, flush_id;\n81:   logic       stall_ex_mem, hold_mem_wb;\n82:   logic [1:0] fwd_rs1_sel, fwd_rs2_sel;\n83: \n84:   // EX redirect\n85:   logic        redirect;\n86:   logic [31:0] redirect_target;\n87: \n88:   // BHT update\n89:   logic        bht_update_en;\n90:   logic [4:0]  bht_update_idx;\n91:   logic        bht_update_taken;\n92: \n93:   // regfile interface (driven by ID + WB stages)\n94:   logic [4:0]  rs1_addr_w;\n95:   logic [4:0]  rs2_addr_w;\n96:   logic [31:0] rs1_data_w;\n97:   logic [31:0] rs2_data_w;\n98:   logic        wb_w_en;\n99:   logic [4:0]  wb_w_addr;\n100:   logic [31:0] wb_w_data;\n101: \n102:   // ── IF ────────────────────────────────────────────────────────────────\n103:   if_stage u_if (\n104:     .clock            (clock),\n105:     .reset            (reset),\n106:     .stall            (stall_if),\n107:     .flush            (flush_if),\n108:     .redirect         (redirect),\n109:     .redirect_target  (redirect_target),\n110:     .imem_addr        (io_imemAddr),\n111:     .imem_data        (io_imemData),\n112:     .out              (if_id_w),\n113:     .bht_update_en    (bht_update_en),\n114:     .bht_update_idx   (bht_update_idx),\n115:     .bht_update_taken (bht_update_taken)\n116:   );\n117: \n118:   // ── ID + regfile ──────────────────────────────────────────────────────\n119:   id_stage u_id (\n120:     .clock    (clock),\n121:     .reset    (reset),\n122:     .stall    (stall_id),\n123:     .flush    (flush_id),\n124:     .in       (if_id_w),\n125:     .rs1_addr (rs1_addr_w),\n126:     .rs2_addr (rs2_addr_w),\n127:     .rs1_data (rs1_data_w),\n128:     .rs2_data (rs2_data_w),\n129:     .out      (id_ex_w)\n130:   );\n131: \n132:   reg_file u_rf (\n133:     .clock    (clock),\n134:     .reset    (reset),\n135:     .rs1_addr (rs1_addr_w),\n136:     .rs2_addr (rs2_addr_w),\n137:     .rs1_data (rs1_data_w),\n138:     .rs2_data (rs2_data_w),\n139:     .w_en     (wb_w_en),\n140:     .w_addr   (wb_w_addr),\n141:     .w_data   (wb_w_data)\n142:   );\n143: \n144:   // ── EX ────────────────────────────────────────────────────────────────\n145:   ex_stage u_ex (\n146:     .clock            (clock),\n147:     .reset            (reset),\n148:     .stall            (stall_ex_mem),\n149:     .in               (id_ex_w),\n150:     .fwd_rs1_sel      (fwd_rs1_sel),\n151:     .fwd_rs2_sel      (fwd_rs2_sel),\n152:     .fwd_ex_mem       (ex_mem_w.alu_result),  // EX/MEM-registered ALU result\n153:     .fwd_mem_wb       (wb_w_data),            // WB-stage's write-mux output\n154:     .out              (ex_mem_w),\n155:     .redirect         (redirect),\n156:     .redirect_target  (redirect_target),\n157:     .bht_update_en    (bht_update_en),\n158:     .bht_update_idx   (bht_update_idx),\n159:     .bht_update_taken (bht_update_taken)\n160:   );\n161: \n162:   // ── MEM ───────────────────────────────────────────────────────────────\n163:   mem_stage u_mem (\n164:     .clock      (clock),\n165:     .reset      (reset),\n166:     .hold_wb    (hold_mem_wb),\n167:     .in         (ex_mem_w),\n168:     .dmem_addr  (io_dmemAddr),\n169:     .dmem_wdata (io_dmemWData),\n170:     .dmem_rdata (io_dmemRData),\n171:     .dmem_wen   (io_dmemWEn),\n172:     .dmem_ren   (io_dmemREn),\n173:     .out        (mem_wb_w)\n174:   );\n175: \n176:   // ── WB ────────────────────────────────────────────────────────────────\n177:   wb_stage u_wb (\n178:     .in     (mem_wb_w),\n179:     .w_en   (wb_w_en),\n180:     .w_addr (wb_w_addr),\n181:     .w_data (wb_w_data)\n182:   );\n183: \n184:   // ── Hazard / forwarding ───────────────────────────────────────────────\n185:   hazard_unit u_hazard (\n186:     .id_ex_mem_read (id_ex_w.ctrl.mem_read),\n187:     .id_ex_rd       (id_ex_w.rd),\n188:     .if_id_rs1      (if_id_w.instr[19:15]),\n189:     .if_id_rs2      (if_id_w.instr[24:20]),\n190:     .redirect       (redirect),\n191:     .imem_ready     (io_imemReady),\n192:     .dmem_ready     (io_dmemReady),\n193:     .ex_mem_mem_op  (ex_mem_w.ctrl.mem_read | ex_mem_w.ctrl.mem_write),\n194:     .stall_if       (stall_if),\n195:     .stall_id       (stall_id),\n196:     .flush_if       (flush_if),\n197:     .flush_id       (flush_id),\n198:     .stall_ex_mem   (stall_ex_mem),\n199:     .hold_mem_wb    (hold_mem_wb)\n200:   );\n201: \n202:   forward_unit u_fwd (\n203:     .id_ex_rs1   (id_ex_w.rs1_addr),\n204:     .id_ex_rs2   (id_ex_w.rs2_addr),\n205:     .ex_mem_rd   (ex_mem_w.rd),\n206:     .ex_mem_w_en (ex_mem_w.ctrl.reg_write),\n207:     .mem_wb_rd   (mem_wb_w.rd),\n208:     .mem_wb_w_en (mem_wb_w.ctrl.reg_write),\n209:     .fwd_rs1     (fwd_rs1_sel),\n210:     .fwd_rs2     (fwd_rs2_sel)\n211:   );\n212: \n213:   // ── RVFI ──────────────────────────────────────────────────────────────\n214:   // The MEM/WB register is the retirement boundary. rvfi_order increments\n215:   // every cycle rvfi_valid is high; CLAUDE.md invariant 4 (riscv-formal\n216:   // unique-check) requires strict +1.\n217:   logic [63:0] rvfi_order_q;\n218:   logic        rd_wen;\n219: \n220:   always_ff @(posedge clock) begin\n221:     if (reset)                rvfi_order_q <= 64'b0;\n222:     else if (mem_wb_w.valid)  rvfi_order_q <= rvfi_order_q + 64'b1;\n223:   end\n224: \n225:   always_comb begin\n226:     rd_wen = mem_wb_w.ctrl.reg_write && (mem_wb_w.rd != 5'b0);\n227: \n228:     // Channel 0: the only retirement channel for the single-issue baseline.\n229:     io_rvfi_valid_0     = mem_wb_w.valid;\n230:     io_rvfi_order_0     = rvfi_order_q;\n231:     io_rvfi_insn_0      = mem_wb_w.instr;\n232:     io_rvfi_trap_0      = mem_wb_w.ctrl.is_illegal;\n233:     io_rvfi_halt_0      = 1'b0;\n234:     io_rvfi_intr_0      = 1'b0;\n235:     io_rvfi_mode_0      = 2'd3;     // M-mode only\n236:     io_rvfi_ixl_0       = 2'd1;     // 32-bit ISA\n237:     io_rvfi_rs1_addr_0  = mem_wb_w.rs1_addr;\n238:     io_rvfi_rs1_rdata_0 = mem_wb_w.rs1_val;\n239:     io_rvfi_rs2_addr_0  = mem_wb_w.rs2_addr;\n240:     io_rvfi_rs2_rdata_0 = mem_wb_w.rs2_val;\n241:     io_rvfi_rd_addr_0   = rd_wen ? mem_wb_w.rd : 5'b0;\n242:     io_rvfi_rd_wdata_0  = rd_wen ? wb_w_data   : 32'b0;\n243:     io_rvfi_pc_rdata_0  = mem_wb_w.pc;\n244:     io_rvfi_pc_wdata_0  = mem_wb_w.pc_next;\n245:     io_rvfi_mem_addr_0  = mem_wb_w.mem_addr;\n246:     io_rvfi_mem_rmask_0 = mem_wb_w.mem_rmask;\n247:     io_rvfi_mem_wmask_0 = mem_wb_w.mem_wmask;\n248:     io_rvfi_mem_rdata_0 = mem_wb_w.mem_rdata;\n249:     io_rvfi_mem_wdata_0 = mem_wb_w.mem_wdata;\n250:   end\n251: \n252: endmodule\n\n(End of file - total 252 lines)\n</content>","metadata":{"preview":"// rtl/core.sv\n//\n// Top-level wiring for the 5-stage in-order RV32IM core.\n//\n//  IF -> ID -> EX -> MEM -> WB\n//   |    |     ^\n//   |    +-----+    forward_unit drives EX-stage rs1/rs2 muxes\n//   |               from EX/MEM and MEM/WB\n//   +- stall <- hazard_unit (load-use)\n//\n// IO port names use the `io_*` Chisel-emit prefix so the existing\n// formal/wrapper_si.sv and test/cosim/main.cpp bindings carry through\n// byte-for-byte. RVFI port set is the single-channel set described in\n// CLAUDE.md invariant 1 under `nret: 1` (declared in core.yaml). The\n// orchestrator routes formal to wrapper_si.sv + checks_si.cfg and FPGA\n// synth to fpga/core_bench_si.sv for this core. There is no channel 1.\n//\n// Latency:        full pipeline; instruction n retires at MEM/WB on\n//                 cycle n+4 (no hazards) or later (load-use stall,\n//                 redirect).","truncated":false,"loaded":[]},"title":"cores/bench/rtl/core.sv","time":{"start":1778753511815,"end":1778753511822}},"id":"prt_e25f89d69001EXi7PJ9Y3UDh94","sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","messageID":"msg_e25f86010001rejW5ktX0FSie6"}}
{"type":"tool_use","timestamp":1778753512683,"sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","part":{"type":"tool","tool":"read","callID":"read:6","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/if_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/if_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/if_stage.sv\n2: //\n3: // Instruction fetch stage. Holds the PC register; the IF/ID payload\n4: // (pc + instr + valid) is *combinational* — there is no separate IF/ID\n5: // flop in this microarchitecture, the next-stage's ID/EX register\n6: // captures everything one cycle later.\n7: //\n8: // On flush or redirect, the instruction emitted to ID is forced to NOP\n9: // (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n10: // observing a real rs1/rs2 from a wrong-path instruction and inserting\n11: // a spurious load-use stall the cycle after a taken branch.\n12: //\n13: // Latency:        PC-reg update is synchronous; output is combinational.\n14: // RVFI fields:    feeds pc_rdata (via ID/EX/MEM/WB) and pc_wdata (via\n15: //                 EX-stage redirect).\n16: module if_stage (\n17:   input  logic              clock,\n18:   input  logic              reset,\n19:   input  logic              stall,            // hold PC (load-use)\n20:   input  logic              flush,            // emit NOP into ID this cycle\n21:   input  logic              redirect,         // EX has resolved a branch/jump\n22:   input  logic [31:0]       redirect_target,\n23:   output logic [31:0]       imem_addr,\n24:   input  logic [31:0]       imem_data,\n25:   output if_id_t  out,\n26:   // BHT update from EX stage\n27:   input  logic              bht_update_en,\n28:   input  logic [4:0]        bht_update_idx,\n29:   input  logic              bht_update_taken\n30: );\n31: \n32:   localparam logic [31:0] RESET_PC = 32'h0000_0000;\n33: \n34:   logic [31:0] pc;\n35:   logic [31:0] next_pc;\n36: \n37:   // ── BHT + branch predictor ────────────────────────────────────────────\n38:   logic        is_branch_instr;\n39:   logic        is_jal_instr;\n40:   logic [31:0] b_imm;\n41:   logic [31:0] j_imm;\n42:   logic        predict_taken;\n43:   logic [31:0] predict_target;\n44: \n45:   // 32-entry x 2-bit saturating counters, initialised strongly-taken.\n46:   logic [1:0] bht [0:31];\n47:   logic [4:0] bht_idx;\n48:   /* verilator lint_off UNUSEDSIGNAL */\n49:   logic [1:0] bht_cnt;\n50:   /* verilator lint_on UNUSEDSIGNAL */\n51:   logic       bht_pred;\n52: \n53:   always_comb begin\n54:     is_branch_instr = (imem_data[6:0] == 7'b1100011);\n55:     is_jal_instr    = (imem_data[6:0] == 7'b1101111);\n56: \n57:     // B-type immediate\n58:     b_imm = {{19{imem_data[31]}}, imem_data[31], imem_data[7],\n59:              imem_data[30:25], imem_data[11:8], 1'b0};\n60:     // J-type immediate\n61:     j_imm = {{11{imem_data[31]}}, imem_data[31], imem_data[19:12],\n62:              imem_data[20], imem_data[30:21], 1'b0};\n63: \n64:     // BHT read: PC[6:2] selects counter; MSB drives direction.\n65:     bht_idx = pc[6:2];\n66:     bht_cnt = bht[bht_idx];\n67:     bht_pred = bht_cnt[1];\n68: \n69:     // Conditional branches use BHT; JAL is always taken.\n70:     predict_taken = (is_branch_instr && bht_pred) ||\n71:                     is_jal_instr;\n72: \n73:     predict_target = is_branch_instr ? (pc + b_imm) :\n74:                      is_jal_instr    ? (pc + j_imm) :\n75:                                        (pc + 32'd4);\n76:   end\n77: \n78:   // BHT update (from EX-stage resolved branch).\n79:   always_ff @(posedge clock) begin\n80:     if (reset) begin\n81:       for (int i = 0; i < 32; i++) bht[i] <= 2'b11;\n82:     end else if (bht_update_en) begin\n83:       if (bht_update_taken && bht[bht_update_idx] != 2'b11)\n84:         bht[bht_update_idx] <= bht[bht_update_idx] + 2'b1;\n85:       else if (!bht_update_taken && bht[bht_update_idx] != 2'b00)\n86:         bht[bht_update_idx] <= bht[bht_update_idx] - 2'b1;\n87:     end\n88:   end\n89: \n90:   always_comb begin\n91:     next_pc = redirect ? redirect_target :\n92:               predict_taken ? predict_target :\n93:               (pc + 32'd4);\n94:   end\n95: \n96:   // Redirect must override stall: a BRANCH/JAL/JALR in EX may fire\n97:   // redirect on the same cycle as imem_stall or dmem_stall — without\n98:   // this priority the redirect target would be silently dropped, the\n99:   // PC would hold its old (wrong-path) value, and execution would\n100:   // resume on the wrong path once the bus unstalls. Verified by the\n101:   // VexRiscv-binary CoreMark sweep with --istall enabled.\n102:   always_ff @(posedge clock) begin\n103:     if      (reset)    pc <= RESET_PC;\n104:     else if (redirect) pc <= redirect_target;\n105:     else if (!stall)   pc <= next_pc;\n106:   end\n107: \n108:   assign imem_addr = pc;\n109: \n110:   always_comb begin\n111:     out.pc         = pc;\n112:     out.instr      = (flush || redirect) ? 32'h0000_0013 : imem_data;\n113:     out.valid      = !(flush || redirect);\n114:     out.pred_taken = predict_taken && !(flush || redirect);\n115:   end\n116: \n117: endmodule\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"// rtl/if_stage.sv\n//\n// Instruction fetch stage. Holds the PC register; the IF/ID payload\n// (pc + instr + valid) is *combinational* — there is no separate IF/ID\n// flop in this microarchitecture, the next-stage's ID/EX register\n// captures everything one cycle later.\n//\n// On flush or redirect, the instruction emitted to ID is forced to NOP\n// (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n// observing a real rs1/rs2 from a wrong-path instruction and inserting\n// a spurious load-use stall the cycle after a taken branch.\n//\n// Latency:        PC-reg update is synchronous; output is combinational.\n// RVFI fields:    feeds pc_rdata (via ID/EX/MEM/WB) and pc_wdata (via\n//                 EX-stage redirect).\nmodule if_stage (\n  input  logic              clock,\n  input  logic              reset,\n  input  logic              stall,            // hold PC (load-use)\n  input  logic              flush,            // emit NOP into ID this cycle","truncated":false,"loaded":[]},"title":"cores/bench/rtl/if_stage.sv","time":{"start":1778753512666,"end":1778753512682}},"id":"prt_e25f8a192001f1Ojtav3YycYvl","sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","messageID":"msg_e25f86010001rejW5ktX0FSie6"}}
{"type":"tool_use","timestamp":1778753513572,"sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","part":{"type":"tool","tool":"read","callID":"read:7","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/ex_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/ex_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/ex_stage.sv\n2: //\n3: // Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n4: // MEM/WB), runs the ALU, resolves branches, computes the redirect\n5: // target. Owns the EX/MEM pipeline register.\n6: //\n7: // Forwarding select encoding (driven by forward_unit):\n8: //   00 = ID/EX register value (no forward)\n9: //   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n10: //   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n11: //\n12: // Latency:        1 cycle (EX/MEM register clocked here).\n13: // RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n14: //                 ALU and JAL/JALR (PC+4), and the branch resolve.\n15: module ex_stage (\n16:   input  logic               clock,\n17:   input  logic               reset,\n18:   input  logic               stall,         // freeze EX/MEM register (dmem stall)\n19:   input  id_ex_t   in,\n20:   input  logic [1:0]         fwd_rs1_sel,\n21:   input  logic [1:0]         fwd_rs2_sel,\n22:   input  logic [31:0]        fwd_ex_mem,    // EX/MEM.alu_result (registered)\n23:   input  logic [31:0]        fwd_mem_wb,    // WB-stage write-data mux output\n24:   output ex_mem_t  out,\n25:   output logic               redirect,\n26:   output logic [31:0]        redirect_target,\n27:   // BHT update back to IF stage\n28:   output logic               bht_update_en,\n29:   output logic [4:0]         bht_update_idx,\n30:   output logic               bht_update_taken\n31: );\n32: \n33:   // ── Operand forwarding muxes ───────────────────────────────────────────\n34:   logic [31:0] rs1;\n35:   logic [31:0] rs2;\n36: \n37:   always_comb begin\n38:     case (fwd_rs1_sel)\n39:       2'd1:    rs1 = fwd_ex_mem;\n40:       2'd2:    rs1 = fwd_mem_wb;\n41:       default: rs1 = in.rs1_val;\n42:     endcase\n43:     case (fwd_rs2_sel)\n44:       2'd1:    rs2 = fwd_ex_mem;\n45:       2'd2:    rs2 = fwd_mem_wb;\n46:       default: rs2 = in.rs2_val;\n47:     endcase\n48:   end\n49: \n50:   // ── ALU operand selection ─────────────────────────────────────────────\n51:   logic [31:0] alu_a;\n52:   logic [31:0] alu_b;\n53:   always_comb begin\n54:     alu_a = in.ctrl.is_auipc ? in.pc  : rs1;\n55:     alu_b = in.ctrl.alu_src  ? in.imm : rs2;\n56:   end\n57: \n58:   logic [31:0] alu_result;\n59:   alu u_alu (\n60:     .op  (in.ctrl.alu_op),\n61:     .a   (alu_a),\n62:     .b   (alu_b),\n63:     .out (alu_result)\n64:   );\n65: \n66:   // ── Branch resolve ────────────────────────────────────────────────────\n67:   logic        branch_cond;\n68:   logic        branch_taken;\n69:   logic [31:0] branch_target;\n70:   logic [31:0] jump_target;\n71:   /* verilator lint_off UNUSEDSIGNAL */\n72:   logic [31:0] jalr_sum;  // bit 0 deliberately dropped per RV JALR spec\n73:   /* verilator lint_on UNUSEDSIGNAL */\n74: \n75:   always_comb begin\n76:     case (in.ctrl.branch_op)\n77:       BR_BEQ:  branch_cond = (rs1 == rs2);\n78:       BR_BNE:  branch_cond = (rs1 != rs2);\n79:       BR_BLT:  branch_cond = ($signed(rs1) <  $signed(rs2));\n80:       BR_BGE:  branch_cond = ($signed(rs1) >= $signed(rs2));\n81:       BR_BLTU: branch_cond = (rs1 <  rs2);\n82:       BR_BGEU: branch_cond = (rs1 >= rs2);\n83:       default: branch_cond = 1'b0;\n84:     endcase\n85:     branch_taken  = in.ctrl.is_branch && branch_cond;\n86:     branch_target = in.pc + in.imm;\n87:     // JALR clears bit 0 (RV spec); JAL uses imm directly.\n88:     jalr_sum    = rs1 + in.imm;\n89:     jump_target = in.ctrl.is_jalr ? {jalr_sum[31:1], 1'b0}\n90:                                   : (in.pc + in.imm);\n91:   end\n92: \n93:   // ── BHT update ────────────────────────────────────────────────────────\n94:   assign bht_update_en    = !stall && in.valid && in.ctrl.is_branch;\n95:   assign bht_update_idx   = in.pc[6:2];\n96:   assign bht_update_taken = branch_taken;\n97: \n98:   // ── Misaligned branch / jump target trap ──────────────────────────────\n99:   // riscv-formal's spec demands rvfi_trap=1 when next_pc is misaligned\n100:   // (without C extension that means [1:0] != 0). We trap the offending\n101:   // instruction, suppress the redirect (PC stays linear), and clear\n102:   // reg_write so JAL/JALR don't write the return address on trap.\n103:   //\n104:   // With the static predictor, a predicted-taken branch/jump that turns\n105:   // out to be misaligned must still redirect to pc+4 to squash the\n106:   // speculative fetch that already happened in IF.\n107:   logic misalign_branch;\n108:   logic misalign_jump;\n109:   logic misalign_fault;\n110:   logic pred_misalign_flush;\n111:   logic pred_wrong;          // predicted taken but doesn't actually change PC\n112:   logic unpred_taken;        // predicted not-taken but branch is actually taken\n113:   ctrl_t ctrl_with_trap;\n114: \n115:   always_comb begin\n116:     misalign_branch = in.ctrl.is_branch && branch_taken\n117:                       && (branch_target[1:0] != 2'b00);\n118:     misalign_jump   = in.ctrl.is_jump && (jump_target[1:0] != 2'b00);\n119:     misalign_fault  = misalign_branch || misalign_jump;\n120: \n121:     // If we predicted taken but target is misaligned, squash the\n122:     // speculative fetch by redirecting back to pc+4.\n123:     pred_misalign_flush = in.pred_taken && misalign_fault;\n124: \n125:     // Predicted taken but instruction is not a taken branch/jump.\n126:     // This covers mispredicted taken branches AND invalid instructions\n127:     // that IF mistakenly predicted (e.g. reserved branch funct3).\n128:     pred_wrong = in.pred_taken &&\n129:                  !((in.ctrl.is_branch && branch_taken) || in.ctrl.is_jump);\n130: \n131:     // Predicted not-taken but branch is actually taken.\n132:     unpred_taken = !in.pred_taken && in.ctrl.is_branch && branch_taken;\n133: \n134:     ctrl_with_trap = in.ctrl;\n135:     if (misalign_fault) begin\n136:       ctrl_with_trap.is_illegal = 1'b1;\n137:       ctrl_with_trap.reg_write  = 1'b0;\n138:     end\n139:   end\n140: \n141:   // Redirect on mispredict, JALR, or misaligned predicted-taken.\n142:   assign redirect        = (((pred_wrong || unpred_taken ||\n143:                              (in.ctrl.is_jump && in.ctrl.is_jalr)) &&\n144:                             !misalign_fault) ||\n145:                             pred_misalign_flush);\n146:   assign redirect_target = pred_misalign_flush ? (in.pc + 32'd4) :\n147:                            pred_wrong          ? (in.pc + 32'd4) :\n148:                            in.ctrl.is_jump     ? jump_target :\n149:                            branch_taken        ? branch_target :\n150:                                                  (in.pc + 32'd4);\n151: \n152:   // ── EX/MEM register ───────────────────────────────────────────────────\n153:   ex_mem_t reg_q;\n154: \n155:   always_ff @(posedge clock) begin\n156:     if (reset) begin\n157:       reg_q <= '0;\n158:     end else if (stall) begin\n159:       // dmem stall: hold the EX/MEM register so the in-flight LOAD/STORE\n160:       // stays in MEM stage waiting on the bus.\n161:       reg_q <= reg_q;\n162:     end else begin\n163:       reg_q.pc            <= in.pc;\n164:       // For JAL/JALR, the rd_wdata is PC+4 (return address), not the ALU's\n165:       // sum (which is the jump target). The MEM/WB register's read-data\n166:       // mux only kicks in for LOADs, so we route PC+4 here.\n167:       reg_q.alu_result    <= in.ctrl.is_jump ? (in.pc + 32'd4) : alu_result;\n168:       reg_q.write_data    <= rs2;\n169:       reg_q.rd            <= in.rd;\n170:       reg_q.rs1_addr      <= in.rs1_addr;\n171:       reg_q.rs2_addr      <= in.rs2_addr;\n172:       reg_q.rs1_val       <= rs1;\n173:       reg_q.rs2_val       <= rs2;\n174:       // pc_next reverts to pc+4 on misalign trap so the pc_fwd checker\n175:       // (asserting next retirement's pc_rdata == this pc_wdata) stays\n176:       // consistent with the suppressed redirect.\n177:       reg_q.pc_next       <= misalign_fault     ? (in.pc + 32'd4)\n178:                             : in.ctrl.is_jump   ? jump_target\n179:                             : branch_taken      ? branch_target\n180:                                                 : (in.pc + 32'd4);\n181:       reg_q.branch_taken  <= branch_taken;\n182:       reg_q.branch_target <= branch_target;\n183:       reg_q.ctrl          <= ctrl_with_trap;\n184:       reg_q.instr         <= in.instr;\n185:       reg_q.valid         <= in.valid;\n186:     end\n187:   end\n188: \n189:   assign out = reg_q;\n190: \n191: endmodule\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"// rtl/ex_stage.sv\n//\n// Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n// MEM/WB), runs the ALU, resolves branches, computes the redirect\n// target. Owns the EX/MEM pipeline register.\n//\n// Forwarding select encoding (driven by forward_unit):\n//   00 = ID/EX register value (no forward)\n//   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n//   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n//\n// Latency:        1 cycle (EX/MEM register clocked here).\n// RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n//                 ALU and JAL/JALR (PC+4), and the branch resolve.\nmodule ex_stage (\n  input  logic               clock,\n  input  logic               reset,\n  input  logic               stall,         // freeze EX/MEM register (dmem stall)\n  input  id_ex_t   in,\n  input  logic [1:0]         fwd_rs1_sel,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/ex_stage.sv","time":{"start":1778753513568,"end":1778753513571}},"id":"prt_e25f8a4dc001NR187Um1mu686a","sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","messageID":"msg_e25f86010001rejW5ktX0FSie6"}}
{"type":"tool_use","timestamp":1778753514403,"sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","part":{"type":"tool","tool":"read","callID":"read:8","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/hazard_unit.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/hazard_unit.sv</path>\n<type>file</type>\n<content>\n1: // rtl/hazard_unit.sv\n2: //\n3: // Detects the only data hazard the textbook 5-stage doesn't cover via\n4: // forwarding: load-use. A LOAD in EX produces its data only after MEM,\n5: // so an instruction immediately behind that consumes the LOAD's rd\n6: // must be stalled by exactly one cycle.\n7: //\n8: // Outputs:\n9: //   stall_if / stall_id : freeze the PC reg and the IF/ID combinational\n10: //                          payload (cleared by ID's flush input).\n11: //   flush_if / flush_id : on EX redirect, kill the two in-flight\n12: //                          instructions ahead of the redirect target.\n13: //   flush_id            : also kills ID's own register on load-use to\n14: //                          inject a single-cycle bubble between LOAD\n15: //                          and the dependent instruction.\n16: //\n17: // Latency:        combinational.\n18: // RVFI fields:    n/a (governs validity of subsequent retirements).\n19: module hazard_unit (\n20:   input  logic       id_ex_mem_read,    // ID/EX.ctrl.mem_read (LOAD in EX)\n21:   input  logic [4:0] id_ex_rd,          // ID/EX.rd            (LOAD's dest)\n22:   input  logic [4:0] if_id_rs1,         // IF/ID instr[19:15]  (next rs1)\n23:   input  logic [4:0] if_id_rs2,         // IF/ID instr[24:20]  (next rs2)\n24:   input  logic       redirect,          // EX has resolved a branch/jump\n25:   // Bus backpressure (default-1 in zero-wait testbenches; VexRiscv-style\n26:   // random ~22% stall in vex_main.cpp). When low, the corresponding\n27:   // memory request is NOT serviced this cycle.\n28:   input  logic       imem_ready,\n29:   input  logic       dmem_ready,\n30:   // EX/MEM has a memory op in flight (the LOAD/STORE the dmem stall\n31:   // would actually be holding up). Computed at top level from the\n32:   // EX/MEM register's ctrl.mem_read | ctrl.mem_write.\n33:   input  logic       ex_mem_mem_op,\n34:   output logic       stall_if,          // PC reg holds\n35:   output logic       stall_id,          // ID/EX register holds (vs. bubble)\n36:   output logic       flush_if,          // IF/ID comb output -> NOP\n37:   output logic       flush_id,          // ID/EX register captures '0\n38:   output logic       stall_ex_mem,      // EX/MEM register holds\n39:   output logic       hold_mem_wb        // MEM/WB clears valid only;\n40:                                         // data fields stay (for fwd)\n41: );\n42: \n43:   logic load_use_hazard;\n44:   logic imem_stall;\n45:   logic dmem_stall;\n46: \n47:   always_comb begin\n48:     load_use_hazard = id_ex_mem_read\n49:                    && (id_ex_rd == if_id_rs1 || id_ex_rd == if_id_rs2)\n50:                    && (id_ex_rd != 5'b0);\n51:     imem_stall = !imem_ready;\n52:     // dmem stall only matters if there's actually a memory op in EX/MEM\n53:     // — otherwise bus-not-ready is irrelevant to the pipeline.\n54:     dmem_stall = !dmem_ready && ex_mem_mem_op;\n55: \n56:     // PC reg holds on any stall reason.\n57:     stall_if      = load_use_hazard || imem_stall || dmem_stall;\n58:     // IF/ID combinational payload: NOP whenever we wouldn't have a valid\n59:     // instruction this cycle (redirect target unknown to IF, or imem\n60:     // didn't deliver).\n61:     flush_if      = redirect || imem_stall;\n62:     // ID/EX register:\n63:     //   - dmem_stall  -> hold        (preserve in-flight pipeline state)\n64:     //   - load_use    -> bubble      (1-cycle stall between LOAD + use)\n65:     //   - redirect    -> bubble      (kill wrong-path)\n66:     //   - otherwise   -> capture\n67:     // dmem_stall takes precedence over load_use's bubble: re-evaluate\n68:     // load_use next cycle when the bus unblocks. flush_id is 1 only when\n69:     // we want bubble (not hold).\n70:     stall_id      = dmem_stall || load_use_hazard;\n71:     flush_id      = (load_use_hazard || redirect) && !dmem_stall;\n72:     // EX/MEM register: holds on dmem_stall (LOAD waits in MEM until the\n73:     // bus delivers).\n74:     stall_ex_mem  = dmem_stall;\n75:     // MEM/WB register: on dmem_stall the previously-retired instruction's\n76:     // data fields stay alive for forwarding (e.g. a held BNE needs the\n77:     // LOAD's load_data via fwd_mem_wb), but valid is cleared so we don't\n78:     // double-retire / double-write the regfile.\n79:     hold_mem_wb   = dmem_stall;\n80:   end\n81: \n82: endmodule\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"// rtl/hazard_unit.sv\n//\n// Detects the only data hazard the textbook 5-stage doesn't cover via\n// forwarding: load-use. A LOAD in EX produces its data only after MEM,\n// so an instruction immediately behind that consumes the LOAD's rd\n// must be stalled by exactly one cycle.\n//\n// Outputs:\n//   stall_if / stall_id : freeze the PC reg and the IF/ID combinational\n//                          payload (cleared by ID's flush input).\n//   flush_if / flush_id : on EX redirect, kill the two in-flight\n//                          instructions ahead of the redirect target.\n//   flush_id            : also kills ID's own register on load-use to\n//                          inject a single-cycle bubble between LOAD\n//                          and the dependent instruction.\n//\n// Latency:        combinational.\n// RVFI fields:    n/a (governs validity of subsequent retirements).\nmodule hazard_unit (\n  input  logic       id_ex_mem_read,    // ID/EX.ctrl.mem_read (LOAD in EX)","truncated":false,"loaded":[]},"title":"cores/bench/rtl/hazard_unit.sv","time":{"start":1778753514388,"end":1778753514402}},"id":"prt_e25f8a860002jZKc1OB9h0t0OE","sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","messageID":"msg_e25f86010001rejW5ktX0FSie6"}}
{"type":"tool_use","timestamp":1778753515017,"sessionID":"ses_1da08a9b3ffeiE0K02BupWfSfi","part":{"type":"tool","tool":"read","callID":"read:9","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/mem_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/mem_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/mem_stage.sv\n2: //\n3: // Memory access stage. Drives the dmem read/write ports combinationally\n4: // from the EX/MEM register, and sign/zero-extends the loaded data into\n5: // the MEM/WB register.\n6: //\n7: // Byte-lane discipline:\n8: //   - Write data is replicated across all four byte lanes; the\n9: //     byte-mask (mem_wmask) selects the actual destination bytes.\n10: //   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n11: //     zero-extend the low 8/16 bits per the LB/LBU/LH/LHU encoding.\n12: //   - For RVFI ALIGNED_MEM, mem_addr is reported word-aligned and the\n13: //     byte position is captured in mem_rmask / mem_wmask.\n14: //\n15: // Latency:        1 cycle (MEM/WB register clocked here).\n16: // RVFI fields:    feeds mem_addr, mem_rmask, mem_wmask, mem_rdata,\n17: //                 mem_wdata, plus rd_wdata via the loaded-data path.\n18: module mem_stage (\n19:   input  logic               clock,\n20:   input  logic               reset,\n21:   // hold_wb: dmem stall is in effect. MEM/WB's data fields are RETAINED\n22:   // (so the previously-retired LOAD's `rd` / `read_data` / `ctrl.reg_write`\n23:   // remain visible to forward_unit), but `valid` is cleared so:\n24:   //   - rvfi_order doesn't increment for held cycles\n25:   //   - wb_stage doesn't write the regfile twice\n26:   // Zeroing the whole register would lose the LOAD's load_data, breaking\n27:   // MEM/WB->EX forwarding for any dependent instruction that's also held\n28:   // in ID/EX during the stall (e.g. a BNE that consumes a LOAD's result).\n29:   input  logic               hold_wb,\n30:   // ex_mem_t carries branch_taken / branch_target / pc_next / rs?_val\n31:   // for downstream RVFI use; mem_stage only consumes a subset, so the\n32:   // remaining fields look unused from this module's perspective.\n33:   /* verilator lint_off UNUSEDSIGNAL */\n34:   input  ex_mem_t  in,\n35:   /* verilator lint_on UNUSEDSIGNAL */\n36:   // dmem interface\n37:   output logic [31:0]        dmem_addr,\n38:   output logic [31:0]        dmem_wdata,\n39:   input  logic [31:0]        dmem_rdata,\n40:   output logic [3:0]         dmem_wen,\n41:   output logic               dmem_ren,\n42:   // MEM/WB register output\n43:   output mem_wb_t  out\n44: );\n45: \n46:   logic [31:0] wdata_rep;\n47:   logic [3:0]  byte_mask;\n48:   logic [31:0] aligned_addr;\n49:   // shifted[31:16] is dropped on byte/halfword loads; only [15:0] feeds\n50:   // the sign/zero-extension mux.\n51:   /* verilator lint_off UNUSEDSIGNAL */\n52:   logic [31:0] shifted;\n53:   /* verilator lint_on UNUSEDSIGNAL */\n54:   logic [7:0]  byte_val;\n55:   logic [15:0] hword_val;\n56:   logic [31:0] load_data;\n57: \n58:   // Misaligned mem-access trap. RV32I requires word-aligned LW/SW and\n59:   // halfword-aligned LH/LHU/SH; byte ops are always aligned.\n60:   // riscv-formal's RISCV_FORMAL_ALIGNED_MEM contract demands rvfi_trap=1\n61:   // when the effective byte address is not aligned to the access width.\n62:   // On trap, the dmem ports are gated off and ctrl propagates is_illegal.\n63:   logic mem_misalign;\n64:   logic mem_op;\n65:   ctrl_t ctrl_with_trap;\n66: \n67:   always_comb begin\n68:     // Byte/halfword replication for stores.\n69:     case (in.ctrl.mem_width)\n70:       2'd0:    wdata_rep = {4{in.write_data[7:0]}};\n71:       2'd1:    wdata_rep = {2{in.write_data[15:0]}};\n72:       default: wdata_rep = in.write_data;\n73:     endcase\n74: \n75:     // Byte-lane mask shifted to addr[1:0] * 1.\n76:     case (in.ctrl.mem_width)\n77:       2'd0:    byte_mask = (4'b0001 << in.alu_result[1:0]);\n78:       2'd1:    byte_mask = (4'b0011 << in.alu_result[1:0]);\n79:       default: byte_mask = 4'b1111;\n80:     endcase\n81: \n82:     mem_op       = in.ctrl.mem_read || in.ctrl.mem_write;\n83:     mem_misalign = mem_op && (\n84:                      (in.ctrl.mem_width == 2'd2 && in.alu_result[1:0] != 2'b00) ||\n85:                      (in.ctrl.mem_width == 2'd1 && in.alu_result[0]   != 1'b0)\n86:                      // 2'd0 (byte) is never misaligned.\n87:                    );\n88: \n89:     ctrl_with_trap = in.ctrl;\n90:     if (mem_misalign) begin\n91:       ctrl_with_trap.is_illegal = 1'b1;\n92:       ctrl_with_trap.reg_write  = 1'b0;\n93:     end\n94: \n95:     // Combinational dmem outputs — gated off on misalign.\n96:     dmem_addr  = in.alu_result;\n97:     dmem_wdata = wdata_rep;\n98:     dmem_wen   = (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n99:     dmem_ren   = in.ctrl.mem_read  && !mem_misalign;\n100: \n101:     // Load extraction: shift right then sign/zero-extend the low N bits.\n102:     shifted   = dmem_rdata >> (in.alu_result[1:0] * 8);\n103:     byte_val  = shifted[7:0];\n104:     hword_val = shifted[15:0];\n105:     case (in.ctrl.mem_width)\n106:       2'd0:    load_data = in.ctrl.mem_sext\n107:                          ? {{24{byte_val[7]}},  byte_val}\n108:                          : {24'b0,              byte_val};\n109:       2'd1:    load_data = in.ctrl.mem_sext\n110:                          ? {{16{hword_val[15]}}, hword_val}\n111:                          : {16'b0,               hword_val};\n112:       default: load_data = dmem_rdata;\n113:     endcase\n114: \n115:     // RVFI ALIGNED_MEM expects word-aligned mem_addr; mem_addr=0 if no access.\n116:     aligned_addr = (mem_op && !mem_misalign)\n117:                  ? {in.alu_result[31:2], 2'b00}\n118:                  : 32'b0;\n119:   end\n120: \n121:   // ── MEM/WB register ───────────────────────────────────────────────────\n122:   mem_wb_t reg_q;\n123: \n124:   always_ff @(posedge clock) begin\n125:     if (reset) begin\n126:       reg_q <= '0;\n127:     end else if (hold_wb) begin\n128:       // Clear valid (no double-retire / no double-regfile-write), but\n129:       // KEEP every other field. Forwarding from MEM/WB to a stalled\n130:       // dependent in ID/EX needs the held LOAD's rd/read_data/ctrl\n131:       // alive for as many cycles as the dmem stall lasts.\n132:       reg_q.valid <= 1'b0;\n133:     end else begin\n134:       reg_q.pc         <= in.pc;\n135:       reg_q.alu_result <= in.alu_result;\n136:       reg_q.read_data  <= load_data;\n137:       reg_q.rd         <= in.rd;\n138:       reg_q.rs1_addr   <= in.rs1_addr;\n139:       reg_q.rs2_addr   <= in.rs2_addr;\n140:       reg_q.rs1_val    <= in.rs1_val;\n141:       reg_q.rs2_val    <= in.rs2_val;\n142:       reg_q.pc_next    <= in.pc_next;\n143:       reg_q.mem_addr   <= aligned_addr;\n144:       reg_q.mem_rdata  <= dmem_rdata;\n145:       reg_q.mem_wdata  <= wdata_rep;\n146:       reg_q.mem_wmask  <= (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n147:       reg_q.mem_rmask  <= (in.ctrl.mem_read  && !mem_misalign) ? byte_mask : 4'b0000;\n148:       reg_q.ctrl       <= ctrl_with_trap;\n149:       reg_q.instr      <= in.instr;\n150:       reg_q.valid      <= in.valid;\n151:     end\n152:   end\n153: \n154:   assign out = reg_q;\n155: \n156: endmodule\n\n(End of file - total 156 lines)\n</content>","metadata":{"preview":"// rtl/mem_stage.sv\n//\n// Memory access stage. Drives the dmem read/write ports combinationally\n// from the EX/MEM register, and sign/zero-extends the loaded data into\n// the MEM/WB register.\n//\n// Byte-lane discipline:\n//   - Write data is replicated across all four byte lanes; the\n//     byte-mask (mem_wmask) selects the actual destination bytes.\n//   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n//     zer