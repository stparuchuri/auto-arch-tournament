{"type":"tool_use","timestamp":1778749729191,"sessionID":"ses_1da496f0affe1xo1ihroyY0XWo","part":{"type":"tool","tool":"read","callID":"functions.read:7","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/test/cosim/main.cpp"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/test/cosim/main.cpp</path>\n<type>file</type>\n<content>\n1: #include <iostream>\n2: #include <fstream>\n3: #include <string>\n4: #include <vector>\n5: #include <cstdint>\n6: #include <cstring>\n7: #include \"Vcore.h\"\n8: #include \"verilated.h\"\n9: \n10: struct ELF {\n11:     std::vector<uint8_t> data;\n12:     uint32_t entry = 0;\n13:     void load(const char* path) {\n14:         std::ifstream f(path, std::ios::binary);\n15:         data.assign(std::istreambuf_iterator<char>(f), {});\n16:         if (data.size() < 52) return;\n17:         entry = *reinterpret_cast<uint32_t*>(&data[24]);\n18:     }\n19:     uint32_t phoff()     { return *reinterpret_cast<uint32_t*>(&data[28]); }\n20:     uint16_t phentsize() { return *reinterpret_cast<uint16_t*>(&data[42]); }\n21:     uint16_t phnum()     { return *reinterpret_cast<uint16_t*>(&data[44]); }\n22: };\n23: \n24: static constexpr uint32_t MEM_SIZE = 1u << 20;  // 1 MiB\n25: static uint8_t imem[MEM_SIZE] = {};\n26: static uint8_t dmem[MEM_SIZE] = {};\n27: static bool oob_access = false;  // sticky: once set, final marker reports it\n28: \n29: static bool in_uart_range(uint32_t a) { return (a & 0xFFF00000u) == 0x10000000u; }\n30: static bool in_mem_range (uint32_t a) { return a < MEM_SIZE; }\n31: \n32: // Benchmark-time MMIO markers. CoreMark's portme.c writes to BENCH_START\n33: // from start_time() and BENCH_STOP from stop_time(); the sim records the\n34: // cycle count at each write so run_fpga_eval can compute\n35: // bench_cycles = stop - start, excluding init/CRC-printing overhead.\n36: static constexpr uint32_t BENCH_START_ADDR = 0x10000100u;\n37: static constexpr uint32_t BENCH_STOP_ADDR  = 0x10000104u;\n38: \n39: uint32_t rw(uint8_t* m, uint32_t a) {\n40:     a &= 0xFFFFC;\n41:     return m[a]|(m[a+1]<<8)|(m[a+2]<<16)|(m[a+3]<<24);\n42: }\n43: void ww(uint8_t* m, uint32_t a, uint32_t v, uint8_t mask) {\n44:     a &= 0xFFFFC;\n45:     for(int i=0;i<4;i++) if((mask>>i)&1) m[a+i]=(v>>(i*8))&0xFF;\n46: }\n47: \n48: // VexRiscv-style random bus backpressure model (regression/main.cpp:2079).\n49: // xorshift7 LFSR; accept request when (state & 0x7F) < 100 (~78% accept,\n50: // ~22% stall). Replicating exactly so CoreMark/MHz numbers from this\n51: // cosim are directly comparable to VexRiscv's published \"full no cache,\n52: // 2.30\" — which is measured under iStall+dStall enabled.\n53: static uint32_t lfsr_state_main = 0xDEADBEEFu;\n54: static bool bus_accepts_main() {\n55:     lfsr_state_main ^= lfsr_state_main << 13;\n56:     lfsr_state_main ^= lfsr_state_main >> 17;\n57:     lfsr_state_main ^= lfsr_state_main << 5;\n58:     return (lfsr_state_main & 0x7Fu) < 100u;\n59: }\n60: \n61: int main(int argc, char** argv) {\n62:     if(argc < 2) {\n63:         std::cerr << \"usage: sim <elf> [maxcycles] [--bench] [--istall] [--dstall] [--seed N]\\n\";\n64:         return 1;\n65:     }\n66:     uint64_t maxcycles = argc > 2 ? atoll(argv[2]) : 50000000ULL;\n67:     // --bench:  suppress per-retirement output; print only the final record.\n68:     // --istall: random ~22% imem-bus backpressure (VexRiscv-style).\n69:     // --dstall: same on dmem bus. The orchestrator's fitness eval\n70:     //           (tools/eval/fpga.py:run_coremark_ipc) passes BOTH so the\n71:     //           CoreMark/MHz number we score against matches VexRiscv's\n72:     //           published methodology rather than a zero-wait fantasy bus.\n73:     bool bench_mode = false;\n74:     bool istall = false;\n75:     bool dstall = false;\n76:     for (int i = 1; i < argc; i++) {\n77:         if      (std::strcmp(argv[i], \"--bench\")  == 0) bench_mode = true;\n78:         else if (std::strcmp(argv[i], \"--istall\") == 0) istall     = true;\n79:         else if (std::strcmp(argv[i], \"--dstall\") == 0) dstall     = true;\n80:         else if (std::strcmp(argv[i], \"--seed\")   == 0 && i + 1 < argc)\n81:             lfsr_state_main = (uint32_t)atoll(argv[++i]);\n82:     }\n83: \n84:     ELF elf; elf.load(argv[1]);\n85:     for(int i=0;i<elf.phnum();i++){\n86:         uint32_t off    = elf.phoff() + i*elf.phentsize();\n87:         uint32_t type   = *reinterpret_cast<uint32_t*>(&elf.data[off]);\n88:         uint32_t foff   = *reinterpret_cast<uint32_t*>(&elf.data[off+4]);\n89:         uint32_t vaddr  = *reinterpret_cast<uint32_t*>(&elf.data[off+8]);\n90:         uint32_t filesz = *reinterpret_cast<uint32_t*>(&elf.data[off+16]);\n91:         if(type==1 && vaddr < (1<<20)) {\n92:             memcpy(imem+vaddr, elf.data.data()+foff, filesz);\n93:             memcpy(dmem+vaddr, elf.data.data()+foff, filesz);\n94:         }\n95:     }\n96: \n97:     Verilated::commandArgs(argc, argv);\n98:     Vcore* top = new Vcore;\n99:     top->reset = 1; top->clock = 0;\n100:     top->io_imemReady = 1;\n101:     top->io_dmemReady = 1;\n102:     for(int i=0;i<5;i++){top->clock=0;top->eval();top->clock=1;top->eval();}\n103:     top->reset = 0;\n104: \n105:     char bench_last[512] = {};\n106:     bool hit_ebreak = false;\n107:     // UART capture: writes to 0x10000000 go to stdout as characters, not dmem.\n108:     // CoreMark's portme.c redirects ee_printf through this MMIO so the bench\n109:     // driver can parse \"CoreMark Size\"/\"ERROR!\" banners for CRC validation.\n110:     std::string uart_buf;\n111:     uint64_t bench_start_cycle = 0, bench_stop_cycle = 0;\n112:     bool     bench_start_set = false, bench_stop_set = false;\n113:     for(uint64_t cycle=0; cycle<maxcycles; cycle++) {\n114:         top->clock = 0;\n115:         // Bus backpressure. Same VexRiscv-style ~22% accept-fail rate on\n116:         // both imem and dmem when the corresponding flag is on. Drives 1\n117:         // (zero-wait) by default so existing selftest cosim runs aren't\n118:         // slowed down by unrelated stalls.\n119:         top->io_imemReady = istall ? bus_accepts_main() : 1;\n120:         top->io_dmemReady = dstall ? bus_accepts_main() : 1;\n121:         // Bounds checks: silent wraparound used to mask CPU effective-address bugs\n122:         // (both sim and reference aliased identically, so cosim would still pass).\n123:         // Flag OOB so the testbench reports it and returns non-zero.\n124:         //   - imem: PC should always be in range; flag every fetch outside.\n125:         //   - dmem read: ANY read outside [0, MEM_SIZE) is OOB — including\n126:         //     the UART range, which is write-only. Reads from UART used to\n127:         //     silently alias to dmem[addr & 0xFFFFC] and not flag oob_access,\n128:         //     diverging from reference.py which DOES flag them. Now both agree:\n129:         //     UART reads flag oob and return 0.\n130:         //   - dmem write: UART range is allowed (TX); BENCH_START/STOP are\n131:         //     allowed (markers); anything else outside dmem is OOB (handled\n132:         //     in the dmem-write block below — kept BEFORE the clock posedge so\n133:         //     a STORE that's accepted on the cycle dmem_ready transitions\n134:         //     0->1 doesn't disappear when EX/MEM advances at posedge).\n135:         if (!in_mem_range(top->io_imemAddr)) oob_access = true;\n136:         top->io_imemData  = rw(imem, top->io_imemAddr);\n137:         if (in_mem_range(top->io_dmemAddr)) {\n138:             top->io_dmemRData = rw(dmem, top->io_dmemAddr);\n139:         } else {\n140:             top->io_dmemRData = 0;\n141:             if (top->io_dmemREn) oob_access = true;\n142:         }\n143:         top->eval();\n144: \n145:         // Process dmem writes BEFORE the clock posedge — see the matching\n146:         // commit on test/cosim/vex_main.cpp for the timing-bug rationale:\n147:         // post-posedge sampling drops STOREs that get accepted on the\n148:         // cycle dmem_ready transitions 0 -> 1.\n149:         if(top->io_dmemWEn && top->io_dmemReady) {\n150:             // MMIO UART at 0x10000000: capture to uart_buf, don't route to dmem\n151:             // (a non-gated ww() would wrap 0x10000000 to dmem[0] and corrupt it).\n152:             // BENCH_START/BENCH_STOP markers at 0x10000100 / 0x10000104: record\n153:             // cycle counts so the bench harness can bracket the benchmark loop\n154:             // and exclude CoreMark init/CRC-printing from the timing window.\n155:             uint32_t addr = top->io_dmemAddr;\n156:             if (addr == BENCH_START_ADDR) {\n157:                 if (!bench_start_set) { bench_start_cycle = cycle; bench_start_set = true; }\n158:             } else if (addr == BENCH_STOP_ADDR) {\n159:                 // Last stop_time() call wins — CoreMark calls it once, but\n160:                 // tolerate multiple if a bench program re-times.\n161:                 bench_stop_cycle = cycle; bench_stop_set = true;\n162:             } else if (in_uart_range(addr)) {\n163:                 for (int i = 0; i < 4; i++) {\n164:                     if ((top->io_dmemWEn >> i) & 1) {\n165:                         char c = (top->io_dmemWData >> (i * 8)) & 0xFF;\n166:                         if (c) uart_buf.push_back(c);\n167:                     }\n168:                 }\n169:             } else if (in_mem_range(addr)) {\n170:                 ww(dmem, addr, top->io_dmemWData, top->io_dmemWEn);\n171:             } else {\n172:                 // OOB write (neither dmem nor UART). Flag so testbench reports it.\n173:                 oob_access = true;\n174:             }\n175:         }\n176: \n177:         top->clock = 1; top->eval();\n178: \n179:         // Drain channel 0 then channel 1 (NRET=2 contract). For V0\n180:         // single-issue, channel 1's valid is always 0, so the JSON stream\n181:         // is byte-identical to the pre-NRET=2 baseline.\n182:         auto emit = [&](uint8_t  v,\n183:                         uint64_t order,\n184:                         uint32_t insn,\n185:                         uint32_t pc_rdata, uint32_t pc_wdata,\n186:                         uint8_t  rd_addr,  uint32_t rd_wdata,\n187:                         uint8_t  rs1_addr, uint32_t rs1_rdata,\n188:                         uint8_t  rs2_addr, uint32_t rs2_rdata,\n189:                         uint32_t mem_addr,\n190:                         uint8_t  mem_rmask, uint32_t mem_rdata,\n191:                         uint8_t  mem_wmask, uint32_t mem_wdata,\n192:                         uint8_t  trap, uint8_t halt, uint8_t intr,\n193:                         uint8_t  mode, uint8_t ixl) -> bool {\n194:             if (!v) return false;\n195:             char buf[640];\n196:             snprintf(buf, sizeof(buf),\n197:                 \"{\\\"order\\\":%llu,\\\"cycle\\\":%llu,\\\"insn\\\":%u,\\\"pc_rdata\\\":%u,\\\"pc_wdata\\\":%u,\"\n198:                 \"\\\"rd_addr\\\":%u,\\\"rd_wdata\\\":%u,\"\n199:                 \"\\\"rs1_addr\\\":%u,\\\"rs1_rdata\\\":%u,\"\n200:                 \"\\\"rs2_addr\\\":%u,\\\"rs2_rdata\\\":%u,\"\n201:                 \"\\\"mem_addr\\\":%u,\\\"mem_rmask\\\":%u,\\\"mem_rdata\\\":%u,\"\n202:                 \"\\\"mem_wmask\\\":%u,\\\"mem_wdata\\\":%u,\"\n203:                 \"\\\"trap\\\":%u,\\\"halt\\\":%u,\\\"intr\\\":%u,\\\"mode\\\":%u,\\\"ixl\\\":%u}\",\n204:                 (unsigned long long)order,\n205:                 (unsigned long long)cycle,\n206:                 insn, pc_rdata, pc_wdata,\n207:                 rd_addr, rd_wdata,\n208:                 rs1_addr, rs1_rdata,\n209:                 rs2_addr, rs2_rdata,\n210:                 mem_addr, mem_rmask, mem_rdata,\n211:                 mem_wmask, mem_wdata,\n212:                 (unsigned)trap, (unsigned)halt, (unsigned)intr,\n213:                 (unsigned)mode, (unsigned)ixl);\n214:             if (bench_mode) {\n215:                 strncpy(bench_last, buf, sizeof(bench_last)-1);\n216:                 if (insn == 0x00100073) { hit_ebreak = true; return true; }\n217:             } else {\n218:                 puts(buf);\n219:                 fflush(stdout);\n220:                 if (insn == 0x00100073) { hit_ebreak = true; return true; }\n221:             }\n222:             return false;\n223:         };\n224: \n225:         if (emit(top->io_rvfi_valid_0, top->io_rvfi_order_0, top->io_rvfi_insn_0,\n226:                  top->io_rvfi_pc_rdata_0, top->io_rvfi_pc_wdata_0,\n227:                  top->io_rvfi_rd_addr_0, top->io_rvfi_rd_wdata_0,\n228:                  top->io_rvfi_rs1_addr_0, top->io_rvfi_rs1_rdata_0,\n229:                  top->io_rvfi_rs2_addr_0, top->io_rvfi_rs2_rdata_0,\n230:                  top->io_rvfi_mem_addr_0,\n231:                  top->io_rvfi_mem_rmask_0, top->io_rvfi_mem_rdata_0,\n232:                  top->io_rvfi_mem_wmask_0, top->io_rvfi_mem_wdata_0,\n233:                  top->io_rvfi_trap_0, top->io_rvfi_halt_0, top->io_rvfi_intr_0,\n234:                  top->io_rvfi_mode_0, top->io_rvfi_ixl_0)) break;\n235: #if NRET >= 2\n236:         // Channel 1 — only present when the core is built with nret: 2.\n237:         // Cores declared nret: 1 expose no `_1` ports, so verilator's\n238:         // generated Vcore.h omits these fields and the build is keyed\n239:         // off the NRET macro injected by test/cosim/build.sh.\n240:         if (emit(top->io_rvfi_valid_1, top->io_rvfi_order_1, top->io_rvfi_insn_1,\n241:                  top->io_rvfi_pc_rdata_1, top->io_rvfi_pc_wdata_1,\n242:                  top->io_rvfi_rd_addr_1, top->io_rvfi_rd_wdata_1,\n243:                  top->io_rvfi_rs1_addr_1, top->io_rvfi_rs1_rdata_1,\n244:                  top->io_rvfi_rs2_addr_1, top->io_rvfi_rs2_rdata_1,\n245:                  top->io_rvfi_mem_addr_1,\n246:                  top->io_rvfi_mem_rmask_1, top->io_rvfi_mem_rdata_1,\n247:                  top->io_rvfi_mem_wmask_1, top->io_rvfi_mem_wdata_1,\n248:                  top->io_rvfi_trap_1, top->io_rvfi_halt_1, top->io_rvfi_intr_1,\n249:                  top->io_rvfi_mode_1, top->io_rvfi_ixl_1)) break;\n250: #endif\n251:     }\n252:     if (bench_mode) {\n253:         // Emit final record, plus an explicit completion marker. Consumers MUST\n254:         // check \"ebreak\":true before trusting the cycle count — otherwise the\n255:         // benchmark hit maxcycles without completing and the reading is invalid.\n256:         if (bench_last[0]) puts(bench_last);\n257:         // Escape backslash/quote/newline in uart_buf for JSON string safety.\n258:         std::string esc;\n259:         for (char c : uart_buf) {\n260:             if (c == '\\\\' || c == '\"') { esc.push_back('\\\\'); esc.push_back(c); }\n261:             else if (c == '\\n') { esc += \"\\\\n\"; }\n262:             else if (c == '\\r') { esc += \"\\\\r\"; }\n263:             else if (c == '\\t') { esc += \"\\\\t\"; }\n264:             else if (c >= 0x20 && c < 0x7F) { esc.push_back(c); }\n265:             // drop other non-printables silently\n266:         }\n267:         printf(\"{\\\"ebreak\\\":%s,\\\"maxcycles_hit\\\":%s,\\\"oob\\\":%s,\"\n268:                \"\\\"bench_start_cycle\\\":%llu,\\\"bench_stop_cycle\\\":%llu,\"\n269:                \"\\\"bench_bracketed\\\":%s,\\\"uart\\\":\\\"%s\\\"}\\n\",\n270:                hit_ebreak ? \"true\" : \"false\",\n271:                hit_ebreak ? \"false\" : \"true\",\n272:                oob_access ? \"true\" : \"false\",\n273:                (unsigned long long)bench_start_cycle,\n274:                (unsigned long long)bench_stop_cycle,\n275:                (bench_start_set && bench_stop_set) ? \"true\" : \"false\",\n276:                esc.c_str());\n277:     }\n278:     delete top;\n279:     // Non-zero exit if sim ran out of cycles OR an out-of-bounds memory\n280:     // access occurred. OOB historically silently aliased to dmem[0] which\n281:     // could mask CPU effective-address bugs — now it fails loud.\n282:     if (!hit_ebreak) return 2;\n283:     if (oob_access)  return 3;\n284:     return 0;\n285: }\n\n(End of file - total 285 lines)\n</content>","metadata":{"preview":"#include <iostream>\n#include <fstream>\n#include <string>\n#include <vector>\n#include <cstdint>\n#include <cstring>\n#include \"Vcore.h\"\n#include \"verilated.h\"\n\nstruct ELF {\n    std::vector<uint8_t> data;\n    uint32_t entry = 0;\n    void load(const char* path) {\n        std::ifstream f(path, std::ios::binary);\n        data.assign(std::istreambuf_iterator<char>(f), {});\n        if (data.size() < 52) return;\n        entry = *reinterpret_cast<uint32_t*>(&data[24]);\n    }\n    uint32_t phoff()     { return *reinterpret_cast<uint32_t*>(&data[28]); }\n    uint16_t phentsize() { return *reinterpret_cast<uint16_t*>(&data[42]); }","truncated":false,"loaded":[]},"title":"test/cosim/main.cpp","time":{"start":1778749729171,"end":1778749729189}},"id":"prt_e25bee76d001DzSEIsWE3r05xv","sessionID":"ses_1da496f0affe1xo1ihroyY0XWo","messageID":"msg_e25be7943001rhsbFBCtt0BuL0"}}
