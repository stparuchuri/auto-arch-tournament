{"type":"tool_use","timestamp":1778733592421,"sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","part":{"type":"tool","tool":"read","callID":"read:2","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/core_pkg.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/core_pkg.sv</path>\n<type>file</type>\n<content>\n1: // rtl/core_pkg.sv\n2: //\n3: // Core-wide constants and pipeline-bundle types.\n4: //\n5: // Compilation-unit scope (no `package … endpackage` wrapper) because\n6: // Yosys's Verilog frontend rejects `import pkg::*;` even though it\n7: // accepts `pkg::sym` refs and package definitions. A file-scope\n8: // definition with an `\\`ifndef` guard is the lowest common denominator\n9: // across Verilator, Yosys, sby, and nextpnr-himbaechel.\n10: //\n11: // Order matters: this file MUST be the first source passed to any tool\n12: // (Verilator/cocotb runner / build.sh / formal staging). Subsequent\n13: // includes hit the guard and become no-ops.\n14: //\n15: // Latency:        n/a (declarations only).\n16: // RVFI fields:    none (defines types; no logic).\n17: `ifndef CORE_PKG_DEFINED\n18: `define CORE_PKG_DEFINED\n19: \n20:   // ── ALU operations ──────────────────────────────────────────────────────\n21:   localparam logic [4:0] ALU_ADD    = 5'd0;\n22:   localparam logic [4:0] ALU_SUB    = 5'd1;\n23:   localparam logic [4:0] ALU_AND    = 5'd2;\n24:   localparam logic [4:0] ALU_OR     = 5'd3;\n25:   localparam logic [4:0] ALU_XOR    = 5'd4;\n26:   localparam logic [4:0] ALU_SLT    = 5'd5;\n27:   localparam logic [4:0] ALU_SLTU   = 5'd6;\n28:   localparam logic [4:0] ALU_SLL    = 5'd7;\n29:   localparam logic [4:0] ALU_SRL    = 5'd8;\n30:   localparam logic [4:0] ALU_SRA    = 5'd9;\n31:   localparam logic [4:0] ALU_LUI    = 5'd10;\n32:   localparam logic [4:0] ALU_MUL    = 5'd11;\n33:   localparam logic [4:0] ALU_MULH   = 5'd12;\n34:   localparam logic [4:0] ALU_MULHU  = 5'd13;\n35:   localparam logic [4:0] ALU_MULHSU = 5'd14;\n36:   localparam logic [4:0] ALU_DIV    = 5'd15;\n37:   localparam logic [4:0] ALU_DIVU   = 5'd16;\n38:   localparam logic [4:0] ALU_REM    = 5'd17;\n39:   localparam logic [4:0] ALU_REMU   = 5'd18;\n40: \n41:   // ── Branch operations (encoded = funct3 of BRANCH opcode) ───────────────\n42:   // Phase 1 only references BR_BEQ (decoder default). The rest are\n43:   // referenced by the EX-stage comparator in phase 2; we keep them here\n44:   // for documentation and silence UNUSEDPARAM until then.\n45:   localparam logic [2:0] BR_BEQ  = 3'd0;\n46:   /* verilator lint_off UNUSEDPARAM */\n47:   localparam logic [2:0] BR_BNE  = 3'd1;\n48:   localparam logic [2:0] BR_BLT  = 3'd4;\n49:   localparam logic [2:0] BR_BGE  = 3'd5;\n50:   localparam logic [2:0] BR_BLTU = 3'd6;\n51:   localparam logic [2:0] BR_BGEU = 3'd7;\n52:   /* verilator lint_on UNUSEDPARAM */\n53: \n54:   // ── Pipeline-bundle typedefs ────────────────────────────────────────────\n55:   typedef struct packed {\n56:     logic [4:0] alu_op;\n57:     logic       alu_src;     // 0 = rs2 value, 1 = immediate\n58:     logic [2:0] branch_op;\n59:     logic       is_branch;\n60:     logic       is_jump;\n61:     logic       is_jalr;\n62:     logic       is_lui;\n63:     logic       is_auipc;\n64:     logic       mem_read;\n65:     logic       mem_write;\n66:     logic [1:0] mem_width;   // 0 = byte, 1 = half, 2 = word\n67:     logic       mem_sext;    // sign-extend load result\n68:     logic       reg_write;\n69:     logic       mem_to_reg;  // 1 = write loaded data, 0 = write ALU result\n70:     logic       is_illegal;  // default-true in decoder; cleared inside\n71:                               // validated opcode/funct arms only.\n72:   } ctrl_t;\n73: \n74:   // IF -> ID combinational bundle (no register; PC reg sits in if_stage).\n75:   typedef struct packed {\n76:     logic [31:0] pc;\n77:     logic [31:0] instr;\n78:     logic        valid;\n79:     logic        pred_taken;  // static prediction: 1 for backward branches / JAL\n80:   } if_id_t;\n81: \n82:   // ID/EX register payload.\n83:   typedef struct packed {\n84:     logic [31:0] pc;\n85:     logic [31:0] rs1_val;\n86:     logic [31:0] rs2_val;\n87:     logic [31:0] imm;\n88:     logic [4:0]  rd;\n89:     logic [4:0]  rs1_addr;\n90:     logic [4:0]  rs2_addr;\n91:     ctrl_t       ctrl;\n92:     logic [31:0] instr;\n93:     logic        valid;\n94:     logic        pred_taken;  // prediction threaded from IF\n95:   } id_ex_t;\n96: \n97:   // EX/MEM register payload.\n98:   typedef struct packed {\n99:     logic [31:0] pc;\n100:     logic [31:0] alu_result;\n101:     logic [31:0] write_data;     // raw rs2 (post-forward), pre byte replication\n102:     logic [4:0]  rd;\n103:     logic [4:0]  rs1_addr;\n104:     logic [4:0]  rs2_addr;\n105:     logic [31:0] rs1_val;        // post-forward rs1 used by EX\n106:     logic [31:0] rs2_val;        // post-forward rs2 used by EX\n107:     logic [31:0] pc_next;        // resolved next-PC (target / pc+4)\n108:     logic        branch_taken;\n109:     logic [31:0] branch_target;\n110:     ctrl_t       ctrl;\n111:     logic [31:0] instr;\n112:     logic        valid;\n113:   } ex_mem_t;\n114: \n115:   // MEM/WB register payload — mirrors the RVFI-feeding contract.\n116:   typedef struct packed {\n117:     logic [31:0] pc;\n118:     logic [31:0] alu_result;\n119:     logic [31:0] read_data;      // sign/zero-extended load (for regfile write)\n120:     logic [4:0]  rd;\n121:     logic [4:0]  rs1_addr;\n122:     logic [4:0]  rs2_addr;\n123:     logic [31:0] rs1_val;\n124:     logic [31:0] rs2_val;\n125:     logic [31:0] pc_next;\n126:     logic [31:0] mem_addr;       // word-aligned for RVFI ALIGNED_MEM\n127:     logic [31:0] mem_rdata;      // raw memory word\n128:     logic [31:0] mem_wdata;      // replicated byte-lane write data\n129:     logic [3:0]  mem_wmask;\n130:     logic [3:0]  mem_rmask;\n131:     ctrl_t       ctrl;\n132:     logic [31:0] instr;\n133:     logic        valid;\n134:   } mem_wb_t;\n135: \n136: `endif // CORE_PKG_DEFINED\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"// rtl/core_pkg.sv\n//\n// Core-wide constants and pipeline-bundle types.\n//\n// Compilation-unit scope (no `package … endpackage` wrapper) because\n// Yosys's Verilog frontend rejects `import pkg::*;` even though it\n// accepts `pkg::sym` refs and package definitions. A file-scope\n// definition with an `\\`ifndef` guard is the lowest common denominator\n// across Verilator, Yosys, sby, and nextpnr-himbaechel.\n//\n// Order matters: this file MUST be the first source passed to any tool\n// (Verilator/cocotb runner / build.sh / formal staging). Subsequent\n// includes hit the guard and become no-ops.\n//\n// Latency:        n/a (declarations only).\n// RVFI fields:    none (defines types; no logic).\n`ifndef CORE_PKG_DEFINED\n`define CORE_PKG_DEFINED\n\n  // ── ALU operations ──────────────────────────────────────────────────────","truncated":false,"loaded":[]},"title":"cores/bench/rtl/core_pkg.sv","time":{"start":1778733592404,"end":1778733592420}},"id":"prt_e24c8abf200142MNhnicAEgRUq","sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","messageID":"msg_e24c5abe4001U52WzCFEbvqmDo"}}
{"type":"tool_use","timestamp":1778733593107,"sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","part":{"type":"tool","tool":"read","callID":"read:3","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/mem_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/mem_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/mem_stage.sv\n2: //\n3: // Memory access stage. Drives the dmem read/write ports combinationally\n4: // from the EX/MEM register, and sign/zero-extends the loaded data into\n5: // the MEM/WB register.\n6: //\n7: // Byte-lane discipline:\n8: //   - Write data is replicated across all four byte lanes; the\n9: //     byte-mask (mem_wmask) selects the actual destination bytes.\n10: //   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n11: //     zero-extend the low 8/16 bits per the LB/LBU/LH/LHU encoding.\n12: //   - For RVFI ALIGNED_MEM, mem_addr is reported word-aligned and the\n13: //     byte position is captured in mem_rmask / mem_wmask.\n14: //\n15: // Latency:        1 cycle (MEM/WB register clocked here).\n16: // RVFI fields:    feeds mem_addr, mem_rmask, mem_wmask, mem_rdata,\n17: //                 mem_wdata, plus rd_wdata via the loaded-data path.\n18: module mem_stage (\n19:   input  logic               clock,\n20:   input  logic               reset,\n21:   // hold_wb: dmem stall is in effect. MEM/WB's data fields are RETAINED\n22:   // (so the previously-retired LOAD's `rd` / `read_data` / `ctrl.reg_write`\n23:   // remain visible to forward_unit), but `valid` is cleared so:\n24:   //   - rvfi_order doesn't increment for held cycles\n25:   //   - wb_stage doesn't write the regfile twice\n26:   // Zeroing the whole register would lose the LOAD's load_data, breaking\n27:   // MEM/WB->EX forwarding for any dependent instruction that's also held\n28:   // in ID/EX during the stall (e.g. a BNE that consumes a LOAD's result).\n29:   input  logic               hold_wb,\n30:   // ex_mem_t carries branch_taken / branch_target / pc_next / rs?_val\n31:   // for downstream RVFI use; mem_stage only consumes a subset, so the\n32:   // remaining fields look unused from this module's perspective.\n33:   /* verilator lint_off UNUSEDSIGNAL */\n34:   input  ex_mem_t  in,\n35:   /* verilator lint_on UNUSEDSIGNAL */\n36:   // dmem interface\n37:   output logic [31:0]        dmem_addr,\n38:   output logic [31:0]        dmem_wdata,\n39:   input  logic [31:0]        dmem_rdata,\n40:   output logic [3:0]         dmem_wen,\n41:   output logic               dmem_ren,\n42:   // MEM/WB register output\n43:   output mem_wb_t  out\n44: );\n45: \n46:   logic [31:0] wdata_rep;\n47:   logic [3:0]  byte_mask;\n48:   logic [31:0] aligned_addr;\n49:   // shifted[31:16] is dropped on byte/halfword loads; only [15:0] feeds\n50:   // the sign/zero-extension mux.\n51:   /* verilator lint_off UNUSEDSIGNAL */\n52:   logic [31:0] shifted;\n53:   /* verilator lint_on UNUSEDSIGNAL */\n54:   logic [7:0]  byte_val;\n55:   logic [15:0] hword_val;\n56:   logic [31:0] load_data;\n57: \n58:   // Misaligned mem-access trap. RV32I requires word-aligned LW/SW and\n59:   // halfword-aligned LH/LHU/SH; byte ops are always aligned.\n60:   // riscv-formal's RISCV_FORMAL_ALIGNED_MEM contract demands rvfi_trap=1\n61:   // when the effective byte address is not aligned to the access width.\n62:   // On trap, the dmem ports are gated off and ctrl propagates is_illegal.\n63:   logic mem_misalign;\n64:   logic mem_op;\n65:   ctrl_t ctrl_with_trap;\n66: \n67:   always_comb begin\n68:     // Byte/halfword replication for stores.\n69:     case (in.ctrl.mem_width)\n70:       2'd0:    wdata_rep = {4{in.write_data[7:0]}};\n71:       2'd1:    wdata_rep = {2{in.write_data[15:0]}};\n72:       default: wdata_rep = in.write_data;\n73:     endcase\n74: \n75:     // Byte-lane mask shifted to addr[1:0] * 1.\n76:     case (in.ctrl.mem_width)\n77:       2'd0:    byte_mask = (4'b0001 << in.alu_result[1:0]);\n78:       2'd1:    byte_mask = (4'b0011 << in.alu_result[1:0]);\n79:       default: byte_mask = 4'b1111;\n80:     endcase\n81: \n82:     mem_op       = in.ctrl.mem_read || in.ctrl.mem_write;\n83:     mem_misalign = mem_op && (\n84:                      (in.ctrl.mem_width == 2'd2 && in.alu_result[1:0] != 2'b00) ||\n85:                      (in.ctrl.mem_width == 2'd1 && in.alu_result[0]   != 1'b0)\n86:                      // 2'd0 (byte) is never misaligned.\n87:                    );\n88: \n89:     ctrl_with_trap = in.ctrl;\n90:     if (mem_misalign) begin\n91:       ctrl_with_trap.is_illegal = 1'b1;\n92:       ctrl_with_trap.reg_write  = 1'b0;\n93:     end\n94: \n95:     // Combinational dmem outputs — gated off on misalign.\n96:     dmem_addr  = in.alu_result;\n97:     dmem_wdata = wdata_rep;\n98:     dmem_wen   = (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n99:     dmem_ren   = in.ctrl.mem_read  && !mem_misalign;\n100: \n101:     // Load extraction: shift right then sign/zero-extend the low N bits.\n102:     shifted   = dmem_rdata >> (in.alu_result[1:0] * 8);\n103:     byte_val  = shifted[7:0];\n104:     hword_val = shifted[15:0];\n105:     case (in.ctrl.mem_width)\n106:       2'd0:    load_data = in.ctrl.mem_sext\n107:                          ? {{24{byte_val[7]}},  byte_val}\n108:                          : {24'b0,              byte_val};\n109:       2'd1:    load_data = in.ctrl.mem_sext\n110:                          ? {{16{hword_val[15]}}, hword_val}\n111:                          : {16'b0,               hword_val};\n112:       default: load_data = dmem_rdata;\n113:     endcase\n114: \n115:     // RVFI ALIGNED_MEM expects word-aligned mem_addr; mem_addr=0 if no access.\n116:     aligned_addr = (mem_op && !mem_misalign)\n117:                  ? {in.alu_result[31:2], 2'b00}\n118:                  : 32'b0;\n119:   end\n120: \n121:   // ── MEM/WB register ───────────────────────────────────────────────────\n122:   mem_wb_t reg_q;\n123: \n124:   always_ff @(posedge clock) begin\n125:     if (reset) begin\n126:       reg_q <= '0;\n127:     end else if (hold_wb) begin\n128:       // Clear valid (no double-retire / no double-regfile-write), but\n129:       // KEEP every other field. Forwarding from MEM/WB to a stalled\n130:       // dependent in ID/EX needs the held LOAD's rd/read_data/ctrl\n131:       // alive for as many cycles as the dmem stall lasts.\n132:       reg_q.valid <= 1'b0;\n133:     end else begin\n134:       reg_q.pc         <= in.pc;\n135:       reg_q.alu_result <= in.alu_result;\n136:       reg_q.read_data  <= load_data;\n137:       reg_q.rd         <= in.rd;\n138:       reg_q.rs1_addr   <= in.rs1_addr;\n139:       reg_q.rs2_addr   <= in.rs2_addr;\n140:       reg_q.rs1_val    <= in.rs1_val;\n141:       reg_q.rs2_val    <= in.rs2_val;\n142:       reg_q.pc_next    <= in.pc_next;\n143:       reg_q.mem_addr   <= aligned_addr;\n144:       reg_q.mem_rdata  <= dmem_rdata;\n145:       reg_q.mem_wdata  <= wdata_rep;\n146:       reg_q.mem_wmask  <= (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n147:       reg_q.mem_rmask  <= (in.ctrl.mem_read  && !mem_misalign) ? byte_mask : 4'b0000;\n148:       reg_q.ctrl       <= ctrl_with_trap;\n149:       reg_q.instr      <= in.instr;\n150:       reg_q.valid      <= in.valid;\n151:     end\n152:   end\n153: \n154:   assign out = reg_q;\n155: \n156: endmodule\n\n(End of file - total 156 lines)\n</content>","metadata":{"preview":"// rtl/mem_stage.sv\n//\n// Memory access stage. Drives the dmem read/write ports combinationally\n// from the EX/MEM register, and sign/zero-extends the loaded data into\n// the MEM/WB register.\n//\n// Byte-lane discipline:\n//   - Write data is replicated across all four byte lanes; the\n//     byte-mask (mem_wmask) selects the actual destination bytes.\n//   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n//     zero-extend the low 8/16 bits per the LB/LBU/LH/LHU encoding.\n//   - For RVFI ALIGNED_MEM, mem_addr is reported word-aligned and the\n//     byte position is captured in mem_rmask / mem_wmask.\n//\n// Latency:        1 cycle (MEM/WB register clocked here).\n// RVFI fields:    feeds mem_addr, mem_rmask, mem_wmask, mem_rdata,\n//                 mem_wdata, plus rd_wdata via the loaded-data path.\nmodule mem_stage (\n  input  logic               clock,\n  input  logic               reset,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/mem_stage.sv","time":{"start":1778733593092,"end":1778733593106}},"id":"prt_e24c8af58001bCCgQY7oEGJAl9","sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","messageID":"msg_e24c5abe4001U52WzCFEbvqmDo"}}
{"type":"tool_use","timestamp":1778733593810,"sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","part":{"type":"tool","tool":"read","callID":"read:4","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/wb_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/wb_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/wb_stage.sv\n2: //\n3: // Write-back stage. Pure combinational mux that selects between the\n4: // loaded-data path (mem_to_reg=1) and the ALU-result path. Drives the\n5: // regfile write port; the regfile itself stalls on x0 and gates on\n6: // w_en.\n7: //\n8: // Latency:        combinational.\n9: // RVFI fields:    feeds rd_wdata (= w_data when w_en=1, else 0).\n10: module wb_stage (\n11:   // mem_wb_t fields beyond reg_write/rd/mem_to_reg/read_data/alu_result\n12:   // (pc, mem_*, rs?_*, instr) are RVFI-only and read at top level.\n13:   /* verilator lint_off UNUSEDSIGNAL */\n14:   input  mem_wb_t  in,\n15:   /* verilator lint_on UNUSEDSIGNAL */\n16:   output logic               w_en,\n17:   output logic [4:0]         w_addr,\n18:   output logic [31:0]        w_data\n19: );\n20: \n21:   always_comb begin\n22:     w_en   = in.ctrl.reg_write && in.valid;\n23:     w_addr = in.rd;\n24:     w_data = in.ctrl.mem_to_reg ? in.read_data : in.alu_result;\n25:   end\n26: \n27: endmodule\n\n(End of file - total 27 lines)\n</content>","metadata":{"preview":"// rtl/wb_stage.sv\n//\n// Write-back stage. Pure combinational mux that selects between the\n// loaded-data path (mem_to_reg=1) and the ALU-result path. Drives the\n// regfile write port; the regfile itself stalls on x0 and gates on\n// w_en.\n//\n// Latency:        combinational.\n// RVFI fields:    feeds rd_wdata (= w_data when w_en=1, else 0).\nmodule wb_stage (\n  // mem_wb_t fields beyond reg_write/rd/mem_to_reg/read_data/alu_result\n  // (pc, mem_*, rs?_*, instr) are RVFI-only and read at top level.\n  /* verilator lint_off UNUSEDSIGNAL */\n  input  mem_wb_t  in,\n  /* verilator lint_on UNUSEDSIGNAL */\n  output logic               w_en,\n  output logic [4:0]         w_addr,\n  output logic [31:0]        w_data\n);\n","truncated":false,"loaded":[]},"title":"cores/bench/rtl/wb_stage.sv","time":{"start":1778733593799,"end":1778733593809}},"id":"prt_e24c8b20b001CBkDwXMx7zssbz","sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","messageID":"msg_e24c5abe4001U52WzCFEbvqmDo"}}
{"type":"tool_use","timestamp":1778733594215,"sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","part":{"type":"tool","tool":"read","callID":"read:5","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/ex_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep1/cores/bench/rtl/ex_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/ex_stage.sv\n2: //\n3: // Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n4: // MEM/WB), runs the ALU, resolves branches, computes the redirect\n5: // target. Owns the EX/MEM pipeline register.\n6: //\n7: // Forwarding select encoding (driven by forward_unit):\n8: //   00 = ID/EX register value (no forward)\n9: //   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n10: //   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n11: //\n12: // Latency:        1 cycle (EX/MEM register clocked here).\n13: // RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n14: //                 ALU and JAL/JALR (PC+4), and the branch resolve.\n15: module ex_stage (\n16:   input  logic               clock,\n17:   input  logic               reset,\n18:   input  logic               stall,         // freeze EX/MEM register (dmem stall)\n19:   input  id_ex_t   in,\n20:   input  logic [1:0]         fwd_rs1_sel,\n21:   input  logic [1:0]         fwd_rs2_sel,\n22:   input  logic [31:0]        fwd_ex_mem,    // EX/MEM.alu_result (registered)\n23:   input  logic [31:0]        fwd_mem_wb,    // WB-stage write-data mux output\n24:   output ex_mem_t  out,\n25:   output logic               redirect,\n26:   output logic [31:0]        redirect_target,\n27:   // BHT update back to IF stage\n28:   output logic               bht_update_en,\n29:   output logic [4:0]         bht_update_idx,\n30:   output logic               bht_update_taken\n31: );\n32: \n33:   // ── Operand forwarding muxes ───────────────────────────────────────────\n34:   logic [31:0] rs1;\n35:   logic [31:0] rs2;\n36: \n37:   always_comb begin\n38:     case (fwd_rs1_sel)\n39:       2'd1:    rs1 = fwd_ex_mem;\n40:       2'd2:    rs1 = fwd_mem_wb;\n41:       default: rs1 = in.rs1_val;\n42:     endcase\n43:     case (fwd_rs2_sel)\n44:       2'd1:    rs2 = fwd_ex_mem;\n45:       2'd2:    rs2 = fwd_mem_wb;\n46:       default: rs2 = in.rs2_val;\n47:     endcase\n48:   end\n49: \n50:   // ── ALU operand selection ─────────────────────────────────────────────\n51:   logic [31:0] alu_a;\n52:   logic [31:0] alu_b;\n53:   always_comb begin\n54:     alu_a = in.ctrl.is_auipc ? in.pc  : rs1;\n55:     alu_b = in.ctrl.alu_src  ? in.imm : rs2;\n56:   end\n57: \n58:   logic [31:0] alu_result;\n59:   alu u_alu (\n60:     .op  (in.ctrl.alu_op),\n61:     .a   (alu_a),\n62:     .b   (alu_b),\n63:     .out (alu_result)\n64:   );\n65: \n66:   // ── Branch resolve ────────────────────────────────────────────────────\n67:   logic        branch_cond;\n68:   logic        branch_taken;\n69:   logic [31:0] branch_target;\n70:   logic [31:0] jump_target;\n71:   /* verilator lint_off UNUSEDSIGNAL */\n72:   logic [31:0] jalr_sum;  // bit 0 deliberately dropped per RV JALR spec\n73:   /* verilator lint_on UNUSEDSIGNAL */\n74: \n75:   always_comb begin\n76:     case (in.ctrl.branch_op)\n77:       BR_BEQ:  branch_cond = (rs1 == rs2);\n78:       BR_BNE:  branch_cond = (rs1 != rs2);\n79:       BR_BLT:  branch_cond = ($signed(rs1) <  $signed(rs2));\n80:       BR_BGE:  branch_cond = ($signed(rs1) >= $signed(rs2));\n81:       BR_BLTU: branch_cond = (rs1 <  rs2);\n82:       BR_BGEU: branch_cond = (rs1 >= rs2);\n83:       default: branch_cond = 1'b0;\n84:     endcase\n85:     branch_taken  = in.ctrl.is_branch && branch_cond;\n86:     branch_target = in.pc + in.imm;\n87:     // JALR clears bit 0 (RV spec); JAL uses imm directly.\n88:     jalr_sum    = rs1 + in.imm;\n89:     jump_target = in.ctrl.is_jalr ? {jalr_sum[31:1], 1'b0}\n90:                                   : (in.pc + in.imm);\n91:   end\n92: \n93:   // ── BHT update ────────────────────────────────────────────────────────\n94:   assign bht_update_en    = !stall && in.valid && in.ctrl.is_branch;\n95:   assign bht_update_idx   = in.pc[6:2];\n96:   assign bht_update_taken = branch_taken;\n97: \n98:   // ── Misaligned branch / jump target trap ──────────────────────────────\n99:   // riscv-formal's spec demands rvfi_trap=1 when next_pc is misaligned\n100:   // (without C extension that means [1:0] != 0). We trap the offending\n101:   // instruction, suppress the redirect (PC stays linear), and clear\n102:   // reg_write so JAL/JALR don't write the return address on trap.\n103:   //\n104:   // With the static predictor, a predicted-taken branch/jump that turns\n105:   // out to be misaligned must still redirect to pc+4 to squash the\n106:   // speculative fetch that already happened in IF.\n107:   logic misalign_branch;\n108:   logic misalign_jump;\n109:   logic misalign_fault;\n110:   logic pred_misalign_flush;\n111:   logic pred_wrong;          // predicted taken but doesn't actually change PC\n112:   logic unpred_taken;        // predicted not-taken but branch is actually taken\n113:   ctrl_t ctrl_with_trap;\n114: \n115:   always_comb begin\n116:     misalign_branch = in.ctrl.is_branch && branch_taken\n117:                       && (branch_target[1:0] != 2'b00);\n118:     misalign_jump   = in.ctrl.is_jump && (jump_target[1:0] != 2'b00);\n119:     misalign_fault  = misalign_branch || misalign_jump;\n120: \n121:     // If we predicted taken but target is misaligned, squash the\n122:     // speculative fetch by redirecting back to pc+4.\n123:     pred_misalign_flush = in.pred_taken && misalign_fault;\n124: \n125:     // Predicted taken but instruction is not a taken branch/jump.\n126:     // This covers mispredicted taken branches AND invalid instructions\n127:     // that IF mistakenly predicted (e.g. reserved branch funct3).\n128:     pred_wrong = in.pred_taken &&\n129:                  !((in.ctrl.is_branch && branch_taken) || in.ctrl.is_jump);\n130: \n131:     // Predicted not-taken but branch is actually taken.\n132:     unpred_taken = !in.pred_taken && in.ctrl.is_branch && branch_taken;\n133: \n134:     ctrl_with_trap = in.ctrl;\n135:     if (misalign_fault) begin\n136:       ctrl_with_trap.is_illegal = 1'b1;\n137:       ctrl_with_trap.reg_write  = 1'b0;\n138:     end\n139:   end\n140: \n141:   // Redirect on mispredict, JALR, or misaligned predicted-taken.\n142:   assign redirect        = (((pred_wrong || unpred_taken ||\n143:                              (in.ctrl.is_jump && in.ctrl.is_jalr)) &&\n144:                             !misalign_fault) ||\n145:                             pred_misalign_flush);\n146:   assign redirect_target = pred_misalign_flush ? (in.pc + 32'd4) :\n147:                            pred_wrong          ? (in.pc + 32'd4) :\n148:                            in.ctrl.is_jump     ? jump_target :\n149:                            branch_taken        ? branch_target :\n150:                                                  (in.pc + 32'd4);\n151: \n152:   // ── EX/MEM register ───────────────────────────────────────────────────\n153:   ex_mem_t reg_q;\n154: \n155:   always_ff @(posedge clock) begin\n156:     if (reset) begin\n157:       reg_q <= '0;\n158:     end else if (stall) begin\n159:       // dmem stall: hold the EX/MEM register so the in-flight LOAD/STORE\n160:       // stays in MEM stage waiting on the bus.\n161:       reg_q <= reg_q;\n162:     end else begin\n163:       reg_q.pc            <= in.pc;\n164:       // For JAL/JALR, the rd_wdata is PC+4 (return address), not the ALU's\n165:       // sum (which is the jump target). The MEM/WB register's read-data\n166:       // mux only kicks in for LOADs, so we route PC+4 here.\n167:       reg_q.alu_result    <= in.ctrl.is_jump ? (in.pc + 32'd4) : alu_result;\n168:       reg_q.write_data    <= rs2;\n169:       reg_q.rd            <= in.rd;\n170:       reg_q.rs1_addr      <= in.rs1_addr;\n171:       reg_q.rs2_addr      <= in.rs2_addr;\n172:       reg_q.rs1_val       <= rs1;\n173:       reg_q.rs2_val       <= rs2;\n174:       // pc_next reverts to pc+4 on misalign trap so the pc_fwd checker\n175:       // (asserting next retirement's pc_rdata == this pc_wdata) stays\n176:       // consistent with the suppressed redirect.\n177:       reg_q.pc_next       <= misalign_fault     ? (in.pc + 32'd4)\n178:                             : in.ctrl.is_jump   ? jump_target\n179:                             : branch_taken      ? branch_target\n180:                                                 : (in.pc + 32'd4);\n181:       reg_q.branch_taken  <= branch_taken;\n182:       reg_q.branch_target <= branch_target;\n183:       reg_q.ctrl          <= ctrl_with_trap;\n184:       reg_q.instr         <= in.instr;\n185:       reg_q.valid         <= in.valid;\n186:     end\n187:   end\n188: \n189:   assign out = reg_q;\n190: \n191: endmodule\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"// rtl/ex_stage.sv\n//\n// Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n// MEM/WB), runs the ALU, resolves branches, computes the redirect\n// target. Owns the EX/MEM pipeline register.\n//\n// Forwarding select encoding (driven by forward_unit):\n//   00 = ID/EX register value (no forward)\n//   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n//   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n//\n// Latency:        1 cycle (EX/MEM register clocked here).\n// RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n//                 ALU and JAL/JALR (PC+4), and the branch resolve.\nmodule ex_stage (\n  input  logic               clock,\n  input  logic               reset,\n  input  logic               stall,         // freeze EX/MEM register (dmem stall)\n  input  id_ex_t   in,\n  input  logic [1:0]         fwd_rs1_sel,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/ex_stage.sv","time":{"start":1778733594195,"end":1778733594213}},"id":"prt_e24c8b4ca001yOcUtY8IJRIuBt","sessionID":"ses_1db419843ffeQUi9B9VyBNpPkX","messageID":"msg_e24c5abe4001U52WzCFEbvqmDo"}}
