{"type":"tool_use","timestamp":1778731467693,"sessionID":"ses_1db5d8991ffesSiZOxWJo145or","part":{"type":"tool","tool":"read","callID":"read:11","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/bench/test/test_alu.py"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/bench/test/test_alu.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for rtl/alu.sv.\n2: \n3: The ALU is purely combinational (RV32IM). MUL / DIV / REM use the\n4: SystemVerilog `*`, `/`, `%` operators and resolve in zero cycles, so\n5: there is no clock, reset, or handshake on this module.\n6: \"\"\"\n7: from __future__ import annotations\n8: \n9: import cocotb\n10: from cocotb.triggers import Timer\n11: \n12: from _helpers import (\n13:     ALU_ADD, ALU_SUB, ALU_AND, ALU_OR, ALU_XOR,\n14:     ALU_SLT, ALU_SLTU, ALU_SLL, ALU_SRL, ALU_SRA,\n15:     ALU_LUI,\n16:     ALU_MUL, ALU_MULH, ALU_MULHU, ALU_MULHSU,\n17:     ALU_DIV, ALU_DIVU, ALU_REM, ALU_REMU,\n18:     run_cocotb,\n19: )\n20: \n21: MASK32 = 0xFFFFFFFF\n22: \n23: \n24: async def _setup(dut):\n25:     \"\"\"No-op — the ALU has no clock or reset. Kept so each test entry can\n26:     `await _setup(dut)` for parity with other test files.\"\"\"\n27:     return\n28: \n29: \n30: async def _check(dut, op, a, b, expected):\n31:     \"\"\"Drive op/a/b and check the combinational result.\"\"\"\n32:     dut.op.value = op\n33:     dut.a.value  = a & MASK32\n34:     dut.b.value  = b & MASK32\n35:     await Timer(1, \"ns\")\n36:     actual = int(dut.out.value) & MASK32\n37:     assert actual == (expected & MASK32), (\n38:         f\"op={op} a=0x{a & MASK32:08x} b=0x{b & MASK32:08x} \"\n39:         f\"expected=0x{expected & MASK32:08x} got=0x{actual:08x}\"\n40:     )\n41: \n42: \n43: async def _check_div(dut, op, a, b, expected):\n44:     \"\"\"Combinational div/rem — alias for _check. Was a multi-cycle FSM\n45:     under hyp-20260427-002, reverted in 6688be7 (v2 reset).\"\"\"\n46:     await _check(dut, op, a, b, expected)\n47: \n48: \n49: @cocotb.test()\n50: async def add(dut):\n51:     await _setup(dut)\n52:     await _check(dut, ALU_ADD, 5, 3, 8)\n53:     await _check(dut, ALU_ADD, 0xFFFFFFFF, 1, 0)  # wrap\n54: \n55: \n56: @cocotb.test()\n57: async def sub(dut):\n58:     await _setup(dut)\n59:     await _check(dut, ALU_SUB, 10, 3, 7)\n60:     await _check(dut, ALU_SUB, 0, 1, 0xFFFFFFFF)  # borrow\n61: \n62: \n63: @cocotb.test()\n64: async def bitwise(dut):\n65:     await _setup(dut)\n66:     await _check(dut, ALU_AND, 0xFF, 0x0F, 0x0F)\n67:     await _check(dut, ALU_OR,  0xF0, 0x0F, 0xFF)\n68:     await _check(dut, ALU_XOR, 0xFF, 0x0F, 0xF0)\n69: \n70: \n71: @cocotb.test()\n72: async def slt_signed(dut):\n73:     await _setup(dut)\n74:     await _check(dut, ALU_SLT, 0xFFFFFFFF, 0, 1)              # -1 < 0\n75:     await _check(dut, ALU_SLT, 1, 0, 0)\n76:     await _check(dut, ALU_SLT, 0x7FFFFFFF, 0x80000000, 0)     # MAX > MIN\n77: \n78: \n79: @cocotb.test()\n80: async def sltu_unsigned(dut):\n81:     await _setup(dut)\n82:     await _check(dut, ALU_SLTU, 0xFFFFFFFF, 0, 0)             # max > 0\n83:     await _check(dut, ALU_SLTU, 0, 1, 1)\n84: \n85: \n86: @cocotb.test()\n87: async def sll(dut):\n88:     await _setup(dut)\n89:     await _check(dut, ALU_SLL, 1, 4, 16)\n90:     await _check(dut, ALU_SLL, 1, 31, 0x80000000)\n91:     await _check(dut, ALU_SLL, 1, 0x20, 1)                    # shamt = b[4:0] = 0\n92: \n93: \n94: @cocotb.test()\n95: async def srl(dut):\n96:     await _setup(dut)\n97:     await _check(dut, ALU_SRL, 0x80000000, 1, 0x40000000)\n98:     await _check(dut, ALU_SRL, 0x80000000, 31, 1)\n99:     await _check(dut, ALU_SRL, 0xFFFFFFFF, 0x25, 0x07FFFFFF)   # shamt masked\n100: \n101: \n102: @cocotb.test()\n103: async def sra(dut):\n104:     await _setup(dut)\n105:     await _check(dut, ALU_SRA, 0x80000000, 1, 0xC0000000)\n106:     await _check(dut, ALU_SRA, 0x80000000, 31, 0xFFFFFFFF)\n107:     await _check(dut, ALU_SRA, 0x7FFFFFFF, 1, 0x3FFFFFFF)\n108: \n109: \n110: @cocotb.test()\n111: async def lui(dut):\n112:     await _setup(dut)\n113:     await _check(dut, ALU_LUI, 0, 0x12345000, 0x12345000)\n114: \n115: \n116: @cocotb.test()\n117: async def mul(dut):\n118:     await _setup(dut)\n119:     await _check(dut, ALU_MUL, 3, 4, 12)\n120:     await _check(dut, ALU_MUL, 0xFFFFFFFF, 0xFFFFFFFF, 1)      # (-1)*(-1) low\n121: \n122: \n123: @cocotb.test()\n124: async def mulh(dut):\n125:     await _setup(dut)\n126:     # INT_MIN * 2 = -2^32; high half = -1\n127:     await _check(dut, ALU_MULH, 0x80000000, 2, 0xFFFFFFFF)\n128:     # INT_MIN * INT_MIN = 2^62; high half = 0x40000000\n129:     await _check(dut, ALU_MULH, 0x80000000, 0x80000000, 0x40000000)\n130:     await _check(dut, ALU_MULH, 1, 1, 0)\n131: \n132: \n133: @cocotb.test()\n134: async def mulhu(dut):\n135:     await _setup(dut)\n136:     await _check(dut, ALU_MULHU, 0xFFFFFFFF, 2, 1)\n137:     await _check(dut, ALU_MULHU, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFE)\n138: \n139: \n140: @cocotb.test()\n141: async def mulhsu(dut):\n142:     await _setup(dut)\n143:     # signed -2^31 * unsigned (2^32-1) = -2^63 + 2^31 = 0x8000_0000_8000_0000\n144:     await _check(dut, ALU_MULHSU, 0x80000000, 0xFFFFFFFF, 0x80000000)\n145:     # (-1) * unsigned -> high half is sign extension\n146:     await _check(dut, ALU_MULHSU, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF)\n147: \n148: \n149: @cocotb.test()\n150: async def div_signed(dut):\n151:     await _setup(dut)\n152:     await _check_div(dut, ALU_DIV, 10, 3, 3)\n153:     await _check_div(dut, ALU_DIV, 0xFFFFFFFC, 2, 0xFFFFFFFE)      # -4/2 = -2\n154:     await _check_div(dut, ALU_DIV, 7, 0xFFFFFFFE, 0xFFFFFFFD)      # 7/-2 = -3 (trunc to 0)\n155: \n156: \n157: @cocotb.test()\n158: async def div_by_zero(dut):\n159:     await _setup(dut)\n160:     await _check_div(dut, ALU_DIV, 123, 0, 0xFFFFFFFF)\n161:     await _check_div(dut, ALU_DIV, 0, 0, 0xFFFFFFFF)\n162: \n163: \n164: @cocotb.test()\n165: async def div_overflow(dut):\n166:     await _setup(dut)\n167:     # INT_MIN / -1 -> INT_MIN  (defined overflow per RV32IM)\n168:     await _check_div(dut, ALU_DIV, 0x80000000, 0xFFFFFFFF, 0x80000000)\n169: \n170: \n171: @cocotb.test()\n172: async def divu(dut):\n173:     await _setup(dut)\n174:     await _check_div(dut, ALU_DIVU, 0xFFFFFFFF, 2, 0x7FFFFFFF)\n175:     await _check_div(dut, ALU_DIVU, 100, 7, 14)\n176: \n177: \n178: @cocotb.test()\n179: async def divu_by_zero(dut):\n180:     await _setup(dut)\n181:     await _check_div(dut, ALU_DIVU, 42, 0, 0xFFFFFFFF)\n182: \n183: \n184: @cocotb.test()\n185: async def rem_signed(dut):\n186:     await _setup(dut)\n187:     await _check_div(dut, ALU_REM, 10, 3, 1)\n188:     # -10 % 3 trunc-to-zero: -10 = (-3)*3 + (-1) -> rem = -1 = 0xFFFFFFFF\n189:     await _check_div(dut, ALU_REM, 0xFFFFFFF6, 3, 0xFFFFFFFF)\n190:     # 10 % -3 trunc-to-zero: 10 = (-3)*(-3) + 1 -> rem = 1 (sign of dividend)\n191:     await _check_div(dut, ALU_REM, 10, 0xFFFFFFFD, 1)\n192: \n193: \n194: @cocotb.test()\n195: async def rem_by_zero(dut):\n196:     await _setup(dut)\n197:     await _check_div(dut, ALU_REM, 0xDEADBEEF, 0, 0xDEADBEEF)\n198: \n199: \n200: @cocotb.test()\n201: async def rem_overflow(dut):\n202:     await _setup(dut)\n203:     # INT_MIN % -1 -> 0\n204:     await _check_div(dut, ALU_REM, 0x80000000, 0xFFFFFFFF, 0)\n205: \n206: \n207: @cocotb.test()\n208: async def remu(dut):\n209:     await _setup(dut)\n210:     await _check_div(dut, ALU_REMU, 7, 3, 1)\n211: \n212: \n213: @cocotb.test()\n214: async def remu_by_zero(dut):\n215:     await _setup(dut)\n216:     await _check_div(dut, ALU_REMU, 0xCAFEBABE, 0, 0xCAFEBABE)\n217: \n218: \n219: @cocotb.test()\n220: async def back_to_back_divides(dut):\n221:     \"\"\"Verify the FSM resets cleanly between consecutive iterative\n222:     divides — no carry-over of operands or state from the previous op.\n223:     \"\"\"\n224:     await _setup(dut)\n225:     # Real divides only (avoid edge-case short-circuit) so each pass\n226:     # exercises the full 33-cycle FSM.\n227:     await _check_div(dut, ALU_DIVU, 100, 7, 14)\n228:     await _check_div(dut, ALU_DIVU, 0xFFFFFFFF, 2, 0x7FFFFFFF)\n229:     await _check_div(dut, ALU_DIV, 0xFFFFFFFC, 2, 0xFFFFFFFE)  # -4/2 = -2\n230:     await _check_div(dut, ALU_REM, 10, 3, 1)\n231:     await _check_div(dut, ALU_REMU, 7, 3, 1)\n232: \n233: \n234: def test_alu_runner():\n235:     \"\"\"pytest entry — runs every @cocotb.test() above under Verilator.\"\"\"\n236:     run_cocotb(toplevel=\"alu\",\n237:                sources=[\"core_pkg.sv\", \"alu.sv\"],\n238:                test_module=\"test_alu\")\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for rtl/alu.sv.\n\nThe ALU is purely combinational (RV32IM). MUL / DIV / REM use the\nSystemVerilog `*`, `/`, `%` operators and resolve in zero cycles, so\nthere is no clock, reset, or handshake on this module.\n\"\"\"\nfrom __future__ import annotations\n\nimport cocotb\nfrom cocotb.triggers import Timer\n\nfrom _helpers import (\n    ALU_ADD, ALU_SUB, ALU_AND, ALU_OR, ALU_XOR,\n    ALU_SLT, ALU_SLTU, ALU_SLL, ALU_SRL, ALU_SRA,\n    ALU_LUI,\n    ALU_MUL, ALU_MULH, ALU_MULHU, ALU_MULHSU,\n    ALU_DIV, ALU_DIVU, ALU_REM, ALU_REMU,\n    run_cocotb,\n)\n","truncated":false,"loaded":[]},"title":"cores/bench/test/test_alu.py","time":{"start":1778731467687,"end":1778731467692}},"id":"prt_e24a8418c004Jjhh0UoXaYfLfl","sessionID":"ses_1db5d8991ffesSiZOxWJo145or","messageID":"msg_e24a82da80012RkUP7A7JSy6Wq"}}
