0513-003-r1s2.log\n-rw-r--r--   1 bonetto  staff  11112 May 13 23:36 .agent.hyp-20260513-003-r2s2.log\n-rw-r--r--   1 bonetto  staff  16623 May 13 23:47 .agent.hyp-20260513-003-r3s2.log\n-rw-r--r--   1 bonetto  staff   1643 May 13 23:47 hyp-20260513-003-r3s2.yaml\n","exit":0,"description":"Check hypotheses directory exists","truncated":false},"title":"Check hypotheses directory exists","time":{"start":1778727224584,"end":1778727224586}},"id":"prt_e246782aa001Ethn96F0MWtGUh","sessionID":"ses_1dba172feffe2KO65sK7StgYiJ","messageID":"msg_e245e8d560018E9177WARENkiz"}}
