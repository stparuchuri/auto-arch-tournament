{"type":"tool_use","timestamp":1778736366324,"sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","part":{"type":"tool","tool":"read","callID":"read:7","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/div_unit.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/div_unit.sv</path>\n<type>file</type>\n<content>\n1: // rtl/div_unit.sv\n2: //\n3: // Iterative RV32M divider/remainder unit. The EX stage starts it only for\n4: // DIV/DIVU/REM/REMU and bubbles EX/MEM until done, keeping the cold divider\n5: // off the one-cycle ALU result path.\n6: module div_unit (\n7:   input  logic        clock,\n8:   input  logic        reset,\n9:   input  logic        start,\n10:   input  logic [4:0]  op,\n11:   input  logic [31:0] a,\n12:   input  logic [31:0] b,\n13:   output logic        busy,\n14:   output logic        done,\n15:   output logic [31:0] result\n16: );\n17: \n18:   localparam logic [1:0] ST_IDLE = 2'd0;\n19:   localparam logic [1:0] ST_BUSY = 2'd1;\n20:   localparam logic [1:0] ST_DONE = 2'd2;\n21: \n22:   logic [1:0]  state_q;\n23:   logic [31:0] result_q;\n24: \n25:   assign busy   = (state_q == ST_BUSY);\n26:   assign done   = (state_q == ST_DONE);\n27:   assign result = result_q;\n28: \n29: `ifdef RISCV_FORMAL_ALTOPS\n30:   logic [31:0] alt_result;\n31: \n32:   always_comb begin\n33:     case (op)\n34:       ALU_DIV:  alt_result = (a - b) ^ 32'h7f8529ec;\n35:       ALU_DIVU: alt_result = (a - b) ^ 32'h10e8fd70;\n36:       ALU_REM:  alt_result = (a - b) ^ 32'h8da68fa5;\n37:       ALU_REMU: alt_result = (a - b) ^ 32'h3138d0e1;\n38:       default:  alt_result = 32'b0;\n39:     endcase\n40:   end\n41: \n42:   always_ff @(posedge clock) begin\n43:     if (reset) begin\n44:       state_q  <= ST_IDLE;\n45:       result_q <= 32'b0;\n46:     end else begin\n47:       case (state_q)\n48:         ST_IDLE: begin\n49:           if (start) begin\n50:             result_q <= alt_result;\n51:             state_q  <= ST_BUSY;\n52:           end\n53:         end\n54:         ST_BUSY: state_q <= ST_DONE;\n55:         ST_DONE: state_q <= ST_IDLE;\n56:         default: state_q <= ST_IDLE;\n57:       endcase\n58:     end\n59:   end\n60: `else\n61:   logic [31:0] dividend_q;\n62:   logic [31:0] divisor_q;\n63:   /* verilator lint_off UNUSEDSIGNAL */\n64:   logic [31:0] quotient_q;\n65:   /* verilator lint_on UNUSEDSIGNAL */\n66:   logic [31:0] remainder_q;\n67:   logic [5:0]  count_q;\n68:   logic        quot_neg_q;\n69:   logic        rem_neg_q;\n70:   logic        want_rem_q;\n71: \n72:   logic        signed_op;\n73:   logic        want_rem;\n74:   logic        a_neg;\n75:   logic        b_neg;\n76:   logic [31:0] abs_a;\n77:   logic [31:0] abs_b;\n78:   logic        divide_by_zero;\n79:   logic        signed_overflow;\n80:   logic [31:0] special_result;\n81: \n82:   logic [32:0] trial_remainder;\n83:   logic [32:0] trial_divisor;\n84:   logic        trial_take;\n85:   /* verilator lint_off UNUSEDSIGNAL */\n86:   logic [32:0] remainder_step;\n87:   /* verilator lint_on UNUSEDSIGNAL */\n88:   logic [31:0] quotient_step;\n89:   logic [31:0] unsigned_remainder;\n90:   logic [31:0] signed_quotient;\n91:   logic [31:0] signed_remainder;\n92:   logic [31:0] final_result;\n93: \n94:   always_comb begin\n95:     signed_op       = (op == ALU_DIV) || (op == ALU_REM);\n96:     want_rem        = (op == ALU_REM) || (op == ALU_REMU);\n97:     a_neg           = signed_op && a[31];\n98:     b_neg           = signed_op && b[31];\n99:     abs_a           = a_neg ? (~a + 32'd1) : a;\n100:     abs_b           = b_neg ? (~b + 32'd1) : b;\n101:     divide_by_zero  = (b == 32'b0);\n102:     signed_overflow = signed_op && (a == 32'h80000000) && (b == 32'hFFFFFFFF);\n103: \n104:     if (divide_by_zero)\n105:       special_result = want_rem ? a : 32'hFFFFFFFF;\n106:     else if (signed_overflow)\n107:       special_result = want_rem ? 32'b0 : 32'h80000000;\n108:     else\n109:       special_result = 32'b0;\n110: \n111:     trial_remainder   = {remainder_q, dividend_q[31]};\n112:     trial_divisor     = {1'b0, divisor_q};\n113:     trial_take        = (trial_remainder >= trial_divisor);\n114:     remainder_step    = trial_take ? (trial_remainder - trial_divisor)\n115:                                    : trial_remainder;\n116:     quotient_step     = {quotient_q[30:0], trial_take};\n117:     unsigned_remainder = remainder_step[31:0];\n118:     signed_quotient   = quot_neg_q ? (~quotient_step + 32'd1)\n119:                                    : quotient_step;\n120:     signed_remainder  = rem_neg_q ? (~unsigned_remainder + 32'd1)\n121:                                   : unsigned_remainder;\n122:     final_result      = want_rem_q ? signed_remainder : signed_quotient;\n123:   end\n124: \n125:   always_ff @(posedge clock) begin\n126:     if (reset) begin\n127:       state_q     <= ST_IDLE;\n128:       result_q    <= 32'b0;\n129:       dividend_q  <= 32'b0;\n130:       divisor_q   <= 32'b0;\n131:       quotient_q  <= 32'b0;\n132:       remainder_q <= 32'b0;\n133:       count_q     <= 6'b0;\n134:       quot_neg_q  <= 1'b0;\n135:       rem_neg_q   <= 1'b0;\n136:       want_rem_q  <= 1'b0;\n137:     end else begin\n138:       case (state_q)\n139:         ST_IDLE: begin\n140:           if (start) begin\n141:             quotient_q  <= 32'b0;\n142:             remainder_q <= 32'b0;\n143:             want_rem_q  <= want_rem;\n144:             quot_neg_q  <= signed_op && (a[31] ^ b[31]);\n145:             rem_neg_q   <= signed_op && a[31];\n146:             if (divide_by_zero || signed_overflow) begin\n147:               result_q   <= special_result;\n148:               dividend_q <= 32'b0;\n149:               divisor_q  <= 32'b0;\n150:               count_q    <= 6'b0;\n151:             end else begin\n152:               dividend_q <= abs_a;\n153:               divisor_q  <= abs_b;\n154:               count_q    <= 6'd32;\n155:             end\n156:             state_q <= ST_BUSY;\n157:           end\n158:         end\n159: \n160:         ST_BUSY: begin\n161:           if (count_q == 6'b0) begin\n162:             state_q <= ST_DONE;\n163:           end else begin\n164:             dividend_q  <= {dividend_q[30:0], 1'b0};\n165:             quotient_q  <= quotient_step;\n166:             remainder_q <= remainder_step[31:0];\n167:             count_q     <= count_q - 6'd1;\n168:             if (count_q == 6'd1) begin\n169:               result_q <= final_result;\n170:               state_q  <= ST_DONE;\n171:             end\n172:           end\n173:         end\n174: \n175:         ST_DONE: state_q <= ST_IDLE;\n176:         default: state_q <= ST_IDLE;\n177:       endcase\n178:     end\n179:   end\n180: `endif\n181: \n182: endmodule\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"// rtl/div_unit.sv\n//\n// Iterative RV32M divider/remainder unit. The EX stage starts it only for\n// DIV/DIVU/REM/REMU and bubbles EX/MEM until done, keeping the cold divider\n// off the one-cycle ALU result path.\nmodule div_unit (\n  input  logic        clock,\n  input  logic        reset,\n  input  logic        start,\n  input  logic [4:0]  op,\n  input  logic [31:0] a,\n  input  logic [31:0] b,\n  output logic        busy,\n  output logic        done,\n  output logic [31:0] result\n);\n\n  localparam logic [1:0] ST_IDLE = 2'd0;\n  localparam logic [1:0] ST_BUSY = 2'd1;\n  localparam logic [1:0] ST_DONE = 2'd2;","truncated":false,"loaded":[]},"title":"cores/v1/rtl/div_unit.sv","time":{"start":1778736366306,"end":1778736366323}},"id":"prt_e24f3000f002fFauVuYoJYeLtG","sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","messageID":"msg_e24f2efeb002TUXJR5NHjkvsM1"}}
{"type":"step_finish","timestamp":1778736366967,"sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","part":{"id":"prt_e24f30577001e5rDX79r1kFz27","reason":"tool-calls","snapshot":"28cd45f82ca6d1ec14c4ff0fbe23cdf1d6b40522","messageID":"msg_e24f2efeb002TUXJR5NHjkvsM1","sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","type":"step-finish","tokens":{"total":65707,"input":2352,"output":51,"reasoning":72,"cache":{"write":0,"read":63232}},"cost":0.01284352}}
{"type":"step_start","timestamp":1778736370537,"sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","part":{"id":"prt_e24f31366001GvYRoEtZiGRxdh","messageID":"msg_e24f30599001d1cDZAF9QEcbUt","sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","snapshot":"28cd45f82ca6d1ec14c4ff0fbe23cdf1d6b40522","type":"step-start"}}
{"type":"tool_use","timestamp":1778736373280,"sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","part":{"type":"tool","tool":"read","callID":"read:8","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/ex_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/ex_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/ex_stage.sv\n2: //\n3: // Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n4: // MEM/WB), runs the ALU, resolves branches, and redirects only when the\n5: // IF-stage prediction disagrees with the resolved next PC. Owns the EX/MEM\n6: // pipeline register.\n7: //\n8: // Forwarding select encoding (driven by forward_unit):\n9: //   00 = ID/EX register value (no forward)\n10: //   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n11: //   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n12: //\n13: // Latency:        1 cycle (EX/MEM register clocked here).\n14: // RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n15: //                 ALU and JAL/JALR (PC+4), and the branch resolve.\n16: module ex_stage (\n17:   input  logic               clock,\n18:   input  logic               reset,\n19:   input  logic               stall,         // freeze EX/MEM register (dmem stall)\n20:   input  id_ex_t   in,\n21:   input  logic [1:0]         fwd_rs1_sel,\n22:   input  logic [1:0]         fwd_rs2_sel,\n23:   input  logic [31:0]        fwd_ex_mem,    // EX/MEM.alu_result (registered)\n24:   input  logic [31:0]        fwd_mem_wb,    // WB-stage write-data mux output\n25:   output ex_mem_t  out,\n26:   output logic               ex_long_busy,\n27:   output logic               redirect,\n28:   output logic [31:0]        redirect_target\n29: );\n30: \n31:   // ── Operand forwarding muxes ───────────────────────────────────────────\n32:   logic [31:0] rs1;\n33:   logic [31:0] rs2;\n34: \n35:   always_comb begin\n36:     case (fwd_rs1_sel)\n37:       2'd1:    rs1 = fwd_ex_mem;\n38:       2'd2:    rs1 = fwd_mem_wb;\n39:       default: rs1 = in.rs1_val;\n40:     endcase\n41:     case (fwd_rs2_sel)\n42:       2'd1:    rs2 = fwd_ex_mem;\n43:       2'd2:    rs2 = fwd_mem_wb;\n44:       default: rs2 = in.rs2_val;\n45:     endcase\n46:   end\n47: \n48:   // ── ALU operand selection ─────────────────────────────────────────────\n49:   logic [31:0] alu_a;\n50:   logic [31:0] alu_b;\n51:   always_comb begin\n52:     alu_a = in.ctrl.is_auipc ? in.pc  : rs1;\n53:     alu_b = in.ctrl.alu_src  ? in.imm : rs2;\n54:   end\n55: \n56:   logic [31:0] alu_result;\n57:   alu u_alu (\n58:     .op  (in.ctrl.alu_op),\n59:     .a   (alu_a),\n60:     .b   (alu_b),\n61:     .out (alu_result)\n62:   );\n63: \n64:   // ── Cold divide/remainder unit ────────────────────────────────────────\n65:   logic is_div_op;\n66:   logic div_request;\n67:   logic div_start;\n68:   logic div_busy;\n69:   logic div_done;\n70:   logic [31:0] div_result_w;\n71:   logic        div_active_q;\n72:   logic        div_result_valid_q;\n73:   logic [31:0] div_result_q;\n74:   /* verilator lint_off UNUSEDSIGNAL */\n75:   id_ex_t      div_in_q;\n76:   /* verilator lint_on UNUSEDSIGNAL */\n77:   logic [31:0] div_rs1_q;\n78:   logic [31:0] div_rs2_q;\n79:   logic        div_complete;\n80:   logic [31:0] div_result_selected;\n81: \n82:   always_comb begin\n83:     is_div_op   = (in.ctrl.alu_op == ALU_DIV)\n84:                || (in.ctrl.alu_op == ALU_DIVU)\n85:                || (in.ctrl.alu_op == ALU_REM)\n86:                || (in.ctrl.alu_op == ALU_REMU);\n87:     div_request = in.valid && is_div_op && !in.ctrl.is_illegal && !div_active_q;\n88:     div_start   = div_request && !stall;\n89:     div_complete = div_active_q && (div_result_valid_q || div_done);\n90:     div_result_selected = div_result_valid_q ? div_result_q : div_result_w;\n91:     // Asserted on the launch cycle and every busy cycle. It deasserts on the\n92:     // completion cycle so IF/ID can advance while the completed DIV enters\n93:     // EX/MEM.\n94:     ex_long_busy = div_start || div_busy || (div_active_q && !div_complete);\n95:   end\n96: \n97:   div_unit u_div (\n98:     .clock  (clock),\n99:     .reset  (reset),\n100:     .start  (div_start),\n101:     .op     (in.ctrl.alu_op),\n102:     .a      (alu_a),\n103:     .b      (alu_b),\n104:     .busy   (div_busy),\n105:     .done   (div_done),\n106:     .result (div_result_w)\n107:   );\n108: \n109:   // ── Branch resolve ────────────────────────────────────────────────────\n110:   logic        branch_cond;\n111:   logic        branch_taken;\n112:   logic [31:0] branch_target;\n113:   logic [31:0] branch_next_pc;\n114:   logic [31:0] predicted_next_pc;\n115:   logic [31:0] jump_target;\n116:   /* verilator lint_off UNUSEDSIGNAL */\n117:   logic [31:0] jalr_sum;  // bit 0 deliberately dropped per RV JALR spec\n118:   /* verilator lint_on UNUSEDSIGNAL */\n119: \n120:   always_comb begin\n121:     case (in.ctrl.branch_op)\n122:       BR_BEQ:  branch_cond = (rs1 == rs2);\n123:       BR_BNE:  branch_cond = (rs1 != rs2);\n124:       BR_BLT:  branch_cond = ($signed(rs1) <  $signed(rs2));\n125:       BR_BGE:  branch_cond = ($signed(rs1) >= $signed(rs2));\n126:       BR_BLTU: branch_cond = (rs1 <  rs2);\n127:       BR_BGEU: branch_cond = (rs1 >= rs2);\n128:       default: branch_cond = 1'b0;\n129:     endcase\n130:     branch_taken  = in.ctrl.is_branch && branch_cond;\n131:     branch_target = in.pc + in.imm;\n132:     branch_next_pc = branch_taken ? branch_target : (in.pc + 32'd4);\n133:     predicted_next_pc = in.predicted_taken ? in.predicted_target\n134:                                            : (in.pc + 32'd4);\n135:     // JALR clears bit 0 (RV spec); JAL uses imm directly.\n136:     jalr_sum    = rs1 + in.imm;\n137:     jump_target = in.ctrl.is_jalr ? {jalr_sum[31:1], 1'b0}\n138:                                   : (in.pc + in.imm);\n139:   end\n140: \n141:   // ── Misaligned branch / jump target trap ──────────────────────────────\n142:   // riscv-formal's spec demands rvfi_trap=1 when next_pc is misaligned\n143:   // (without C extension that means [1:0] != 0). We trap the offending\n144:   // instruction, suppress the redirect (PC stays linear), and clear\n145:   // reg_write so JAL/JALR don't write the return address on trap.\n146:   logic misalign_branch;\n147:   logic misalign_jump;\n148:   logic misalign_fault;\n149:   logic branch_mispredict;\n150:   logic jump_redirect;\n151:   logic jal_mispredict;\n152:   ctrl_t ctrl_with_trap;\n153: \n154:   always_comb begin\n155:     misalign_branch = in.ctrl.is_branch && branch_taken\n156:                       && (branch_target[1:0] != 2'b00);\n157:     misalign_jump   = in.ctrl.is_jump && (jump_target[1:0] != 2'b00);\n158:     misalign_fault  = misalign_branch || misalign_jump;\n159: \n160:     ctrl_with_trap = in.ctrl;\n161:     if (misalign_fault) begin\n162:       ctrl_with_trap.is_illegal = 1'b1;\n163:       ctrl_with_trap.reg_write  = 1'b0;\n164:     end\n165: \n166:     branch_mispredict = in.valid\n167:                      && in.ctrl.is_branch\n168:                      && !misalign_fault\n169:                      && (branch_next_pc != predicted_next_pc);\n170:     jal_mispredict    = in.ctrl.is_jump\n171:                      && !in.ctrl.is_jalr\n172:                      && (jump_target != predicted_next_pc);\n173:     jump_redirect     = in.valid\n174:                      && in.ctrl.is_jump\n175:                      && !misalign_fault\n176:                      && (in.ctrl.is_jalr || jal_mispredict);\n177:   end\n178: \n179:   assign redirect        = branch_mispredict || jump_redirect;\n180:   assign redirect_target = in.ctrl.is_jump ? jump_target : branch_next_pc;\n181: \n182:   // ── EX/MEM register ───────────────────────────────────────────────────\n183:   ex_mem_t reg_q;\n184: \n185:   always_ff @(posedge clock) begin\n186:     if (reset) begin\n187:       div_active_q       <= 1'b0;\n188:       div_result_valid_q <= 1'b0;\n189:       div_result_q       <= 32'b0;\n190:       div_in_q           <= '0;\n191:       div_rs1_q          <= 32'b0;\n192:       div_rs2_q          <= 32'b0;\n193:     end else begin\n194:       if (div_start) begin\n195:         div_active_q       <= 1'b1;\n196:         div_result_valid_q <= 1'b0;\n197:         div_result_q       <= 32'b0;\n198:         div_in_q           <= in;\n199:         div_rs1_q          <= rs1;\n200:         div_rs2_q          <= rs2;\n201:       end else if (div_complete && !stall) begin\n202:         div_active_q       <= 1'b0;\n203:         div_result_valid_q <= 1'b0;\n204:       end else if (div_done && div_active_q) begin\n205:         div_result_q       <= div_result_w;\n206:         div_result_valid_q <= 1'b1;\n207:       end\n208:     end\n209:   end\n210: \n211:   always_ff @(posedge clock) begin\n212:     if (reset) begin\n213:       reg_q <= '0;\n214:     end else if (stall) begin\n215:       // dmem stall: hold the EX/MEM register so the in-flight LOAD/STORE\n216:       // stays in MEM stage waiting on the bus.\n217:       reg_q <= reg_q;\n218:     end else if (div_complete) begin\n219:       reg_q.pc            <= div_in_q.pc;\n220:       reg_q.alu_result    <= div_result_selected;\n221:       reg_q.write_data    <= div_rs2_q;\n222:       reg_q.rd            <= div_in_q.rd;\n223:       reg_q.rs1_addr      <= div_in_q.rs1_addr;\n224:       reg_q.rs2_addr      <= div_in_q.rs2_addr;\n225:       reg_q.rs1_val       <= div_rs1_q;\n226:       reg_q.rs2_val       <= div_rs2_q;\n227:       reg_q.pc_next       <= div_in_q.pc + 32'd4;\n228:       reg_q.branch_taken  <= 1'b0;\n229:       reg_q.branch_target <= div_in_q.pc + div_in_q.imm;\n230:       reg_q.ctrl          <= div_in_q.ctrl;\n231:       reg_q.instr         <= div_in_q.instr;\n232:       reg_q.valid         <= div_in_q.valid;\n233:     end else if (div_start || div_active_q) begin\n234:       // A divide-class instruction occupies EX until completion. EX/MEM gets\n235:       // bubbles while the unit is busy so older instructions are not replayed.\n236:       reg_q <= '0;\n237:     end else begin\n238:       reg_q.pc            <= in.pc;\n239:       // For JAL/JALR, the rd_wdata is PC+4 (return address), not the ALU's\n240:       // sum (which is the jump target). The MEM/WB register's read-data\n241:       // mux only kicks in for LOADs, so we route PC+4 here.\n242:       reg_q.alu_result    <= in.ctrl.is_jump ? (in.pc + 32'd4) : alu_result;\n243:       reg_q.write_data    <= rs2;\n244:       reg_q.rd            <= in.rd;\n245:       reg_q.rs1_addr      <= in.rs1_addr;\n246:       reg_q.rs2_addr      <= in.rs2_addr;\n247:       reg_q.rs1_val       <= rs1;\n248:       reg_q.rs2_val       <= rs2;\n249:       // pc_next reverts to pc+4 on misalign trap so the pc_fwd checker\n250:       // (asserting next retirement's pc_rdata == this pc_wdata) stays\n251:       // consistent with the suppressed redirect.\n252:       reg_q.pc_next       <= misalign_fault     ? (in.pc + 32'd4)\n253:                             : in.ctrl.is_jump   ? jump_target\n254:                             : branch_taken      ? branch_target\n255:                                                 : (in.pc + 32'd4);\n256:       reg_q.branch_taken  <= branch_taken;\n257:       reg_q.branch_target <= branch_target;\n258:       reg_q.ctrl          <= ctrl_with_trap;\n259:       reg_q.instr         <= in.instr;\n260:       reg_q.valid         <= in.valid;\n261:     end\n262:   end\n263: \n264:   assign out = reg_q;\n265: \n266: endmodule\n\n(End of file - total 266 lines)\n</content>","metadata":{"preview":"// rtl/ex_stage.sv\n//\n// Execute stage. Resolves the operand muxes (forwarding from EX/MEM and\n// MEM/WB), runs the ALU, resolves branches, and redirects only when the\n// IF-stage prediction disagrees with the resolved next PC. Owns the EX/MEM\n// pipeline register.\n//\n// Forwarding select encoding (driven by forward_unit):\n//   00 = ID/EX register value (no forward)\n//   01 = EX/MEM aluResult (instruction immediately ahead in MEM)\n//   10 = MEM/WB result (instruction two ahead, post regfile-write mux)\n//\n// Latency:        1 cycle (EX/MEM register clocked here).\n// RVFI fields:    feeds pc_wdata (= pc_next), the rd_wdata path for\n//                 ALU and JAL/JALR (PC+4), and the branch resolve.\nmodule ex_stage (\n  input  logic               clock,\n  input  logic               reset,\n  input  logic               stall,         // freeze EX/MEM register (dmem stall)\n  input  id_ex_t   in,","truncated":false,"loaded":[]},"title":"cores/v1/rtl/ex_stage.sv","time":{"start":1778736373273,"end":1778736373279}},"id":"prt_e24f31bdd001guUrDUwJJvSz9x","sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","messageID":"msg_e24f30599001d1cDZAF9QEcbUt"}}
