{"type":"tool_use","timestamp":1778739887691,"sessionID":"ses_1dae05f62ffeBgOtDtJWADHW20","part":{"type":"tool","tool":"read","callID":"functions.read:15","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/if_stage.sv","limit":80,"offset":1},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/if_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/if_stage.sv\n2: //\n3: // Instruction fetch stage. Holds the PC register; the IF/ID payload\n4: // (pc + instr + valid) is *combinational* — there is no separate IF/ID\n5: // flop in this microarchitecture, the next-stage's ID/EX register\n6: // captures everything one cycle later.\n7: //\n8: // On flush or EX redirect, the instruction emitted to ID is forced to NOP\n9: // (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n10: // observing a real rs1/rs2 from a wrong-path instruction and inserting\n11: // a spurious load-use stall after mispredict recovery.\n12: //\n13: // A decode-light static predictor recognizes legal B-type conditional\n14: // branches with a negative immediate and direct JALs, provided the predicted\n15: // target is word-aligned. JALR remains unpredicted and resolves in EX.\n16: // A two-bank direct-mapped replay table hides external imem stalls only\n17: // through a registered lookahead candidate for the current PC; the IF\n18: // decision path never reads or compares the table combinationally. Each\n19: // bank has 128 entries addressed by pc[8:2]. Entries store pc[31:9], a\n20: // valid bit, and the instruction word; a per-index MRU bit chooses which\n21: // bank to replace when neither bank already contains the fetched tag.\n22: //\n23: // Latency:        PC-reg update is synchronous; output is combinational.\n24: // RVFI fields:    feeds pc_rdata (via ID/EX/MEM/WB) and pc_wdata (via\n25: //                 EX-stage redirect).\n26: module if_stage (\n27:   input  logic              clock,\n28:   input  logic              reset,\n29:   input  logic              stall,            // hold PC (load-use)\n30:   input  logic              flush,            // emit NOP into ID this cycle\n31:   input  logic              redirect,         // EX has resolved a branch/jump\n32:   input  logic [31:0]       redirect_target,\n33:   output logic [31:0]       imem_addr,\n34:   input  logic [31:0]       imem_data,\n35:   input  logic              imem_ready,\n36:   output logic              fetch_ready,\n37:   output if_id_t  out\n38: );\n39: \n40:   localparam logic [31:0] RESET_PC = 32'h0000_0000;\n41:   localparam logic [31:0] NOP      = 32'h0000_0013;\n42:   localparam int unsigned REPLAY_INDEX_BITS = 7;\n43:   localparam int unsigned REPLAY_ENTRIES    = 1 << REPLAY_INDEX_BITS;\n44:   localparam int unsigned REPLAY_TAG_HI_LSB = REPLAY_INDEX_BITS + 2;\n45:   localparam int unsigned REPLAY_TAG_HI_BITS = 32 - REPLAY_TAG_HI_LSB;\n46: \n47:   logic [31:0] pc;\n48:   logic [31:0] next_pc;\n49:   logic [31:0] pc_plus4;\n50:   logic [31:0] fetch_instr;\n51:   logic [31:0] branch_imm;\n52:   logic [31:0] jal_imm;\n53:   logic [31:0] branch_target;\n54:   logic [31:0] jal_target;\n55:   logic [31:0] predicted_target;\n56:   logic        fetch_kill;\n57:   logic        predict_enable;\n58:   logic        branch_opcode;\n59:   logic        branch_funct_legal;\n60:   logic        branch_predict_taken;\n61:   logic        jal_opcode;\n62:   logic        jal_predict_taken;\n63:   logic        predicted_taken;\n64: \n65:   logic                              replay_valid_b0 [0:REPLAY_ENTRIES-1];\n66:   logic                              replay_valid_b1 [0:REPLAY_ENTRIES-1];\n67:   logic [REPLAY_TAG_HI_BITS-1:0]     replay_tag_hi_b0 [0:REPLAY_ENTRIES-1];\n68:   logic [REPLAY_TAG_HI_BITS-1:0]     replay_tag_hi_b1 [0:REPLAY_ENTRIES-1];\n69:   logic [31:0]                       replay_instr_b0 [0:REPLAY_ENTRIES-1];\n70:   logic [31:0]                       replay_instr_b1 [0:REPLAY_ENTRIES-1];\n71:   logic                              replay_mru [0:REPLAY_ENTRIES-1];\n72:   logic [REPLAY_INDEX_BITS-1:0]      replay_fill_idx;\n73:   logic [REPLAY_INDEX_BITS-1:0]      replay_lookup_idx;\n74:   logic [REPLAY_TAG_HI_BITS-1:0]     replay_fill_tag_hi;\n75:   logic [REPLAY_TAG_HI_BITS-1:0]     replay_lookup_tag_hi;\n76:   logic [31:0]                       replay_lookup_pc;\n77:   logic                              replay_fill_bank0_match;\n78:   logic                              replay_fill_bank1_match;\n79:   logic                              replay_fill_bank;\n80:   logic                              replay_lookup_bank0_hit;\n\n(Showing lines 1-80 of 204. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// rtl/if_stage.sv\n//\n// Instruction fetch stage. Holds the PC register; the IF/ID payload\n// (pc + instr + valid) is *combinational* — there is no separate IF/ID\n// flop in this microarchitecture, the next-stage's ID/EX register\n// captures everything one cycle later.\n//\n// On flush or EX redirect, the instruction emitted to ID is forced to NOP\n// (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n// observing a real rs1/rs2 from a wrong-path instruction and inserting\n// a spurious load-use stall after mispredict recovery.\n//\n// A decode-light static predictor recognizes legal B-type conditional\n// branches with a negative immediate and direct JALs, provided the predicted\n// target is word-aligned. JALR remains unpredicted and resolves in EX.\n// A two-bank direct-mapped replay table hides external imem stalls only\n// through a registered lookahead candidate for the current PC; the IF\n// decision path never reads or compares the table combinationally. Each\n// bank has 128 entries addressed by pc[8:2]. Entries store pc[31:9], a\n// valid bit, and the instruction word; a per-index MRU bit chooses which","truncated":true,"loaded":[]},"title":"cor