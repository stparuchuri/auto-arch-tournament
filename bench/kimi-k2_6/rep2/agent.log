{"type":"tool_use","timestamp":1778736422342,"sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","part":{"type":"tool","tool":"read","callID":"read:12","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/core_pkg.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep2/cores/v1/rtl/core_pkg.sv</path>\n<type>file</type>\n<content>\n1: // rtl/core_pkg.sv\n2: //\n3: // Core-wide constants and pipeline-bundle types.\n4: //\n5: // Compilation-unit scope (no `package … endpackage` wrapper) because\n6: // Yosys's Verilog frontend rejects `import pkg::*;` even though it\n7: // accepts `pkg::sym` refs and package definitions. A file-scope\n8: // definition with an `\\`ifndef` guard is the lowest common denominator\n9: // across Verilator, Yosys, sby, and nextpnr-himbaechel.\n10: //\n11: // Order matters: this file MUST be the first source passed to any tool\n12: // (Verilator/cocotb runner / build.sh / formal staging). Subsequent\n13: // includes hit the guard and become no-ops.\n14: //\n15: // Latency:        n/a (declarations only).\n16: // RVFI fields:    none (defines types; no logic).\n17: `ifndef CORE_PKG_DEFINED\n18: `define CORE_PKG_DEFINED\n19: \n20:   // ── ALU operations ──────────────────────────────────────────────────────\n21:   localparam logic [4:0] ALU_ADD    = 5'd0;\n22:   localparam logic [4:0] ALU_SUB    = 5'd1;\n23:   localparam logic [4:0] ALU_AND    = 5'd2;\n24:   localparam logic [4:0] ALU_OR     = 5'd3;\n25:   localparam logic [4:0] ALU_XOR    = 5'd4;\n26:   localparam logic [4:0] ALU_SLT    = 5'd5;\n27:   localparam logic [4:0] ALU_SLTU   = 5'd6;\n28:   localparam logic [4:0] ALU_SLL    = 5'd7;\n29:   localparam logic [4:0] ALU_SRL    = 5'd8;\n30:   localparam logic [4:0] ALU_SRA    = 5'd9;\n31:   localparam logic [4:0] ALU_LUI    = 5'd10;\n32:   // RV32M ops use op[4]=1 and op[2:0]=funct3, leaving the common RV32I\n33:   // one-cycle path behind op[4]=0.\n34:   localparam logic [4:0] ALU_MUL    = 5'b10000;\n35:   localparam logic [4:0] ALU_MULH   = 5'b10001;\n36:   localparam logic [4:0] ALU_MULHSU = 5'b10010;\n37:   localparam logic [4:0] ALU_MULHU  = 5'b10011;\n38:   localparam logic [4:0] ALU_DIV    = 5'b10100;\n39:   localparam logic [4:0] ALU_DIVU   = 5'b10101;\n40:   localparam logic [4:0] ALU_REM    = 5'b10110;\n41:   localparam logic [4:0] ALU_REMU   = 5'b10111;\n42: \n43:   // ── Branch operations (encoded = funct3 of BRANCH opcode) ───────────────\n44:   // Phase 1 only references BR_BEQ (decoder default). The rest are\n45:   // referenced by the EX-stage comparator in phase 2; we keep them here\n46:   // for documentation and silence UNUSEDPARAM until then.\n47:   localparam logic [2:0] BR_BEQ  = 3'd0;\n48:   /* verilator lint_off UNUSEDPARAM */\n49:   localparam logic [2:0] BR_BNE  = 3'd1;\n50:   localparam logic [2:0] BR_BLT  = 3'd4;\n51:   localparam logic [2:0] BR_BGE  = 3'd5;\n52:   localparam logic [2:0] BR_BLTU = 3'd6;\n53:   localparam logic [2:0] BR_BGEU = 3'd7;\n54:   /* verilator lint_on UNUSEDPARAM */\n55: \n56:   // ── Pipeline-bundle typedefs ────────────────────────────────────────────\n57:   typedef struct packed {\n58:     logic [4:0] alu_op;\n59:     logic       alu_src;     // 0 = rs2 value, 1 = immediate\n60:     logic [2:0] branch_op;\n61:     logic       is_branch;\n62:     logic       is_jump;\n63:     logic       is_jalr;\n64:     logic       is_lui;\n65:     logic       is_auipc;\n66:     logic       mem_read;\n67:     logic       mem_write;\n68:     logic [1:0] mem_width;   // 0 = byte, 1 = half, 2 = word\n69:     logic       mem_sext;    // sign-extend load result\n70:     logic       reg_write;\n71:     logic       mem_to_reg;  // 1 = write loaded data, 0 = write ALU result\n72:     logic       is_illegal;  // default-true in decoder; cleared inside\n73:                               // validated opcode/funct arms only.\n74:   } ctrl_t;\n75: \n76:   // IF -> ID combinational bundle (no register; PC reg sits in if_stage).\n77:   // instr may be the live imem word or a word supplied by IF's registered\n78:   // lookahead replay predictor during an external imem stall. The replay\n79:   // predictor uses two direct-mapped 128-entry banks indexed by pc[8:2],\n80:   // tagged by pc[31:9], and replaced with a per-index MRU bit. Tag and\n81:   // instruction payload arrays are resetless behind bank valid bits.\n82:   // predicted_* is generic next-PC prediction metadata for any IF-resolved\n83:   // control-flow instruction, not branch-only state.\n84:   typedef struct packed {\n85:     logic [31:0] pc;\n86:     logic [31:0] instr;\n87:     logic        predicted_taken;\n88:     logic [31:0] predicted_target;\n89:     logic        valid;\n90:   } if_id_t;\n91: \n92:   // ID/EX register payload.\n93:   // predicted_* carries the IF next-PC prediction, computed from the selected\n94:   // live/replayed instruction word, into EX for validation.\n95:   typedef struct packed {\n96:     logic [31:0] pc;\n97:     logic [31:0] rs1_val;\n98:     logic [31:0] rs2_val;\n99:     logic [31:0] imm;\n100:     logic [4:0]  rd;\n101:     logic [4:0]  rs1_addr;\n102:     logic [4:0]  rs2_addr;\n103:     ctrl_t       ctrl;\n104:     logic [31:0] instr;\n105:     logic        predicted_taken;\n106:     logic [31:0] predicted_target;\n107:     logic        valid;\n108:   } id_ex_t;\n109: \n110:   // EX/MEM register payload.\n111:   typedef struct packed {\n112:     logic [31:0] pc;\n113:     logic [31:0] alu_result;\n114:     logic [31:0] write_data;     // raw rs2 (post-forward), pre byte replication\n115:     logic [4:0]  rd;\n116:     logic [4:0]  rs1_addr;\n117:     logic [4:0]  rs2_addr;\n118:     logic [31:0] rs1_val;        // post-forward rs1 used by EX\n119:     logic [31:0] rs2_val;        // post-forward rs2 used by EX\n120:     logic [31:0] pc_next;        // resolved next-PC (target / pc+4)\n121:     logic        branch_taken;\n122:     logic [31:0] branch_target;\n123:     ctrl_t       ctrl;\n124:     logic [31:0] instr;\n125:     logic        valid;\n126:   } ex_mem_t;\n127: \n128:   // MEM/WB register payload — mirrors the RVFI-feeding contract.\n129:   typedef struct packed {\n130:     logic [31:0] pc;\n131:     logic [31:0] alu_result;\n132:     logic [31:0] read_data;      // sign/zero-extended load (for regfile write)\n133:     logic [4:0]  rd;\n134:     logic [4:0]  rs1_addr;\n135:     logic [4:0]  rs2_addr;\n136:     logic [31:0] rs1_val;\n137:     logic [31:0] rs2_val;\n138:     logic [31:0] pc_next;\n139:     logic [31:0] mem_addr;       // word-aligned for RVFI ALIGNED_MEM\n140:     logic [31:0] mem_rdata;      // raw memory word\n141:     logic [31:0] mem_wdata;      // replicated byte-lane write data\n142:     logic [3:0]  mem_wmask;\n143:     logic [3:0]  mem_rmask;\n144:     ctrl_t       ctrl;\n145:     logic [31:0] instr;\n146:     logic        valid;\n147:   } mem_wb_t;\n148: \n149: `endif // CORE_PKG_DEFINED\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"// rtl/core_pkg.sv\n//\n// Core-wide constants and pipeline-bundle types.\n//\n// Compilation-unit scope (no `package … endpackage` wrapper) because\n// Yosys's Verilog frontend rejects `import pkg::*;` even though it\n// accepts `pkg::sym` refs and package definitions. A file-scope\n// definition with an `\\`ifndef` guard is the lowest common denominator\n// across Verilator, Yosys, sby, and nextpnr-himbaechel.\n//\n// Order matters: this file MUST be the first source passed to any tool\n// (Verilator/cocotb runner / build.sh / formal staging). Subsequent\n// includes hit the guard and become no-ops.\n//\n// Latency:        n/a (declarations only).\n// RVFI fields:    none (defines types; no logic).\n`ifndef CORE_PKG_DEFINED\n`define CORE_PKG_DEFINED\n\n  // ── ALU operations ──────────────────────────────────────────────────────","truncated":false,"loaded":[]},"title":"cores/v1/rtl/core_pkg.sv","time":{"start":1778736422328,"end":1778736422341}},"id":"prt_e24f3dc6b001MxGfHWpiit5EZM","sessionID":"ses_1db0f83a4ffehvpEIUlbQzUjKs","messageID":"msg_e24f3abd5001ZfPHEzLMxtsCgO"}}
