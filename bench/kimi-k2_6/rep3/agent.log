{"type":"tool_use","timestamp":1778772653890,"sessionID":"ses_1d8e76023ffeeLL9pZauZQgxoT","part":{"type":"tool","tool":"read","callID":"read:6","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/rtl/if_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/rtl/if_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/if_stage.sv\n2: //\n3: // Instruction fetch stage. Holds the PC register; the IF/ID payload\n4: // (pc + instr + valid) is *combinational* — there is no separate IF/ID\n5: // flop in this microarchitecture, the next-stage's ID/EX register\n6: // captures everything one cycle later.\n7: //\n8: // On flush or redirect, the instruction emitted to ID is forced to NOP\n9: // (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n10: // observing a real rs1/rs2 from a wrong-path instruction and inserting\n11: // a spurious load-use stall the cycle after a taken branch.\n12: //\n13: // Latency:        PC-reg update is synchronous; output is combinational.\n14: // RVFI fields:    feeds pc_rdata (via ID/EX/MEM/WB) and pc_wdata (via\n15: //                 EX-stage redirect).\n16: module if_stage (\n17:   input  logic              clock,\n18:   input  logic              reset,\n19:   input  logic              stall,            // hold PC (load-use)\n20:   input  logic              flush,            // emit NOP into ID this cycle\n21:   input  logic              redirect,         // EX has resolved a branch/jump\n22:   input  logic [31:0]       redirect_target,\n23:   output logic [31:0]       imem_addr,\n24:   input  logic [31:0]       imem_data,\n25:   input  logic              imem_ready,       // bus backpressure\n26:   output logic              icache_hit,       // 8-entry direct-mapped hit\n27:   output if_id_t  out\n28: );\n29: \n30:   localparam logic [31:0] RESET_PC = 32'h0000_0000;\n31: \n32:   logic [31:0] pc;\n33:   logic [31:0] next_pc;\n34: \n35:   // ── 8-entry direct-mapped instruction cache ────────────────────────────\n36:   // Indexed by pc[4:2], tag = pc[31:5]. 8 entries × (valid + 27-bit tag + 32-bit data).\n37:   logic [31:0] icache_data  [0:7];\n38:   logic [26:0] icache_tag   [0:7];\n39:   logic        icache_valid [0:7];\n40: \n41:   logic [2:0]  cache_idx;\n42:   logic [26:0] cache_tag;\n43: \n44:   assign cache_idx = pc[4:2];\n45:   assign cache_tag = pc[31:5];\n46: \n47:   always_comb begin\n48:     icache_hit = icache_valid[cache_idx] && (icache_tag[cache_idx] == cache_tag);\n49:   end\n50: \n51:   always_comb begin\n52:     next_pc = redirect ? redirect_target : pc + 32'd4;\n53:   end\n54: \n55:   // PC register and cache update share one always_ff so the cache is\n56:   // updated with the *old* PC (the one that requested imem_data) before\n57:   // the nonblocking assignment to pc takes effect.\n58:   always_ff @(posedge clock) begin\n59:     if (reset) begin\n60:       pc <= RESET_PC;\n61:       for (int i = 0; i < 8; i++) begin\n62:         icache_valid[i] <= 1'b0;\n63:       end\n64:     end else begin\n65:       if (imem_ready && !redirect) begin\n66:         icache_valid[cache_idx] <= 1'b1;\n67:         icache_tag[cache_idx]   <= cache_tag;\n68:         icache_data[cache_idx]  <= imem_data;\n69:       end\n70:       if      (redirect) pc <= redirect_target;\n71:       else if (!stall)   pc <= next_pc;\n72:     end\n73:   end\n74: \n75:   assign imem_addr = pc;\n76: \n77:   // Combinational output:\n78:   //   - flush/redirect -> NOP (prevents wrong-path hazards)\n79:   //   - cache hit during stall -> cached instruction, valid stays high\n80:   //   - otherwise -> live imem_data (valid when !flush && !redirect)\n81:   always_comb begin\n82:     out.pc    = pc;\n83:     if (flush || redirect)\n84:       out.instr = 32'h0000_0013;\n85:     else if (!imem_ready && icache_hit)\n86:       out.instr = icache_data[cache_idx];\n87:     else\n88:       out.instr = imem_data;\n89:     out.valid = !(flush || redirect);\n90:   end\n91: \n92: endmodule\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"// rtl/if_stage.sv\n//\n// Instruction fetch stage. Holds the PC register; the IF/ID payload\n// (pc + instr + valid) is *combinational* — there is no separate IF/ID\n// flop in this microarchitecture, the next-stage's ID/EX register\n// captures everything one cycle later.\n//\n// On flush or redirect, the instruction emitted to ID is forced to NOP\n// (`0x00000013` = ADDI x0,x0,0). This prevents the hazard unit from\n// observing a real rs1/rs2 from a wrong-path instruction and inserting\n// a spurious load-use stall the cycle after a taken branch.\n//\n// Latency:        PC-reg update is synchronous; output is combinational.\n// RVFI fields:    feeds pc_rdata (via ID/EX/MEM/WB) and pc_wdata (via\n//                 EX-stage redirect).\nmodule if_stage (\n  input  logic              clock,\n  input  logic              reset,\n  input  logic              stall,            // hold PC (load-use)\n  input  logic              flush,            // emit NOP into ID this cycle","truncated":false,"loaded":[]},"title":"cores/bench/rtl/if_stage.sv","time":{"start":1778772653881,"end":1778772653889}},"id":"prt_e271cb281001ZMX70jTYS1xkXp","sessionID":"ses_1d8e76023ffeeLL9pZauZQgxoT","messageID":"msg_e271c4b74001hRvr5P8sketTo6"}}
