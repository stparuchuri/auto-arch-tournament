 logic [31:0]        fwd_mem_wb,    // WB-stage write-data mux output\n   output ex_mem_t  out,\n   output logic               redirect,\n-  output logic [31:0]        redirect_target\n+  output logic [31:0]        redirect_target,\n+  // Predictor update outputs (combinational, registered in IF)\n+  output logic               pred_update,\n+  output logic [3:0]         pred_update_idx,\n+  output logic [25:0]        pred_update_tag,\n+  output logic [31:0]        pred_update_target,\n+  output logic               pred_update_taken\n );\n \n   // ── Operand forwarding muxes ───────────────────────────────────────────\n   logic [31:0] rs1;\n","additions":7,"deletions":1},"truncated":false},"title":"cores/bench/rtl/ex_stage.sv","time":{"start":1778780764087,"end":1778780764090}},"id":"prt_e2798619c001yOAkmh2EcP3koV","sessionID":"ses_1d86a7552ffe53XE7uatXuB2Ml","messageID":"msg_e27985214001Ryjwmjl45TWK9H"}}
