ield from ex_mem_t to save 32 FFs and\n     reduce routing.\n  These changes shorten the EX->IF redirect critical path and reduce EX","truncated":false,"loaded":[]},"title":"cores/bench/experiments/hypotheses/hyp-20260514-001-r6s0.yaml","time":{"start":1778767488908,"end":1778767488992}},"id":"prt_e26cde4650010dOYW2JRd8QWkK","sessionID":"ses_1d93775c5ffebpWHQwJ6cKwaAu","messageID":"msg_e26cdc8b50015j1pPjaRw2ruCb"}}
