{"type":"tool_use","timestamp":1778773318784,"sessionID":"ses_1d8e76023ffeeLL9pZauZQgxoT","part":{"type":"tool","tool":"read","callID":"read:12","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/rtl/mem_stage.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/rtl/mem_stage.sv</path>\n<type>file</type>\n<content>\n1: // rtl/mem_stage.sv\n2: //\n3: // Memory access stage. Drives the dmem read/write ports combinationally\n4: // from the EX/MEM register, and sign/zero-extends the loaded data into\n5: // the MEM/WB register.\n6: //\n7: // Byte-lane discipline:\n8: //   - Write data is replicated across all four byte lanes; the\n9: //     byte-mask (mem_wmask) selects the actual destination bytes.\n10: //   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n11: //     zero-extend the low 8/16 bits per the LB/LBU/LH/LHU encoding.\n12: //   - For RVFI ALIGNED_MEM, mem_addr is reported word-aligned and the\n13: //     byte position is captured in mem_rmask / mem_wmask.\n14: //\n15: // Latency:        1 cycle (MEM/WB register clocked here).\n16: // RVFI fields:    feeds mem_addr, mem_rmask, mem_wmask, mem_rdata,\n17: //                 mem_wdata, plus rd_wdata via the loaded-data path.\n18: module mem_stage (\n19:   input  logic               clock,\n20:   input  logic               reset,\n21:   // hold_wb: dmem stall is in effect. MEM/WB's data fields are RETAINED\n22:   // (so the previously-retired LOAD's `rd` / `read_data` / `ctrl.reg_write`\n23:   // remain visible to forward_unit), but `valid` is cleared so:\n24:   //   - rvfi_order doesn't increment for held cycles\n25:   //   - wb_stage doesn't write the regfile twice\n26:   // Zeroing the whole register would lose the LOAD's load_data, breaking\n27:   // MEM/WB->EX forwarding for any dependent instruction that's also held\n28:   // in ID/EX during the stall (e.g. a BNE that consumes a LOAD's result).\n29:   input  logic               hold_wb,\n30:   // ex_mem_t carries branch_taken / branch_target / pc_next / rs?_val\n31:   // for downstream RVFI use; mem_stage only consumes a subset, so the\n32:   // remaining fields look unused from this module's perspective.\n33:   /* verilator lint_off UNUSEDSIGNAL */\n34:   input  ex_mem_t  in,\n35:   /* verilator lint_on UNUSEDSIGNAL */\n36:   // dmem interface\n37:   output logic [31:0]        dmem_addr,\n38:   output logic [31:0]        dmem_wdata,\n39:   input  logic [31:0]        dmem_rdata,\n40:   output logic [3:0]         dmem_wen,\n41:   output logic               dmem_ren,\n42:   // MEM/WB register output\n43:   output mem_wb_t  out\n44: );\n45: \n46:   logic [31:0] wdata_rep;\n47:   logic [3:0]  byte_mask;\n48:   logic [31:0] aligned_addr;\n49:   // shifted[31:16] is dropped on byte/halfword loads; only [15:0] feeds\n50:   // the sign/zero-extension mux.\n51:   /* verilator lint_off UNUSEDSIGNAL */\n52:   logic [31:0] shifted;\n53:   /* verilator lint_on UNUSEDSIGNAL */\n54:   logic [7:0]  byte_val;\n55:   logic [15:0] hword_val;\n56:   logic [31:0] load_data;\n57: \n58:   // Misaligned mem-access trap. RV32I requires word-aligned LW/SW and\n59:   // halfword-aligned LH/LHU/SH; byte ops are always aligned.\n60:   // riscv-formal's RISCV_FORMAL_ALIGNED_MEM contract demands rvfi_trap=1\n61:   // when the effective byte address is not aligned to the access width.\n62:   // On trap, the dmem ports are gated off and ctrl propagates is_illegal.\n63:   logic mem_misalign;\n64:   logic mem_op;\n65:   ctrl_t ctrl_with_trap;\n66: \n67:   always_comb begin\n68:     // Byte/halfword replication for stores.\n69:     case (in.ctrl.mem_width)\n70:       2'd0:    wdata_rep = {4{in.write_data[7:0]}};\n71:       2'd1:    wdata_rep = {2{in.write_data[15:0]}};\n72:       default: wdata_rep = in.write_data;\n73:     endcase\n74: \n75:     // Byte-lane mask shifted to addr[1:0] * 1.\n76:     case (in.ctrl.mem_width)\n77:       2'd0:    byte_mask = (4'b0001 << in.alu_result[1:0]);\n78:       2'd1:    byte_mask = (4'b0011 << in.alu_result[1:0]);\n79:       default: byte_mask = 4'b1111;\n80:     endcase\n81: \n82:     mem_op       = in.ctrl.mem_read || in.ctrl.mem_write;\n83:     mem_misalign = mem_op && (\n84:                      (in.ctrl.mem_width == 2'd2 && in.alu_result[1:0] != 2'b00) ||\n85:                      (in.ctrl.mem_width == 2'd1 && in.alu_result[0]   != 1'b0)\n86:                      // 2'd0 (byte) is never misaligned.\n87:                    );\n88: \n89:     ctrl_with_trap = in.ctrl;\n90:     if (mem_misalign) begin\n91:       ctrl_with_trap.is_illegal = 1'b1;\n92:       ctrl_with_trap.reg_write  = 1'b0;\n93:     end\n94: \n95:     // Combinational dmem outputs — gated off on misalign.\n96:     dmem_addr  = in.alu_result;\n97:     dmem_wdata = wdata_rep;\n98:     dmem_wen   = (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n99:     dmem_ren   = in.ctrl.mem_read  && !mem_misalign;\n100: \n101:     // Load extraction: shift right then sign/zero-extend the low N bits.\n102:     shifted   = dmem_rdata >> (in.alu_result[1:0] * 8);\n103:     byte_val  = shifted[7:0];\n104:     hword_val = shifted[15:0];\n105:     case (in.ctrl.mem_width)\n106:       2'd0:    load_data = in.ctrl.mem_sext\n107:                          ? {{24{byte_val[7]}},  byte_val}\n108:                          : {24'b0,              byte_val};\n109:       2'd1:    load_data = in.ctrl.mem_sext\n110:                          ? {{16{hword_val[15]}}, hword_val}\n111:                          : {16'b0,               hword_val};\n112:       default: load_data = dmem_rdata;\n113:     endcase\n114: \n115:     // RVFI ALIGNED_MEM expects word-aligned mem_addr; mem_addr=0 if no access.\n116:     aligned_addr = (mem_op && !mem_misalign)\n117:                  ? {in.alu_result[31:2], 2'b00}\n118:                  : 32'b0;\n119:   end\n120: \n121:   // ── MEM/WB register ───────────────────────────────────────────────────\n122:   mem_wb_t reg_q;\n123: \n124:   always_ff @(posedge clock) begin\n125:     if (reset) begin\n126:       reg_q <= '0;\n127:     end else if (hold_wb) begin\n128:       // Clear valid (no double-retire / no double-regfile-write), but\n129:       // KEEP every other field. Forwarding from MEM/WB to a stalled\n130:       // dependent in ID/EX needs the held LOAD's rd/read_data/ctrl\n131:       // alive for as many cycles as the dmem stall lasts.\n132:       reg_q.valid <= 1'b0;\n133:     end else begin\n134:       reg_q.pc         <= in.pc;\n135:       reg_q.alu_result <= in.alu_result;\n136:       reg_q.read_data  <= load_data;\n137:       reg_q.rd         <= in.rd;\n138:       reg_q.rs1_addr   <= in.rs1_addr;\n139:       reg_q.rs2_addr   <= in.rs2_addr;\n140:       reg_q.rs1_val    <= in.rs1_val;\n141:       reg_q.rs2_val    <= in.rs2_val;\n142:       reg_q.pc_next    <= in.pc_next;\n143:       reg_q.mem_addr   <= aligned_addr;\n144:       reg_q.mem_rdata  <= dmem_rdata;\n145:       reg_q.mem_wdata  <= wdata_rep;\n146:       reg_q.mem_wmask  <= (in.ctrl.mem_write && !mem_misalign) ? byte_mask : 4'b0000;\n147:       reg_q.mem_rmask  <= (in.ctrl.mem_read  && !mem_misalign) ? byte_mask : 4'b0000;\n148:       reg_q.ctrl       <= ctrl_with_trap;\n149:       reg_q.instr      <= in.instr;\n150:       reg_q.valid      <= in.valid;\n151:     end\n152:   end\n153: \n154:   assign out = reg_q;\n155: \n156: endmodule\n\n(End of file - total 156 lines)\n</content>","metadata":{"preview":"// rtl/mem_stage.sv\n//\n// Memory access stage. Drives the dmem read/write ports combinationally\n// from the EX/MEM register, and sign/zero-extends the loaded data into\n// the MEM/WB register.\n//\n// Byte-lane discipline:\n//   - Write data is replicated across all four byte lanes; the\n//     byte-mask (mem_wmask) selects the actual destination bytes.\n//   - Load: shift the raw word right by `addr[1:0]*8`, then sign- or\n//     zero-extend the low 8/16 bits per the LB/LBU/LH/LHU encoding.\n//   - For RVFI ALIGNED_MEM, mem_addr is reported word-aligned and the\n//     byte position is captured in mem_rmask / mem_wmask.\n//\n// Latency:        1 cycle (MEM/WB register clocked here).\n// RVFI fields:    feeds mem_addr, mem_rmask, mem_wmask, mem_rdata,\n//                 mem_wdata, plus rd_wdata via the loaded-data path.\nmodule mem_stage (\n  input  logic               clock,\n  input  logic               reset,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/mem_stage.sv","time":{"start":1778773318764,"end":1778773318783}},"id":"prt_e2726d9bf001Hdh43L4XBr5NqQ","sessionID":"ses_1d8e76023ffeeLL9pZauZQgxoT","messageID":"msg_e2726b4fa001MD3bQHUJ70r6kg"}}
