{"type":"tool_use","timestamp":1778780552965,"sessionID":"ses_1d86ae568ffeSeDaRHZ9bpqkcn","part":{"type":"tool","tool":"read","callID":"functions.read:0","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/worktrees/hyp-20260514-002-r11s1/cores/bench/rtl/alu.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/worktrees/hyp-20260514-002-r11s1/cores/bench/rtl/alu.sv</path>\n<type>file</type>\n<content>\n1: // rtl/alu.sv\n2: //\n3: // RV32IM combinational ALU. Hardware multiplier and divider are SystemVerilog\n4: // `*` and `/` on signed/unsigned types — Verilator and Yosys both support\n5: // these and emit reasonable structural hardware.\n6: //\n7: // RV32IM division semantics (overridden from straight `signed /`):\n8: //   DIV  by 0       -> -1   (all ones)\n9: //   DIVU by 0       -> 0xFFFFFFFF\n10: //   DIV  INT_MIN/-1 -> INT_MIN  (no trap, defined overflow)\n11: //   REM  by 0       -> dividend\n12: //   REMU by 0       -> dividend\n13: //   REM  INT_MIN/-1 -> 0\n14: //\n15: // Latency:        combinational (0 cycles).\n16: // RVFI fields:    feeds rd_wdata (via EX/MEM/WB), branch resolution, mem_addr.\n17: module alu (\n18:   input  logic [4:0]  op,\n19:   input  logic [31:0] a,\n20:   input  logic [31:0] b,\n21:   output logic [31:0] out\n22: );\n23: \n24:   logic        [4:0]  shamt;\n25:   logic        [31:0] fast_out;\n26:   logic        [31:0] m_out;\n27: \n28:   // 64-bit products, computed once and selected per op.\n29:   // mul_ss/mul_su low halves are unused (only MULH/MULHSU read the high\n30:   // half). Verilator's UNUSEDSIGNAL is silenced locally — the unused\n31:   // bits are dead-code-eliminated by Yosys.\n32:   /* verilator lint_off UNUSEDSIGNAL */\n33:   logic signed [63:0] mul_ss;  // signed*signed\n34:   logic        [63:0] mul_uu;  // unsigned*unsigned (both halves used)\n35:   logic signed [63:0] mul_su;  // signed*unsigned (a signed, b unsigned)\n36:   /* verilator lint_on UNUSEDSIGNAL */\n37: \n38:   always_comb begin\n39:     shamt = b[4:0];\n40: \n41:     // ── Fast path: base integer ops (small mux tree) ────────────────────\n42:     case (op)\n43:       ALU_ADD:  fast_out = a + b;\n44:       ALU_SUB:  fast_out = a - b;\n45:       ALU_AND:  fast_out = a & b;\n46:       ALU_OR:   fast_out = a | b;\n47:       ALU_XOR:  fast_out = a ^ b;\n48:       ALU_SLT:  fast_out = {31'b0, $signed(a) < $signed(b)};\n49:       ALU_SLTU: fast_out = {31'b0, a < b};\n50:       ALU_SLL:  fast_out = a << shamt;\n51:       ALU_SRL:  fast_out = a >> shamt;\n52:       ALU_SRA:  fast_out = $unsigned($signed(a) >>> shamt);\n53:       ALU_LUI:  fast_out = b;\n54:       default:  fast_out = 32'b0;\n55:     endcase\n56:   end\n57: \n58:   always_comb begin\n59:     // Guard multipliers off the critical path for non-M ops.\n60:     // Default products to zero; only evaluate when the opcode actually\n61:     // needs a multiply result.\n62:     mul_ss = 64'b0;\n63:     mul_uu = 64'b0;\n64:     mul_su = 64'b0;\n65:     if (op == ALU_MUL || op == ALU_MULH || op == ALU_MULHU || op == ALU_MULHSU) begin\n66:       mul_ss = $signed({{32{a[31]}}, a}) * $signed({{32{b[31]}}, b});\n67:       mul_uu = {32'b0, a} * {32'b0, b};\n68:       mul_su = $signed({{32{a[31]}}, a}) * $signed({32'b0, b});\n69:     end\n70: \n71:     // ── M-extension path (heavy combinational cloud) ────────────────────\n72:     // Under RISCV_FORMAL_ALTOPS the hardware operations are substituted for\n73:     // tractable algebraic stand-ins so bitwuzla can solve the BMC inside\n74:     // the 20-step depth budget. The same substitution must appear in the\n75:     // riscv-formal spec (insn_*.v). The Verilator/cocotb/cosim builds leave\n76:     // ALTOPS undefined and run the real arithmetic.\n77: `ifdef RISCV_FORMAL_ALTOPS\n78:     case (op)\n79:       ALU_MUL:    m_out = (a + b) ^ 32'h5876063e;\n80:       ALU_MULH:   m_out = (a + b) ^ 32'hf6583fb7;\n81:       ALU_MULHU:  m_out = (a + b) ^ 32'h949ce5e8;\n82:       ALU_MULHSU: m_out = (a - b) ^ 32'hecfbe137;\n83:       ALU_DIV:    m_out = (a - b) ^ 32'h7f8529ec;\n84:       ALU_DIVU:   m_out = (a - b) ^ 32'h10e8fd70;\n85:       ALU_REM:    m_out = (a - b) ^ 32'h8da68fa5;\n86:       ALU_REMU:   m_out = (a - b) ^ 32'h3138d0e1;\n87:       default:    m_out = 32'b0;\n88:     endcase\n89: `else\n90:     case (op)\n91:       ALU_MUL:    m_out = mul_uu[31:0];\n92:       ALU_MULH:   m_out = $unsigned(mul_ss[63:32]);\n93:       ALU_MULHU:  m_out = mul_uu[63:32];\n94:       ALU_MULHSU: m_out = $unsigned(mul_su[63:32]);\n95:       ALU_DIV: begin\n96:         if (b == 32'b0)\n97:           m_out = 32'hFFFFFFFF;\n98:         else if (a == 32'h80000000 && b == 32'hFFFFFFFF)\n99:           m_out = 32'h80000000;\n100:         else\n101:           m_out = $unsigned($signed(a) / $signed(b));\n102:       end\n103:       ALU_DIVU: m_out = (b == 32'b0) ? 32'hFFFFFFFF : (a / b);\n104:       ALU_REM: begin\n105:         if (b == 32'b0)\n106:           m_out = a;\n107:         else if (a == 32'h80000000 && b == 32'hFFFFFFFF)\n108:           m_out = 32'b0;\n109:         else\n110:           m_out = $unsigned($signed(a) % $signed(b));\n111:       end\n112:       ALU_REMU: m_out = (b == 32'b0) ? a : (a % b);\n113:       default:  m_out = 32'b0;\n114:     endcase\n115: `endif\n116:   end\n117: \n118:   // ── Final 2:1 mux ────────────────────────────────────────────────────\n119:   // The fast path (ADD/SUB/LOGIC/SHIFT/SLT/LUI) is selected by a single\n120:   // comparison instead of folding into a 19-entry case statement. This\n121:   // keeps the heavy multiplier/divider outputs off the fast-path mux\n122:   // tree, shortening the combinational path for the majority of ops.\n123:   assign out = (op >= ALU_MUL) ? m_out : fast_out;\n124: \n125: endmodule\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"// rtl/alu.sv\n//\n// RV32IM combinational ALU. Hardware multiplier and divider are SystemVerilog\n// `*` and `/` on signed/unsigned types — Verilator and Yosys both support\n// these and emit reasonable structural hardware.\n//\n// RV32IM division semantics (overridden from straight `signed /`):\n//   DIV  by 0       -> -1   (all ones)\n//   DIVU by 0       -> 0xFFFFFFFF\n//   DIV  INT_MIN/-1 -> INT_MIN  (no trap, defined overflow)\n//   REM  by 0       -> dividend\n//   REMU by 0       -> dividend\n//   REM  INT_MIN/-1 -> 0\n//\n// Latency:        combinational (0 cycles).\n// RVFI fields:    feeds rd_wdata (via EX/MEM/WB), branch resolution, mem_addr.\nmodule alu (\n  input  logic [4:0]  op,\n  input  logic [31:0] a,\n  input  logic [31:0] b,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/alu.sv","time":{"start":1778780552948,"end":1778780552963}},"id":"prt_e27953c24001aaFKEFrr1i8ilx","sessionID":"ses_1d86ae568ffeSeDaRHZ9bpqkcn","messageID":"msg_e27951b220018Mj5EVMshEeawV"}}
