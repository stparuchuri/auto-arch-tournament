{"type":"tool_use","timestamp":1778765261488,"sessionID":"ses_1d95e7f05ffeRkT02PXS0Iz0ll","part":{"type":"tool","tool":"read","callID":"functions.read:16","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/formal/wrapper_si.sv","limit":100},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/formal/wrapper_si.sv</path>\n<type>file</type>\n<content>\n1: // riscv-formal wrapper for single-issue (`nret 1`) cores. Same shape and\n2: // memory model as wrapper.sv, but instantiates `core` with only the\n3: // channel-0 RVFI port set — no `_1` ports. The single-issue path produces\n4: // only ch0 checks; checks_si.cfg sets `nret 1` so genchecks does not\n5: // emit any `_ch1` tasks (no PREUNSAT-as-pass tally needed). Selected by\n6: // the orchestrator when cores/<target>/core.yaml declares nret: 1.\n7: `include \"rvfi_macros.vh\"\n8: \n9: module rvfi_wrapper (\n10:     input clock,\n11:     input reset,\n12:     `RVFI_OUTPUTS\n13: );\n14:     // Solver picks any 32-bit instruction each cycle.\n15:     (* keep *) `rvformal_rand_reg [31:0] imem_data;\n16: \n17:     // 8 KiB dmem (2048 words).\n18:     reg [31:0] dmem [0:2047];\n19: \n20:     wire [31:0] imem_addr;\n21:     wire [31:0] dmem_addr;\n22:     wire [31:0] dmem_wdata;\n23:     wire [3:0]  dmem_wen;\n24:     wire        dmem_ren;\n25: \n26:     always @(posedge clock) begin\n27:         if (dmem_wen[0]) dmem[dmem_addr[12:2]][7:0]   <= dmem_wdata[7:0];\n28:         if (dmem_wen[1]) dmem[dmem_addr[12:2]][15:8]  <= dmem_wdata[15:8];\n29:         if (dmem_wen[2]) dmem[dmem_addr[12:2]][23:16] <= dmem_wdata[23:16];\n30:         if (dmem_wen[3]) dmem[dmem_addr[12:2]][31:24] <= dmem_wdata[31:24];\n31:     end\n32: \n33:     core uut (\n34:         .clock              (clock),\n35:         .reset              (reset),\n36:         .io_imemAddr        (imem_addr),\n37:         .io_imemData        (imem_data),\n38:         .io_imemReady       (1'b1),\n39:         .io_dmemAddr        (dmem_addr),\n40:         .io_dmemWData       (dmem_wdata),\n41:         .io_dmemRData       (dmem[dmem_addr[12:2]]),\n42:         .io_dmemWEn         (dmem_wen),\n43:         .io_dmemREn         (dmem_ren),\n44:         .io_dmemReady       (1'b1),\n45:         // Channel 0 — the only retirement channel. With nret=1 in\n46:         // checks_si.cfg, every rvfi_* signal here is sized for a single\n47:         // channel, so the core's `_0` ports connect directly without\n48:         // slicing. No `_1` ports exist on the core's IO under nret=1.\n49:         .io_rvfi_valid_0    (rvfi_valid),\n50:         .io_rvfi_order_0    (rvfi_order),\n51:         .io_rvfi_insn_0     (rvfi_insn),\n52:         .io_rvfi_trap_0     (rvfi_trap),\n53:         .io_rvfi_halt_0     (rvfi_halt),\n54:         .io_rvfi_intr_0     (rvfi_intr),\n55:         .io_rvfi_mode_0     (rvfi_mode),\n56:         .io_rvfi_ixl_0      (rvfi_ixl),\n57:         .io_rvfi_rs1_addr_0 (rvfi_rs1_addr),\n58:         .io_rvfi_rs1_rdata_0(rvfi_rs1_rdata),\n59:         .io_rvfi_rs2_addr_0 (rvfi_rs2_addr),\n60:         .io_rvfi_rs2_rdata_0(rvfi_rs2_rdata),\n61:         .io_rvfi_rd_addr_0  (rvfi_rd_addr),\n62:         .io_rvfi_rd_wdata_0 (rvfi_rd_wdata),\n63:         .io_rvfi_pc_rdata_0 (rvfi_pc_rdata),\n64:         .io_rvfi_pc_wdata_0 (rvfi_pc_wdata),\n65:         .io_rvfi_mem_addr_0 (rvfi_mem_addr),\n66:         .io_rvfi_mem_rmask_0(rvfi_mem_rmask),\n67:         .io_rvfi_mem_wmask_0(rvfi_mem_wmask),\n68:         .io_rvfi_mem_rdata_0(rvfi_mem_rdata),\n69:         .io_rvfi_mem_wdata_0(rvfi_mem_wdata)\n70:     );\n71: \n72: endmodule\n\n(End of file - total 72 lines)\n</content>","metadata":{"preview":"// riscv-formal wrapper for single-issue (`nret 1`) cores. Same shape and\n// memory model as wrapper.sv, but instantiates `core` with only the\n// channel-0 RVFI port set — no `_1` ports. The single-issue path produces\n// only ch0 checks; checks_si.cfg sets `nret 1` so genchecks does not\n// emit any `_ch1` tasks (no PREUNSAT-as-pass tally needed). Selected by\n// the orchestrator when cores/<target>/core.yaml declares nret: 1.\n`include \"rvfi_macros.vh\"\n\nmodule rvfi_wrapper (\n    input clock,\n    input reset,\n    `RVFI_OUTPUTS\n);\n    // Solver picks any 32-bit instruction each cycle.\n    (* keep *) `rvformal_rand_reg [31:0] imem_data;\n\n    // 8 KiB dmem (2048 words).\n    reg [31:0] dmem [0:2047];\n\n    wire [31:0] imem_addr;","truncated":false,"loaded":[]},"title":"formal/wrapper_si.sv","time":{"start":1778765261480,"end":1778765261488}},"id":"prt_e26abe78b001r0c5M0bgJhbztl","sessionID":"ses_1d95e7f05ffeRkT02PXS0Iz0ll","messageID":"msg_e26ab5d7e0014CegOjXz2JfCYE"}}
