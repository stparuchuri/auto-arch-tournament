{"type":"tool_use","timestamp":1778780614357,"sessionID":"ses_1d86ae568ffeSeDaRHZ9bpqkcn","part":{"type":"tool","tool":"read","callID":"functions.read:4","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/worktrees/hyp-20260514-002-r11s1/cores/bench/rtl/alu.sv"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/cores/bench/worktrees/hyp-20260514-002-r11s1/cores/bench/rtl/alu.sv</path>\n<type>file</type>\n<content>\n1: // rtl/alu.sv\n2: //\n3: // RV32IM combinational ALU. Hardware multiplier and divider are SystemVerilog\n4: // `*` and `/` on signed/unsigned types — Verilator and Yosys both support\n5: // these and emit reasonable structural hardware.\n6: //\n7: // RV32IM division semantics (overridden from straight `signed /`):\n8: //   DIV  by 0       -> -1   (all ones)\n9: //   DIVU by 0       -> 0xFFFFFFFF\n10: //   DIV  INT_MIN/-1 -> INT_MIN  (no trap, defined overflow)\n11: //   REM  by 0       -> dividend\n12: //   REMU by 0       -> dividend\n13: //   REM  INT_MIN/-1 -> 0\n14: //\n15: // Latency:        combinational (0 cycles).\n16: // RVFI fields:    feeds rd_wdata (via EX/MEM/WB), branch resolution, mem_addr.\n17: module alu (\n18:   input  logic [4:0]  op,\n19:   input  logic [31:0] a,\n20:   input  logic [31:0] b,\n21:   output logic [31:0] out\n22: );\n23: \n24:   logic        [4:0]  shamt;\n25:   logic        [31:0] fast_out;\n26:   logic        [31:0] m_out;\n27: \n28:   // Single 64-bit unsigned product; signed high-half results are recovered\n29:   // via cheap 32-bit correction subtractions.  Saves ~2 multipliers.\n30:   logic [63:0] mul_uu;\n31: \n32:   // Correction terms for signed*signed and signed*unsigned high halves.\n33:   // These are 32-bit values subtracted from mul_uu[63:32] to obtain the\n34:   // two's-complement high half.\n35:   logic [31:0] corr_a;  // a[31] ? b : 0\n36:   logic [31:0] corr_b;  // b[31] ? a : 0\n37: \n38:   always_comb begin\n39:     shamt = b[4:0];\n40: \n41:     // ── Fast path: base integer ops (small mux tree) ────────────────────\n42:     case (op)\n43:       ALU_ADD:  fast_out = a + b;\n44:       ALU_SUB:  fast_out = a - b;\n45:       ALU_AND:  fast_out = a & b;\n46:       ALU_OR:   fast_out = a | b;\n47:       ALU_XOR:  fast_out = a ^ b;\n48:       ALU_SLT:  fast_out = {31'b0, $signed(a) < $signed(b)};\n49:       ALU_SLTU: fast_out = {31'b0, a < b};\n50:       ALU_SLL:  fast_out = a << shamt;\n51:       ALU_SRL:  fast_out = a >> shamt;\n52:       ALU_SRA:  fast_out = $unsigned($signed(a) >>> shamt);\n53:       ALU_LUI:  fast_out = b;\n54:       default:  fast_out = 32'b0;\n55:     endcase\n56:   end\n57: \n58:   always_comb begin\n59:     // Guard multiplier off the critical path for non-M ops.\n60:     mul_uu = 64'b0;\n61:     corr_a = 32'b0;\n62:     corr_b = 32'b0;\n63:     if (op == ALU_MUL || op == ALU_MULH || op == ALU_MULHU || op == ALU_MULHSU) begin\n64:       mul_uu = {32'b0, a} * {32'b0, b};\n65:       corr_a = a[31] ? b : 32'b0;\n66:       corr_b = b[31] ? a : 32'b0;\n67:     end\n68: \n69:     // ── M-extension path (heavy combinational cloud) ────────────────────\n70:     // Under RISCV_FORMAL_ALTOPS the hardware operations are substituted for\n71:     // tractable algebraic stand-ins so bitwuzla can solve the BMC inside\n72:     // the 20-step depth budget. The same substitution must appear in the\n73:     // riscv-formal spec (insn_*.v). The Verilator/cocotb/cosim builds leave\n74:     // ALTOPS undefined and run the real arithmetic.\n75: `ifdef RISCV_FORMAL_ALTOPS\n76:     case (op)\n77:       ALU_MUL:    m_out = (a + b) ^ 32'h5876063e;\n78:       ALU_MULH:   m_out = (a + b) ^ 32'hf6583fb7;\n79:       ALU_MULHU:  m_out = (a + b) ^ 32'h949ce5e8;\n80:       ALU_MULHSU: m_out = (a - b) ^ 32'hecfbe137;\n81:       ALU_DIV:    m_out = (a - b) ^ 32'h7f8529ec;\n82:       ALU_DIVU:   m_out = (a - b) ^ 32'h10e8fd70;\n83:       ALU_REM:    m_out = (a - b) ^ 32'h8da68fa5;\n84:       ALU_REMU:   m_out = (a - b) ^ 32'h3138d0e1;\n85:       default:    m_out = 32'b0;\n86:     endcase\n87: `else\n88:     case (op)\n89:       ALU_MUL:    m_out = mul_uu[31:0];\n90:       ALU_MULH:   m_out = mul_uu[63:32] - corr_a - corr_b;\n91:       ALU_MULHU:  m_out = mul_uu[63:32];\n92:       ALU_MULHSU: m_out = mul_uu[63:32] - corr_a;\n93:       ALU_DIV: begin\n94:         if (b == 32'b0)\n95:           m_out = 32'hFFFFFFFF;\n96:         else if (a == 32'h80000000 && b == 32'hFFFFFFFF)\n97:           m_out = 32'h80000000;\n98:         else\n99:           m_out = $unsigned($signed(a) / $signed(b));\n100:       end\n101:       ALU_DIVU: m_out = (b == 32'b0) ? 32'hFFFFFFFF : (a / b);\n102:       ALU_REM: begin\n103:         if (b == 32'b0)\n104:           m_out = a;\n105:         else if (a == 32'h80000000 && b == 32'hFFFFFFFF)\n106:           m_out = 32'b0;\n107:         else\n108:           m_out = $unsigned($signed(a) % $signed(b));\n109:       end\n110:       ALU_REMU: m_out = (b == 32'b0) ? a : (a % b);\n111:       default:  m_out = 32'b0;\n112:     endcase\n113: `endif\n114:   end\n115: \n116:   // ── Final 2:1 mux ────────────────────────────────────────────────────\n117:   // The fast path (ADD/SUB/LOGIC/SHIFT/SLT/LUI) is selected by a single\n118:   // comparison instead of folding into a 19-entry case statement. This\n119:   // keeps the heavy multiplier/divider outputs off the fast-path mux\n120:   // tree, shortening the combinational path for the majority of ops.\n121:   assign out = (op >= ALU_MUL) ? m_out : fast_out;\n122: \n123: endmodule\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"// rtl/alu.sv\n//\n// RV32IM combinational ALU. Hardware multiplier and divider are SystemVerilog\n// `*` and `/` on signed/unsigned types — Verilator and Yosys both support\n// these and emit reasonable structural hardware.\n//\n// RV32IM division semantics (overridden from straight `signed /`):\n//   DIV  by 0       -> -1   (all ones)\n//   DIVU by 0       -> 0xFFFFFFFF\n//   DIV  INT_MIN/-1 -> INT_MIN  (no trap, defined overflow)\n//   REM  by 0       -> dividend\n//   REMU by 0       -> dividend\n//   REM  INT_MIN/-1 -> 0\n//\n// Latency:        combinational (0 cycles).\n// RVFI fields:    feeds rd_wdata (via EX/MEM/WB), branch resolution, mem_addr.\nmodule alu (\n  input  logic [4:0]  op,\n  input  logic [31:0] a,\n  input  logic [31:0] b,","truncated":false,"loaded":[]},"title":"cores/bench/rtl/alu.sv","time":{"start":1778780614346,"end":1778780614356}},"id":"prt_e27962bae001XlPlXY2WMH31RS","sessionID":"ses_1d86ae568ffeSeDaRHZ9bpqkcn","messageID":"msg_e27962496001OOlRZe167WgwVJ"}}
