{"type":"tool_use","timestamp":1778761183110,"sessionID":"ses_1d9986e98ffeo1wc7H48Yz9fNk","part":{"type":"tool","tool":"read","callID":"read:18","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/test/cosim/reference.py","limit":100},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/test/cosim/reference.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"RV32IM reference interpreter for the cosim. Mirrors the DUT's trap\n3: discipline so cosim traces stay aligned across illegal / misaligned\n4: encodings.\n5: \n6: Trap policy (matches rtl/decoder.sv default-illegal + rtl/ex_stage.sv +\n7: rtl/mem_stage.sv misalign traps):\n8: \n9:   - Reserved R-type:        funct7=0x20 with fn3 ∈ {1,2,3,4,6,7}\n10:   - Reserved OP-IMM shifts: SLLI/SRLI/SRAI with disallowed funct7\n11:   - Reserved LOAD funct3:   3, 6, 7\n12:   - Reserved STORE funct3:  3..7\n13:   - Reserved BRANCH funct3: 2, 3\n14:   - JALR funct3 != 0\n15:   - Non-EBREAK SYSTEM:      ECALL, CSR ops, MRET, …\n16:   - Unknown opcode (AMO etc.)\n17:   - Misaligned LH/LHU/LW/SH/SW\n18:   - Misaligned BRANCH (taken) / JAL / JALR target\n19: \n20: On trap the retirement is reported with rvfi_trap=1, rd_addr=0,\n21: rd_wdata=0, mem_*=0, npc=pc+4. The DUT's mem_stage / ex_stage match\n22: this on the same encodings.\n23: \n24: Modifications to this file require explicit user approval.\"\"\"\n25: import struct, sys\n26: from dataclasses import dataclass, field\n27: from typing import Optional\n28: \n29: XLEN = 32\n30: MASK = (1 << XLEN) - 1\n31: MEM_BYTES = 1 << 20  # 1 MiB\n32: \n33: # MMIO UART. Writes are consumed by the testbench. Reads are undefined\n34: # and are flagged as oob_access (sticky); main.cpp does the same.\n35: UART_BASE = 0x10000000\n36: UART_MASK = 0xFFF00000\n37: \n38: @dataclass\n39: class RV32IM:\n40:     mem: bytearray = field(default_factory=lambda: bytearray(MEM_BYTES))\n41:     regs: list = field(default_factory=lambda: [0] * 32)\n42:     pc: int = 0\n43:     retired: int = 0\n44:     oob_access: bool = False\n45:     uart_buf: bytearray = field(default_factory=bytearray)\n46: \n47:     def load_elf(self, path: str):\n48:         data = open(path, 'rb').read()\n49:         assert data[:4] == b'\\x7fELF'\n50:         e_phoff     = struct.unpack_from('<I', data, 28)[0]\n51:         e_phentsize = struct.unpack_from('<H', data, 42)[0]\n52:         e_phnum     = struct.unpack_from('<H', data, 44)[0]\n53:         self.pc     = struct.unpack_from('<I', data, 24)[0]\n54:         for i in range(e_phnum):\n55:             off      = e_phoff + i * e_phentsize\n56:             p_type   = struct.unpack_from('<I', data, off)[0]\n57:             p_offset = struct.unpack_from('<I', data, off+4)[0]\n58:             p_vaddr  = struct.unpack_from('<I', data, off+8)[0]\n59:             p_filesz = struct.unpack_from('<I', data, off+16)[0]\n60:             if p_type == 1:\n61:                 self.mem[p_vaddr:p_vaddr+p_filesz] = data[p_offset:p_offset+p_filesz]\n62: \n63:     def _in_uart(self, a): return (a & UART_MASK) == UART_BASE\n64:     def _in_mem (self, a): return a < MEM_BYTES\n65: \n66:     def rw(self, addr):\n67:         if self._in_uart(addr): self.oob_access = True; return 0\n68:         if not self._in_mem(addr): self.oob_access = True\n69:         return struct.unpack_from('<I', self.mem, addr & 0xFFFFFC)[0]\n70:     def rb(self, addr):\n71:         if self._in_uart(addr): self.oob_access = True; return 0\n72:         if not self._in_mem(addr): self.oob_access = True\n73:         return self.mem[addr & (MEM_BYTES - 1)]\n74:     def rhw(self, addr):\n75:         if self._in_uart(addr): self.oob_access = True; return 0\n76:         if not self._in_mem(addr): self.oob_access = True\n77:         return struct.unpack_from('<H', self.mem, addr & (MEM_BYTES - 2))[0]\n78:     def ww(self, addr, v):\n79:         if self._in_uart(addr):\n80:             self.uart_buf.extend(((v >> (i*8)) & 0xFF) for i in range(4))\n81:             return\n82:         if not self._in_mem(addr): self.oob_access = True\n83:         struct.pack_into('<I', self.mem, addr & 0xFFFFFC, v & MASK)\n84:     def wb(self, addr, v):\n85:         if self._in_uart(addr):\n86:             self.uart_buf.append(v & 0xFF); return\n87:         if not self._in_mem(addr): self.oob_access = True\n88:         self.mem[addr & (MEM_BYTES - 1)] = v & 0xFF\n89:     def whw(self, addr, v):\n90:         if self._in_uart(addr):\n91:             self.uart_buf.extend(((v >> (i*8)) & 0xFF) for i in range(2)); return\n92:         if not self._in_mem(addr): self.oob_access = True\n93:         struct.pack_into('<H', self.mem, addr & (MEM_BYTES - 2), v & 0xFFFF)\n94:     def sx(self, v, bits): return v - (1 << bits) if v >> (bits-1) else v\n95: \n96:     @staticmethod\n97:     def trunc_div(a, b):\n98:         \"\"\"RISC-V signed division: truncate toward zero (C semantics), not Python floor.\"\"\"\n99:         q = abs(a) // abs(b)\n100:         return -q if (a < 0) ^ (b < 0) else q\n\n(Showing lines 1-100 of 318. Use offset=101 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"RV32IM reference interpreter for the cosim. Mirrors the DUT's trap\ndiscipline so cosim traces stay aligned across illegal / misaligned\nencodings.\n\nTrap policy (matches rtl/decoder.sv default-illegal + rtl/ex_stage.sv +\nrtl/mem_stage.sv misalign traps):\n\n  - Reserved R-type:        funct7=0x20 with fn3 ∈ {1,2,3,4,6,7}\n  - Reserved OP-IMM shifts: SLLI/SRLI/SRAI with disallowed funct7\n  - Reserved LOAD funct3:   3, 6, 7\n  - Reserved STORE funct3:  3..7\n  - Reserved BRANCH funct3: 2, 3\n  - JALR funct3 != 0\n  - Non-EBREAK SYSTEM:      ECALL, CSR ops, MRET, …\n  - Unknown opcode (AMO etc.)\n  - Misaligned LH/LHU/LW/SH/SW\n  - Misaligned BRANCH (taken) / JAL / JALR target\n\nOn trap the retirement is reported with rvfi_trap=1, rd_addr=0,","truncated":true,"loaded":[]},"title":"test/cosim/reference.py","time":{"start":1778761183095,"end":1778761183109}},"id":"prt_e266dade7001kdhvvSQhmfJQRw","sessionID":"ses_1d9986e98ffeo1wc7H48Yz9fNk","messageID":"msg_e266d8aa7001ME5ZYAWGPWRW59"}}
