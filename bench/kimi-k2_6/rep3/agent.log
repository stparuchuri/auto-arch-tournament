{"type":"tool_use","timestamp":1778778621670,"sessionID":"ses_1d88e893cffe7s6mjGqyEyXcs7","part":{"type":"tool","tool":"read","callID":"read:24","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/tools/eval/fpga.py","limit":80},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/kimi-k2_6-rep3/tools/eval/fpga.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Runs 3 nextpnr seeds in parallel, returns median Fmax and CoreMark iter/sec.\"\"\"\n2: import asyncio, os, re, json, subprocess, statistics\n3: from pathlib import Path\n4: \n5: from tools.eval.formal import read_nret\n6: from tools.eval._subprocess import run_pgroup\n7: \n8: \n9: def _build_synth_env(worktree, target: str | None,\n10:                      base_env: dict | None = None) -> dict:\n11:     \"\"\"Build the env for `yosys -c fpga/scripts/synth.tcl`.\n12: \n13:     Reads cores/<target>/core.yaml's `nret` field (defaults to 2). When\n14:     nret=1, injects BENCH=fpga/core_bench_si.sv so synth.tcl reads the\n15:     single-issue FPGA wrapper (only `_0` RVFI ports) instead of the\n16:     default dual-channel core_bench.sv. nret=2 leaves BENCH unset and\n17:     synth.tcl falls back to fpga/core_bench.sv.\n18:     \"\"\"\n19:     worktree_path = Path(worktree).resolve()\n20:     env = dict(base_env) if base_env is not None else os.environ.copy()\n21:     if target is None:\n22:         return env\n23:     env[\"RTL_DIR\"] = f\"cores/{target}/rtl\"\n24:     env[\"GEN_DIR\"] = f\"cores/{target}/generated\"\n25:     nret = read_nret(worktree_path / \"cores\" / target / \"core.yaml\")\n26:     if nret == 1:\n27:         env[\"BENCH\"] = \"fpga/core_bench_si.sv\"\n28:     return env\n29: \n30: SEEDS = [1, 2, 3]\n31: NEXTPNR_SCRIPT = \"fpga/scripts/nextpnr_run.sh\"\n32: PORTME_H = \"bench/programs/coremark/baremetal/core_portme.h\"\n33: # Canonical 2K-config CoreMark CRCs (the EEMBC-published reporting size,\n34: # what VexRiscv et al. use). Bench Makefile defaults match: 2K data,\n35: # -O3, ITERATIONS=10. Verified against VexRiscv's pre-compiled\n36: # coremark_rv32im.bin — same seedcrc/crclist/crcmatrix/crcstate, same\n37: # crcfinal. Mismatch at any of these is a benchmark failure.\n38: COREMARK_EXPECTED = {\n39:     'seedcrc':   0xe9f5,\n40:     'crclist':   0xe714,\n41:     'crcmatrix': 0x1fd7,\n42:     'crcstate':  0x8e3a,\n43:     'crcfinal':  0xfcaf,\n44: }\n45: # CoreMark sim flags: random ~22% imem+dmem backpressure (matching\n46: # VexRiscv's iStall/dStall regression model — see\n47: # VexRiscv/src/test/cpp/regression/main.cpp:2079). Without these the\n48: # fitness number reflects a zero-wait fantasy bus that's impossible to\n49: # build, and an apples-to-apples comparison with public CoreMark numbers\n50: # becomes meaningless (cf. our V0 hitting \"2.87 CM/MHz\" zero-wait vs\n51: # \"2.21\" with stalls; the latter is the honest microarch number).\n52: COREMARK_SIM_FLAGS = [\"--bench\", \"--istall\", \"--dstall\"]\n53: # Min seed successes needed to call placement \"good\". V0 runs 3 nextpnr\n54: # seeds; if 2+ fail to place, the design is fragile/bloated/broken and\n55: # the median of a single survivor is not a real signal.\n56: MIN_SUCCESSFUL_SEEDS = 2\n57: \n58: def parse_iterations(worktree: str) -> int:\n59:     \"\"\"Read ITERATIONS from portme.h so we can't get out of sync with the ELF.\"\"\"\n60:     path = Path(worktree).resolve() / PORTME_H\n61:     if not path.exists():\n62:         raise RuntimeError(f\"{path} not found — can't determine CoreMark ITERATIONS\")\n63:     m = re.search(r'^\\s*#\\s*define\\s+ITERATIONS\\s+(\\d+)', path.read_text(), re.MULTILINE)\n64:     if not m:\n65:         raise RuntimeError(f\"ITERATIONS not found in {path}\")\n66:     return int(m.group(1))\n67: \n68: async def run_seed(seed: int, worktree: str, outdir: str, env: dict | None = None) -> dict:\n69:     # cwd=worktree: nextpnr_run.sh reads generated/synth.json and fpga/constraints/*\n70:     # as worktree-relative paths. Without cwd, it would read from the caller's cwd\n71:     # (e.g., repo root) and we'd score the wrong design.\n72:     proc = await asyncio.create_subprocess_exec(\n73:         \"bash\", NEXTPNR_SCRIPT, str(seed), outdir,\n74:         stdout=asyncio.subprocess.PIPE,\n75:         stderr=asyncio.subprocess.PIPE,\n76:         cwd=Path(worktree).resolve(),\n77:         env=env,\n78:     )\n79:     stdout, stderr = await proc.communicate()\n80:     output = (stdout + stderr).decode()\n\n(Showing lines 1-80 of 296. Use offset=81 to continue.)\n</content>","metadata":{"preview":"\"\"\"Runs 3 nextpnr seeds in parallel, returns median Fmax and CoreMark iter/sec.\"\"\"\nimport asyncio, os, re, json, subprocess, statistics\nfrom pathlib import Path\n\nfrom tools.eval.formal import read_nret\nfrom tools.eval._subprocess import run_pgroup\n\n\ndef _build_synth_env(worktree, target: str | None,\n                     base_env: dict | None = None) -> dict:\n    \"\"\"Build the env for `yosys -c fpga/scripts/synth.tcl`.\n\n    Reads cores/<target>/core.yaml's `nret` field (defaults to 2). When\n    nret=1, injects BENCH=fpga/core_bench_si.sv so synth.tcl reads the\n    single-issue FPGA wrapper (only `_0` RVFI ports) instead of the\n    default dual-channel core_bench.sv. nret=2 leaves BENCH unset and\n    synth.tcl falls back to fpga/core_bench.sv.\n    \"\"\"\n    worktree_path = Path(worktree).resolve()\n    env = dict(base_env) if base_env is not None else os.environ.copy()","truncated":true,"loaded":[]},"title":"tools/eval/fpga.py","time":{"start":1778778621652,"end":1778778621669}},"id":"prt_e2777c404001y8P9G5hbZ1gBwF","sessionID":"ses_1d88e893cffe7s6mjGqyEyXcs7","messageID":"msg_e2777a53900114mF17hDF6q7M9"}}
