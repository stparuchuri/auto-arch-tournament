ning misalignment trap handling and fallback resolution.\"\n+  - file: rtl/core_pkg.sv\n+    description: \"Add minimal ID/EX metadata fields for whether a control transfer was resolved early and what next PC should be reported to RVFI.\"\n+  - file: rtl/hazard_unit.sv\n+    description: \"Prioritize the early redirect flush and preserve stall behavior for unsafe branch operand dependencies.\"\n","additions":33,"deletions":0}],"diagnostics":{},"truncated":false},"title":"Success. Updated the following files:\nA cores/bench/experiments/hypotheses/hyp-20260513-002-r1s1.yaml","time":{"start":1778657285083,"end":1778657285088}},"metadata":{"openai":{"itemId":"fc_0816bbdbe5788b03016a0427e716948198b8afce1c8216a3c6"}},"id":"prt_e203bdf0f001dhfED73YxofxXD","sessionID":"ses_1dfc49df4ffeEuRqDg4eIwxR0r","messageID":"msg_e203bcab3001TTy94onPXNKPS3"}}
