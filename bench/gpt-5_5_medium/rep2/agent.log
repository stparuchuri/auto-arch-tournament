n.\"}, {\"file\": \"rtl/if_stage.sv\", \"description\": \"Implement static BTFNT next-PC selection for backward conditional branches and early PC-relative JAL prediction from fetched instruction bits.\"}, {\"file\": \"rtl/id_stage.sv\", \"description\": \"Lat... (line truncated to 2000 chars)","truncated":false,"loaded":[]},"title":"cores/bench/experiments/log.jsonl","time":{"start":1778678952488,"end":1778678952492}},"metadata":{"openai":{"itemId":"fc_02e113830471e87b016a047ca79d00819abf805bab726ba524"}},"id":"prt_e2186f1be001rLvivU1Mr8urf4","sessionID":"ses_1de7940d2ffeyK0MHkwxKUwbJa","messageID":"msg_e2186bf87001PGp6OML6qbRmdO"}}
