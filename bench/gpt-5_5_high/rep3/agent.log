igible CoreMark CPI cost because\n  rare DIV/REM instructions pay the added latency only when they occur.\nexpected_impact:\n  fitness_delta_pct: 8","truncated":false,"loaded":[]},"title":"cores/bench/experiments/hypotheses/hyp-20260512-002-r1s1.yaml","time":{"start":1778636755665,"end":1778636755671}},"metadata":{"openai":{"itemId":"fc_0d94cc69280fa503016a03d7d386f48199bd3fe979353a0cd8"}},"id":"prt_e1f0312cc001HKO5O8rV6OsV86","sessionID":"ses_1e0fdffa1fferQ02u5XDIVUhUP","messageID":"msg_e1f02f80a002GQxltVHb4kQnin"}}
