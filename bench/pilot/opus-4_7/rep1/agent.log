{"type":"tool_use","timestamp":1777762635659,"sessionID":"ses_215173982ffecHKL5CIJz8yL90","part":{"type":"tool","tool":"read","callID":"toolu_bdrk_01M7ofV3RSG1hGDCV74y9SGu","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/opus-4_7-rep1/cores/bench/worktrees/hyp-20260502-002-r3s1/cores/bench/test/test_pipeline.py"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/opus-4_7-rep1/cores/bench/worktrees/hyp-20260502-002-r3s1/cores/bench/test/test_pipeline.py</path>\n<type>file</type>\n<content>\n1: \"\"\"End-to-end pipeline tests for rtl/core.sv.\n2: \n3: Drives a minimal Python-side imem/dmem against the core's combinational\n4: fetch/load model and captures RVFI retirements. Covers the §8 phase-2\n5: acceptance set: forwarding (EX->EX, MEM->EX), branches, JAL, JALR,\n6: SW+LW roundtrip, load-use stall, and the trap discipline (illegal /\n7: ECALL trap, EBREAK does NOT trap).\n8: \"\"\"\n9: from __future__ import annotations\n10: \n11: import cocotb\n12: from cocotb.clock import Clock\n13: from cocotb.triggers import RisingEdge, Timer\n14: \n15: from _helpers import run_cocotb\n16: \n17: \n18: # ── RV32I instruction encoder helpers ──────────────────────────────────────\n19: def _r(funct7, rs2, rs1, funct3, rd, opcode):\n20:     return ((funct7 & 0x7F) << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) \\\n21:          | ((funct3 & 0x7) << 12) | ((rd & 0x1F) << 7) | (opcode & 0x7F)\n22: \n23: \n24: def _i(imm, rs1, funct3, rd, opcode):\n25:     return ((imm & 0xFFF) << 20) | ((rs1 & 0x1F) << 15) | ((funct3 & 0x7) << 12) \\\n26:          | ((rd & 0x1F) << 7) | (opcode & 0x7F)\n27: \n28: \n29: def _s(imm, rs2, rs1, funct3, opcode):\n30:     imm_hi = (imm >> 5) & 0x7F\n31:     imm_lo = imm & 0x1F\n32:     return (imm_hi << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) \\\n33:          | ((funct3 & 0x7) << 12) | (imm_lo << 7) | (opcode & 0x7F)\n34: \n35: \n36: def _b(imm, rs2, rs1, funct3, opcode):\n37:     # imm is a 13-bit signed number; bit 0 is implicitly zero.\n38:     b12  = (imm >> 12) & 1\n39:     b105 = (imm >> 5)  & 0x3F\n40:     b41  = (imm >> 1)  & 0xF\n41:     b11  = (imm >> 11) & 1\n42:     return (b12 << 31) | (b105 << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) \\\n43:          | ((funct3 & 0x7) << 12) | (b41 << 8) | (b11 << 7) | (opcode & 0x7F)\n44: \n45: \n46: def _j(imm, rd, opcode):\n47:     # 21-bit signed imm; bit 0 implicit zero.\n48:     b20    = (imm >> 20) & 1\n49:     b101   = (imm >> 1)  & 0x3FF\n50:     b11    = (imm >> 11) & 1\n51:     b1912  = (imm >> 12) & 0xFF\n52:     return (b20 << 31) | (b101 << 21) | (b11 << 20) | (b1912 << 12) \\\n53:          | ((rd & 0x1F) << 7) | (opcode & 0x7F)\n54: \n55: \n56: def ADDI(rd, rs1, imm): return _i(imm & 0xFFF, rs1, 0b000, rd, 0b0010011)\n57: def ADD (rd, rs1, rs2): return _r(0, rs2, rs1, 0b000, rd, 0b0110011)\n58: def DIV (rd, rs1, rs2): return _r(0b0000001, rs2, rs1, 0b100, rd, 0b0110011)\n59: def DIVU(rd, rs1, rs2): return _r(0b0000001, rs2, rs1, 0b101, rd, 0b0110011)\n60: def REM (rd, rs1, rs2): return _r(0b0000001, rs2, rs1, 0b110, rd, 0b0110011)\n61: def LW  (rd, rs1, imm): return _i(imm & 0xFFF, rs1, 0b010, rd, 0b0000011)\n62: def SW  (rs2, rs1, imm): return _s(imm & 0xFFF, rs2, rs1, 0b010, 0b0100011)\n63: def BEQ (rs1, rs2, imm): return _b(imm, rs2, rs1, 0b000, 0b1100011)\n64: def JAL (rd, imm):       return _j(imm, rd, 0b1101111)\n65: def JALR(rd, rs1, imm):  return _i(imm & 0xFFF, rs1, 0b000, rd, 0b1100111)\n66: def NOP():               return ADDI(0, 0, 0)        # = 0x00000013\n67: def EBREAK():            return 0x00100073\n68: def ECALL():             return 0x00000073\n69: \n70: \n71: # ── Harness ────────────────────────────────────────────────────────────────\n72: async def _run(dut, program, dmem_init=None, max_cycles=200):\n73:     \"\"\"Drive imem/dmem; capture RVFI retirements until EBREAK or max_cycles.\n74: \n75:     imem is read combinationally each cycle from imemAddr; dmem similarly.\n76:     Stores get applied to the Python-side dmem dict so subsequent loads\n77:     see the new value.\n78: \n79:     Returns (retirements, dmem) where retirements is a list of dicts\n80:     sampled on every cycle that rvfi_valid=1.\n81:     \"\"\"\n82:     imem = {i * 4: instr & 0xFFFFFFFF for i, instr in enumerate(program)}\n83:     dmem = dict(dmem_init or {})\n84:     retirements: list[dict] = []\n85: \n86:     cocotb.start_soon(Clock(dut.clock, 10, \"ns\").start())\n87: \n88:     dut.reset.value = 1\n89:     dut.io_imemData.value = 0\n90:     dut.io_dmemRData.value = 0\n91:     # Zero-wait bus model: ready always asserted. The stall-mode tests\n92:     # live in vex_main.cpp's --istall/--dstall flags, not in cocotb.\n93:     dut.io_imemReady.value = 1\n94:     dut.io_dmemReady.value = 1\n95:     for _ in range(3):\n96:         await RisingEdge(dut.clock)\n97: \n98:     # Deassert reset and prime the imem read for the first PC=0 fetch.\n99:     dut.reset.value = 0\n100:     dut.io_imemData.value = imem.get(0, EBREAK())\n101: \n102:     for cycle in range(max_cycles):\n103:         await RisingEdge(dut.clock)\n104:         await Timer(1, \"ns\")  # let combinational signals settle\n105: \n106:         # Sample the post-edge state.\n107:         ia        = int(dut.io_imemAddr.value)\n108:         da        = int(dut.io_dmemAddr.value)\n109:         wen       = int(dut.io_dmemWEn.value)\n110:         rvfi_v    = int(dut.io_rvfi_valid_0.value)\n111: \n112:         # Apply dmem write side effects.\n113:         if wen:\n114:             wdata = int(dut.io_dmemWData.value)\n115:             wa = da & ~3\n116:             old = dmem.get(wa, 0)\n117:             new = old\n118:             for i in range(4):\n119:                 if (wen >> i) & 1:\n120:                     bv = (wdata >> (i * 8)) & 0xFF\n121:                     new = (new & ~(0xFF << (i * 8))) | (bv << (i * 8))\n122:             dmem[wa] = new\n123: \n124:         # Capture RVFI retirement.\n125:         if rvfi_v:\n126:             r = {\n127:                 \"order\":     int(dut.io_rvfi_order_0.value),\n128:                 \"insn\":      int(dut.io_rvfi_insn_0.value),\n129:                 \"pc\":        int(dut.io_rvfi_pc_rdata_0.value),\n130:                 \"pc_next\":   int(dut.io_rvfi_pc_wdata_0.value),\n131:                 \"rd\":        int(dut.io_rvfi_rd_addr_0.value),\n132:                 \"rd_wdata\":  int(dut.io_rvfi_rd_wdata_0.value),\n133:                 \"rs1_addr\":  int(dut.io_rvfi_rs1_addr_0.value),\n134:                 \"rs1_rdata\": int(dut.io_rvfi_rs1_rdata_0.value),\n135:                 \"rs2_addr\":  int(dut.io_rvfi_rs2_addr_0.value),\n136:                 \"rs2_rdata\": int(dut.io_rvfi_rs2_rdata_0.value),\n137:                 \"trap\":      int(dut.io_rvfi_trap_0.value),\n138:                 \"mem_addr\":  int(dut.io_rvfi_mem_addr_0.value),\n139:                 \"mem_wmask\": int(dut.io_rvfi_mem_wmask_0.value),\n140:                 \"mem_wdata\": int(dut.io_rvfi_mem_wdata_0.value),\n141:                 \"mem_rmask\": int(dut.io_rvfi_mem_rmask_0.value),\n142:                 \"mem_rdata\": int(dut.io_rvfi_mem_rdata_0.value),\n143:                 \"cycle\":     cycle,\n144:             }\n145:             retirements.append(r)\n146:             if r[\"insn\"] == EBREAK():\n147:                 break\n148: \n149:         # Drive next cycle's imem fetch and dmem read combinationally.\n150:         dut.io_imemData.value  = imem.get(ia & ~3, EBREAK())\n151:         dut.io_dmemRData.value = dmem.get(da & ~3, 0)\n152:     else:\n153:         raise AssertionError(f\"max_cycles={max_cycles} reached without EBREAK\")\n154: \n155:     return retirements, dmem\n156: \n157: \n158: def _by_insn(retirements, insn):\n159:     \"\"\"Return all retirements matching a specific instruction word.\"\"\"\n160:     return [r for r in retirements if r[\"insn\"] == insn]\n161: \n162: \n163: # ── Tests ──────────────────────────────────────────────────────────────────\n164: @cocotb.test()\n165: async def forwarding_ex_to_ex(dut):\n166:     \"\"\"ADDI x1, x0, 5; ADDI x2, x1, 3 — back-to-back rs1 forward from EX/MEM.\"\"\"\n167:     program = [ADDI(1, 0, 5), ADDI(2, 1, 3), EBREAK()]\n168:     rets, _ = await _run(dut, program)\n169:     [r1] = _by_insn(rets, ADDI(1, 0, 5))\n170:     [r2] = _by_insn(rets, ADDI(2, 1, 3))\n171:     assert r1[\"rd\"] == 1 and r1[\"rd_wdata\"] == 5\n172:     assert r2[\"rd\"] == 2 and r2[\"rd_wdata\"] == 8, (\n173:         f\"x2 should be x1+3=8 via EX->EX forward, got 0x{r2['rd_wdata']:08x}\"\n174:     )\n175:     # Order must be strict +1.\n176:     orders = [r[\"order\"] for r in rets]\n177:     assert orders == list(range(orders[0], orders[0] + len(rets)))\n178: \n179: \n180: @cocotb.test()\n181: async def forwarding_mem_to_ex(dut):\n182:     \"\"\"ADDI x1, x0, 5; NOP; ADDI x2, x1, 3 — rs1 forward from MEM/WB stage.\"\"\"\n183:     program = [ADDI(1, 0, 5), NOP(), ADDI(2, 1, 3), EBREAK()]\n184:     rets, _ = await _run(dut, program)\n185:     [r2] = _by_insn(rets, ADDI(2, 1, 3))\n186:     assert r2[\"rd_wdata\"] == 8\n187: \n188: \n189: @cocotb.test()\n190: async def load_use_stalls(dut):\n191:     \"\"\"SW x3 to mem; LW x1, 0(x0); ADD x2, x1, x4 — load-use must stall once.\n192: \n193:     All immediates kept inside the signed 12-bit positive range so ADDI's\n194:     sign-extension doesn't muddy the expected values.\n195:     \"\"\"\n196:     program = [\n197:         ADDI(3, 0, 0x123),     # x3 = 0x123\n198:         ADDI(4, 0, 0x100),     # x4 = 0x100\n199:         SW  (3, 0, 0),         # mem[0] = x3\n200:         LW  (1, 0, 0),         # x1 = mem[0]; uses x1 next cycle -> stall\n201:         ADD (2, 1, 4),         # x2 = x1 + x4 = 0x223\n202:         EBREAK(),\n203:     ]\n204:     rets, dmem = await _run(dut, program)\n205:     [r2] = _by_insn(rets, ADD(2, 1, 4))\n206:     assert r2[\"rd_wdata\"] == 0x223, f\"x2 expected 0x223, got 0x{r2['rd_wdata']:08x}\"\n207:     assert dmem[0] == 0x123, f\"mem[0] should hold 0x123, got {dmem[0]:#x}\"\n208: \n209: \n210: @cocotb.test()\n211: async def branch_taken_skips(dut):\n212:     \"\"\"BEQ x0, x0, +8 — the wrong-path instruction must NOT retire at all,\n213:     not merely retire with rd_wdata != 99. Asserting only the side effect\n214:     would let a wrong-path retirement with rd=0 / trap=1 / different data\n215:     pass silently.\"\"\"\n216:     program = [\n217:         BEQ(0, 0, 8),          # PC=0;  taken; skip the next instr\n218:         ADDI(1, 0, 99),        # PC=4;  SHOULD NEVER retire\n219:         ADDI(2, 0, 42),        # PC=8;  branch target\n220:         EBREAK(),\n221:     ]\n222:     rets, _ = await _run(dut, program)\n223:     # Strict: no retirement should originate from PC=4.\n224:     leaked = [r for r in rets if r[\"pc\"] == 4]\n225:     assert not leaked, f\"wrong-path retirement leaked from PC=4: {leaked}\"\n226:     # Strict: no retirement carries the skipped instruction word at all.\n227:     leaked_insn = [r for r in rets if r[\"insn\"] == ADDI(1, 0, 99)]\n228:     assert not leaked_insn, f\"skipped instr ADDI x1,99 retired: {leaked_insn}\"\n229:     # Sanity: the target instruction and the EBREAK do retire, in order.\n230:     pcs = [r[\"pc\"] for r in rets]\n231:     assert pcs == [0, 8, 12], f\"unexpected retirement PC sequence: {pcs}\"\n232:     [r2] = _by_insn(rets, ADDI(2, 0, 42))\n233:     assert r2[\"rd_wdata\"] == 42\n234: \n235: \n236: @cocotb.test()\n237: async def jal_writes_pc_plus_4(dut):\n238:     \"\"\"JAL x1, +8; verify the wrong-path slot does not retire and x1=PC+4.\"\"\"\n239:     program = [\n240:         JAL(1, 8),             # PC=0; x1 := 4; jump to PC=8\n241:         ADDI(2, 0, 99),        # PC=4 — wrong-path; must not retire\n242:         ADDI(3, 0, 42),        # PC=8 — target\n243:         EBREAK(),\n244:     ]\n245:     rets, _ = await _run(dut, program)\n246:     pcs = [r[\"pc\"] for r in rets]\n247:     assert pcs == [0, 8, 12], f\"unexpected retirement PC sequence: {pcs}\"\n248:     [rj] = _by_insn(rets, JAL(1, 8))\n249:     assert rj[\"rd\"] == 1\n250:     assert rj[\"rd_wdata\"] == rj[\"pc\"] + 4\n251:     [r3] = _by_insn(rets, ADDI(3, 0, 42))\n252:     assert r3[\"rd_wdata\"] == 42\n253: \n254: \n255: @cocotb.test()\n256: async def jalr_target(dut):\n257:     \"\"\"ADDI x5,x0,12; JALR x1,x5,0; verify wrong-path slot doesn't retire.\"\"\"\n258:     program = [\n259:         ADDI(5, 0, 12),        # PC=0;  x5 := 12\n260:         JALR(1, 5, 0),         # PC=4;  jump to x5+0 = 12\n261:         ADDI(6, 0, 99),        # PC=8;  wrong-path\n262:         ADDI(7, 0, 42),        # PC=12; target\n263:         EBREAK(),\n264:     ]\n265:     rets, _ = await _run(dut, program)\n266:     pcs = [r[\"pc\"] for r in rets]\n267:     assert pcs == [0, 4, 12, 16], f\"unexpected retirement PC sequence: {pcs}\"\n268:     [r7] = _by_insn(rets, ADDI(7, 0, 42))\n269:     assert r7[\"rd_wdata\"] == 42\n270: \n271: \n272: @cocotb.test()\n273: async def sw_lw_roundtrip(dut):\n274:     \"\"\"ADDI x1, 0xCAFE; SW x1; LW x2 — verify x2 sees the freshly stored word.\"\"\"\n275:     val = 0x123  # signed 12-bit fits\n276:     program = [\n277:         ADDI(1, 0, val),\n278:         SW  (1, 0, 0),\n279:         LW  (2, 0, 0),\n280:         EBREAK(),\n281:     ]\n282:     rets, dmem = await _run(dut, program)\n283:     [r2] = _by_insn(rets, LW(2, 0, 0))\n284:     assert r2[\"rd_wdata\"] == val, f\"x2 expected {val:#x}, got 0x{r2['rd_wdata']:x}\"\n285:     assert dmem.get(0) == val\n286: \n287: \n288: @cocotb.test()\n289: async def illegal_traps(dut):\n290:     \"\"\"0xFFFFFFFF retires with rvfi_trap=1 and no rd write.\n291: \n292:     Project convention: when reg_write=0 (which the decoder forces on\n293:     illegal), rvfi_rd_addr and rvfi_rd_wdata are both reported as 0.\n294:     This is one valid RVFI interpretation (the spec says \"for\n295:     instructions that do not write rd, the value is 0\"). Some other\n296:     cores report rd_addr = instr[11:7] regardless of trap and let the\n297:     verifier ignore it on trap=1; both are accepted by riscv-formal.\n298:     Our reference.py and DUT both follow the zeroed-on-trap convention,\n299:     so cosim stays in lockstep.\"\"\"\n300:     program = [\n301:         0xFFFFFFFF,\n302:         EBREAK(),\n303:     ]\n304:     rets, _ = await _run(dut, program)\n305:     bad = next(r for r in rets if r[\"insn\"] == 0xFFFFFFFF)\n306:     assert bad[\"trap\"] == 1\n307:     assert bad[\"rd\"] == 0\n308:     assert bad[\"rd_wdata\"] == 0\n309: \n310: \n311: @cocotb.test()\n312: async def ecall_traps(dut):\n313:     \"\"\"ECALL retires with rvfi_trap=1 (project-specific: only EBREAK is legal).\"\"\"\n314:     program = [\n315:         ECALL(),\n316:         EBREAK(),\n317:     ]\n318:     rets, _ = await _run(dut, program)\n319:     [re] = _by_insn(rets, ECALL())\n320:     assert re[\"trap\"] == 1\n321: \n322: \n323: @cocotb.test()\n324: async def ebreak_does_not_trap(dut):\n325:     \"\"\"EBREAK retires with rvfi_trap=0 — this is the project-specific halt marker.\"\"\"\n326:     program = [EBREAK()]\n327:     rets, _ = await _run(dut, program, max_cycles=20)\n328:     [re] = _by_insn(rets, EBREAK())\n329:     assert re[\"trap\"] == 0, f\"EBREAK should not trap; got trap={re['trap']}\"\n330: \n331: \n332: @cocotb.test()\n333: async def rvfi_order_strictly_monotonic(dut):\n334:     \"\"\"A short stream must produce rvfi_order = 0,1,2,... with no gaps.\"\"\"\n335:     program = [\n336:         ADDI(1, 0, 1),\n337:         ADDI(2, 0, 2),\n338:         ADDI(3, 0, 3),\n339:         ADDI(4, 0, 4),\n340:         EBREAK(),\n341:     ]\n342:     rets, _ = await _run(dut, program)\n343:     orders = [r[\"order\"] for r in rets]\n344:     assert orders == list(range(len(orders))), f\"order not monotonic +1: {orders}\"\n345: \n346: \n347: @cocotb.test()\n348: async def div_stalls_pipeline_then_retires(dut):\n349:     \"\"\"A DIV followed by a dependent ADD: the DIV must stall EX for ~32\n350:     cycles while the iterative divider runs, then retire with the\n351:     correct result; the dependent ADD must see the DIV's rd via\n352:     forwarding. RVFI order remains strictly monotonic across the stall.\n353:     Exercises the div_unit handshake end-to-end through the pipeline.\n354:     \"\"\"\n355:     program = [\n356:         ADDI(1, 0, 100),          # x1 = 100\n357:         ADDI(2, 0, 7),            # x2 = 7\n358:         DIV (3, 1, 2),            # x3 = 100 / 7 = 14 (signed)\n359:         ADD (4, 3, 1),            # x4 = x3 + x1 = 114\n360:         EBREAK(),\n361:     ]\n362:     rets, _ = await _run(dut, program, max_cycles=200)\n363:     [rdiv] = _by_insn(rets, DIV(3, 1, 2))\n364:     assert rdiv[\"rd\"] == 3\n365:     assert rdiv[\"rd_wdata\"] == 14, f\"DIV result expected 14, got 0x{rdiv['rd_wdata']:x}\"\n366:     assert rdiv[\"trap\"] == 0, \"legal DIV must not trap\"\n367:     [radd] = _by_insn(rets, ADD(4, 3, 1))\n368:     assert radd[\"rd_wdata\"] == 114, f\"dependent ADD expected 114, got 0x{radd['rd_wdata']:x}\"\n369:     orders = [r[\"order\"] for r in rets]\n370:     assert orders == list(range(len(orders))), f\"order not monotonic +1: {orders}\"\n371: \n372: \n373: @cocotb.test()\n374: async def div_by_zero_fast_path(dut):\n375:     \"\"\"Divide-by-zero retires quickly with RV32M-defined result (-1).\"\"\"\n376:     program = [\n377:         ADDI(1, 0, 42),\n378:         ADDI(2, 0, 0),\n379:         DIV (3, 1, 2),            # fast path: 42 / 0 = 0xFFFFFFFF\n380:         EBREAK(),\n381:     ]\n382:     rets, _ = await _run(dut, program, max_cycles=100)\n383:     [rdiv] = _by_insn(rets, DIV(3, 1, 2))\n384:     assert rdiv[\"rd_wdata\"] == 0xFFFFFFFF, (\n385:         f\"DIV-by-0 expected 0xFFFFFFFF, got 0x{rdiv['rd_wdata']:08x}\"\n386:     )\n387:     assert rdiv[\"trap\"] == 0\n388: \n389: \n390: @cocotb.test()\n391: async def divu_and_rem(dut):\n392:     \"\"\"DIVU and REM in sequence validate the sign-fixup paths end-to-end.\"\"\"\n393:     program = [\n394:         ADDI(1, 0, 0x7FF),         # x1 = 2047\n395:         ADDI(2, 0, 0x00A),         # x2 = 10\n396:         DIVU(3, 1, 2),             # x3 = 2047 / 10 = 204\n397:         REM (4, 1, 2),             # x4 = 2047 % 10 = 7\n398:         EBREAK(),\n399:     ]\n400:     rets, _ = await _run(dut, program, max_cycles=200)\n401:     [rdivu] = _by_insn(rets, DIVU(3, 1, 2))\n402:     [rrem ] = _by_insn(rets, REM (4, 1, 2))\n403:     assert rdivu[\"rd_wdata\"] == 204, f\"DIVU got 0x{rdivu['rd_wdata']:x}\"\n404:     assert rrem [\"rd_wdata\"] == 7,   f\"REM got 0x{rrem['rd_wdata']:x}\"\n405:     orders = [r[\"order\"] for r in rets]\n406:     assert orders == list(range(len(orders)))\n407: \n408: \n409: def test_pipeline_runner():\n410:     run_cocotb(\n411:         toplevel=\"core\",\n412:         sources=[\n413:             \"core_pkg.sv\",\n414:             \"alu.sv\", \"div_unit.sv\", \"decoder.sv\", \"imm_gen.sv\", \"reg_file.sv\",\n415:             \"fetch_buffer.sv\",\n416:             \"if_stage.sv\", \"id_stage.sv\", \"ex_stage.sv\",\n417:             \"mem_stage.sv\", \"wb_stage.sv\",\n418:             \"hazard_unit.sv\", \"forward_unit.sv\",\n419:             \"core.sv\",\n420:         ],\n421:         test_module=\"test_pipeline\",\n422:     )\n\n(End of file - total 422 lines)\n</content>","metadata":{"preview":"\"\"\"End-to-end pipeline tests for rtl/core.sv.\n\nDrives a minimal Python-side imem/dmem against the core's combinational\nfetch/load model and captures RVFI retirements. Covers the §8 phase-2\nacceptance set: forwarding (EX->EX, MEM->EX), branches, JAL, JALR,\nSW+LW roundtrip, load-use stall, and the trap discipline (illegal /\nECALL trap, EBREAK does NOT trap).\n\"\"\"\nfrom __future__ import annotations\n\nimport cocotb\nfrom cocotb.clock import Clock\nfrom cocotb.triggers import RisingEdge, Timer\n\nfrom _helpers import run_cocotb\n\n\n# ── RV32I instruction encoder helpers ──────────────────────────────────────\ndef _r(funct7, rs2, rs1, funct3, rd, opcode):\n    return ((funct7 & 0x7F) << 25) | ((rs2 & 0x1F) << 20) | ((rs1 & 0x1F) << 15) \\","truncated":false,"loaded":[]},"title":"cores/bench/test/test_pipeline.py","time":{"start":1777762635654,"end":1777762635658}},"metadata":{"openrouter":{"reasoning_details":[]}},"id":"prt_deae90546001UkH9ecdSX7sMXE","sessionID":"ses_215173982ffecHKL5CIJz8yL90","messageID":"msg_deae8ff15001nQUbuNhnbxDW3e"}}
