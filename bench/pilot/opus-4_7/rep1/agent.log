{"type":"tool_use","timestamp":1777762753279,"sessionID":"ses_215154959ffe4lYe6Fozu7Hu6G","part":{"type":"tool","tool":"read","callID":"toolu_bdrk_0196JnY5N7r2SUHQkk8yW8xc","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/opus-4_7-rep1/cores/bench/worktrees/hyp-20260502-003-r3s2/cores/bench/test/_helpers.py"},"output":"<path>/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs/opus-4_7-rep1/cores/bench/worktrees/hyp-20260502-003-r3s2/cores/bench/test/_helpers.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Shared cocotb constants and runner helpers for unit tests.\n2: \n3: Constants mirror rtl/core_pkg.sv. If a localparam there changes, change\n4: the matching value here.\n5: \"\"\"\n6: from __future__ import annotations\n7: \n8: import os\n9: from pathlib import Path\n10: \n11: # cocotb 2.x moved the runner from cocotb.runner to cocotb_tools.runner.\n12: from cocotb_tools.runner import get_runner\n13: \n14: # ── ALU encodings (rtl/core_pkg.sv) ────────────────────────────────────────\n15: ALU_ADD    = 0\n16: ALU_SUB    = 1\n17: ALU_AND    = 2\n18: ALU_OR     = 3\n19: ALU_XOR    = 4\n20: ALU_SLT    = 5\n21: ALU_SLTU   = 6\n22: ALU_SLL    = 7\n23: ALU_SRL    = 8\n24: ALU_SRA    = 9\n25: ALU_LUI    = 10\n26: ALU_MUL    = 11\n27: ALU_MULH   = 12\n28: ALU_MULHU  = 13\n29: ALU_MULHSU = 14\n30: ALU_DIV    = 15\n31: ALU_DIVU   = 16\n32: ALU_REM    = 17\n33: ALU_REMU   = 18\n34: \n35: # ── BranchOp encodings (= funct3 of BRANCH opcode) ─────────────────────────\n36: BR_BEQ  = 0\n37: BR_BNE  = 1\n38: BR_BLT  = 4\n39: BR_BGE  = 5\n40: BR_BLTU = 6\n41: BR_BGEU = 7\n42: \n43: # ── Paths ──────────────────────────────────────────────────────────────────\n44: REPO_ROOT = Path(__file__).resolve().parent.parent\n45: RTL       = REPO_ROOT / \"rtl\"\n46: TEST_DIR  = REPO_ROOT / \"test\"\n47: SIM_BUILD = REPO_ROOT / \"sim_build\"\n48: \n49: \n50: def run_cocotb(toplevel: str, sources: list[str], test_module: str) -> None:\n51:     \"\"\"Build the DUT under Verilator and run the given cocotb test_module.\n52: \n53:     `sources` is a list of bare filenames under rtl/. Order matters —\n54:     package files (e.g. core_pkg.sv) come first.\n55:     \"\"\"\n56:     sim = os.environ.get(\"SIM\", \"verilator\")\n57:     runner = get_runner(sim)\n58:     build_dir = SIM_BUILD / toplevel\n59: \n60:     runner.build(\n61:         sources=[str(RTL / s) for s in sources],\n62:         hdl_toplevel=toplevel,\n63:         build_dir=str(build_dir),\n64:         always=True,\n65:         build_args=[\"-Wall\", \"-Wno-fatal\", \"-Wno-style\"],\n66:     )\n67:     runner.test(\n68:         hdl_toplevel=toplevel,\n69:         test_module=test_module,\n70:         test_dir=str(TEST_DIR),\n71:         build_dir=str(build_dir),\n72:     )\n\n(End of file - total 72 lines)\n</content>","metadata":{"preview":"\"\"\"Shared cocotb constants and runner helpers for unit tests.\n\nConstants mirror rtl/core_pkg.sv. If a localparam there changes, change\nthe matching value here.\n\"\"\"\nfrom __future__ import annotations\n\nimport os\nfrom pathlib import Path\n\n# cocotb 2.x moved the runner from cocotb.runner to cocotb_tools.runner.\nfrom cocotb_tools.runner import get_runner\n\n# ── ALU encodings (rtl/core_pkg.sv) ────────────────────────────────────────\nALU_ADD    = 0\nALU_SUB    = 1\nALU_AND    = 2\nALU_OR     = 3\nALU_XOR    = 4\nALU_SLT    = 5","truncated":false,"loaded":[]},"title":"cores/bench/test/_helpers.py","time":{"start":1777762753273,"end":1777762753278}},"metadata":{"openrouter":{"reasoning_details":[]}},"id":"prt_deaead62b001h1D4cG3Zem8BPo","sessionID":"ses_215154959ffe4lYe6Fozu7Hu6G","messageID":"msg_deaeacf58001hT1s8zWktkN4yu"}}
