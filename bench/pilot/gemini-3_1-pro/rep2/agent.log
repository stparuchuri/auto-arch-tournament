this cycle.\n27:   input  logic       imem_ready,\n28:   input  logic       dmem_ready,\n29:   // EX/MEM has a memory op in flight (the LOAD/STORE the dmem stall\n30:   // would actually be holding up). Computed at top level from the\n31:   // EX/MEM register's ctrl.mem_read | ctrl.mem_write.\n32:   input  logic       ex_mem_mem_op,\n33:   output logic       stall_if,          // PC reg holds\n34:   output logic       stall_id,          // ID/EX register holds (vs. bubble)\n35:   output logic       flush_if,          // IF/ID comb output -> NOP\n36:   output logic       flush_id,          // ID/EX register captures '0\n37:   output logic       stall_ex_mem,      // EX/MEM register holds\n38:   output logic       hold_mem_wb        // MEM/WB clears valid only;\n39:                                         // data fields stay (for fwd)\n40: );\n41: \n42:   logic load_use_hazard;\n43:   logic imem_stall;\n44:   logic dmem_stall;\n45: \n46:   logic [6:0] opcode;\n47:   logic       reads_rs1;\n48:   logic       reads_rs2;\n49:   logic [4:0] if_id_rs1;\n50:   logic [4:0] if_id_rs2;\n51: \n52:   always_comb begin\n53:     opcode = if_id_instr[6:0];\n54:     if_id_rs1 = if_id_instr[19:15];\n55:     if_id_rs2 = if_id_instr[24:20];\n56: \n57:     reads_rs1 = 1'b0;\n58:     reads_rs2 = 1'b0;\n59: \n60:     case (opcode)\n61:       7'b0110011: begin // R-type\n62:         reads_rs1 = 1'b1;\n63:         reads_rs2 = 1'b1;\n64:       end\n65:       7'b0010011: begin // I-type OP-IMM\n66:         reads_rs1 = 1'b1;\n67:       end\n68:       7'b0000011: begin // I-type LOAD\n69:         reads_rs1 = 1'b1;\n70:       end\n71:       7'b0100011: begin // S-type STORE\n72:         reads_rs1 = 1'b1;\n73:         reads_rs2 = 1'b1;\n74:       end\n75:       7'b1100011: begin // B-type BRANCH\n76:         reads_rs1 = 1'b1;\n77:         reads_rs2 = 1'b1;\n78:       end\n79:       7'b1100111: begin // JALR\n80:         reads_rs1 = 1'b1;\n81:       end\n82:       default: begin\n83:         reads_rs1 = 1'b0;\n84:         reads_rs2 = 1'b0;\n85:       end\n86:     endcase\n87: \n88:     load_use_hazard = id_ex_mem_read\n89:                    && (id_ex_rd != 5'b0)\n90:                    && ((reads_rs1 && id_ex_rd == if_id_rs1) ||\n91:                        (reads_rs2 && id_ex_rd == if_id_rs2));\n92: \n93:     imem_stall = !imem_ready;\n94:     // dmem stall only matters if there's actually a memory op in EX/MEM\n95:     // — otherwise bus-not-ready is irrelevant to the pipeline.\n96:     dmem_stall = !dmem_ready && ex_mem_mem_op;\n97: \n98:     // PC reg holds on any stall reason.\n99:     stall_if      = load_use_hazard || imem_stall || dmem_stall;\n100:     // IF/ID combinational payload: NOP whenever we wouldn't have a valid\n101:     // instruction this cycle (redirect target unknown to IF, or imem\n102:     // didn't deliver).\n103:     flush_if      = redirect || imem_stall;\n104:     // ID/EX register:\n105:     //   - dmem_stall  -> hold        (preserve in-flight pipeline state)\n106:     //   - load_use    -> bubble      (1-cycle stall between LOAD + use)\n107:     //   - redirect    -> bubble      (kill wrong-path)\n108:     //   - otherwise   -> capture\n109:     // dmem_stall takes precedence over load_use's bubble: re-evaluate\n110:     // load_use next cycle when the bus unblocks. flush_id is 1 only when\n111:     // we want bubble (not hold).\n112:     stall_id      = dmem_stall || load_use_hazard;\n113:     flush_id      = (load_use_hazard || redirect) && !dmem_stall;\n114:     // EX/MEM register: holds on dmem_stall (LOAD waits in MEM until the\n115:     // bus delivers).\n116:     stall_ex_mem  = dmem_stall;\n117:     // MEM/WB register: on dmem_stall the previously-retired instruction's\n118:     // data fields stay alive for forwarding (e.g. a held BNE needs the\n119:     // LOAD's load_data via fwd_mem_wb), but valid is cleared so we don't\n120:     // double-retire / double-write the regfile.\n121:     hold_mem_wb   = dmem_stall;\n122