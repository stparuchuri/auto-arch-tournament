_taken)) && !misalign_fault;\n+assign btb_wvalid  = actual_taken && !misalign_fault;\n+assign btb_wpc     = in.pc;\n+assign btb_wtarget = branch_target;\n+\n // ── EX/MEM register ───────────────────────────────────────────────────\n ex_mem_t reg_q;\n \n always_ff @(posedge clock) begin\n","filediff":{"file":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep3/cores/bench/worktrees/hyp-20260502-002-r1s1/cores/bench/rtl/ex_stage.sv","patch":"Index: /Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep3/cores/bench/worktrees/hyp-20260502-002-r1s1/cores/bench/rtl/ex_stage.sv\n===================================================================\n--- /Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep3/cores/bench/worktrees/hyp-20260502-002-r1s1/cores/bench/rtl/ex_stage.sv\n+++ /Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep3/cores/bench/worktrees/hyp-20260502-002-r1s1/cores/bench/rtl/ex_stage.sv\n@@ -113,11 +113,34 @@\n     ctrl_with_trap.reg_write  = 1'b0;\n   end\n end\n \n-assign redirect        = (branch_taken || in.ctrl.is_jump) && !misalign_fault;\n-assign redirect_target = in.ctrl.is_jump ? jump_target : branch_target;\n+logic actual_taken;\n+assign actual_taken = in.ctrl.is_branch && branch_cond;\n \n+// Redirect fires when the pipeline must change the fetch PC:\n+//   1. Jump (unconditional, always redirect unless misaligned)\n+//   2. Branch taken but BTB did NOT predict (must redirect to target)\n+//   3. BTB predicted taken but branch NOT taken (must redirect back to PC+4)\n+// When BTB correctly predicts a taken branch, no redirect is needed —\n+// IF already fetched the target.\n+assign redirect = (in.ctrl.is_jump && !misalign_fault) ||\n+                  (actual_taken && !in.predicted_taken && !misalign_fault) ||\n+                  (in.predicted_taken && !actual_taken && !misalign_fault);\n+\n+assign redirect_target = in.ctrl.is_jump ? jump_target :\n+                          actual_taken ? branch_target :\n+                          (in.predicted_taken && !actual_taken) ? (in.pc + 32'd4) :\n+                          32'b0;\n+\n+// BTB training / invalidation\n+//   Train:   branch taken → write valid=1, tag=PC, target=branch_target\n+//   Inval:   BTB predicted taken but branch not taken → write valid=0\n+assign btb_wen     = (actual_taken || (in.predicted_taken && !actual_taken)) && !misalign_fault;\n+assign btb_wvalid  = actual_taken && !misalign_fault;\n+assign btb_wpc     = in.pc;\n+assign btb_wtarget = branch_target;\n+\n // ── EX/MEM register ───────────────────────────────────────────────────\n ex_mem_t reg_q;\n \n always_ff @(posedge clock) begin\n","additions":25,"deletions":2},"truncated":false},"title":"cores/bench/rtl/ex_stage.sv","time":{"start":1777742950299,"end":1777742950301}},"id":"prt_de9bc75eb001CWqD1a5sJYEZcx","sessionID":"ses_2164e2417ffeuvidBdduDudYvn","messageID":"msg_de9bc626c001E9BBxST1bu6O61"}}
