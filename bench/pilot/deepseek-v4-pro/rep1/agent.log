h/jump\n+input  logic       predict_redirect,  // ID has predicted a taken branch\n+  // (fires one cycle after the branch enters ID/EX; flushes the\n+  // wrong-path IF instruction at X+4 but does NOT flush the branch\n+  // sitting in ID/EX that generated the prediction)\n // Bus backpressure (default-1 in zero-wait testbenches; VexRiscv-style\n // random ~22% stall in vex_main.cpp). When low, the corresponding\n // memory request is NOT serviced this cycle.\n input  logic       imem_ready,\n","additions":4,"deletions":0},"truncated":false},"title":"cores/bench/rtl/hazard_unit.sv","time":{"start":1777751137489,"end":1777751137490}},"id":"prt_dea3932de001e7wERfkfFx4bG6","sessionID":"ses_215d71c34ffe46SeBKU0HYPVyC","messageID":"msg_dea39077d001hZpDoLEQkQiVCX"}}
