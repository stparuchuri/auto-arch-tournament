{"type":"tool_use","timestamp":1777747784255,"sessionID":"ses_216060a9cffexhkFr5DZTait0t","part":{"type":"tool","tool":"bash","callID":"call_00_71zKqmDFn8cMywHf3dAt5261","state":{"status":"completed","input":{"command":"python3 -c \"\nimport yaml, json, re, sys\n\nwith open('cores/bench/experiments/hypotheses/hyp-20260502-002-r1s1.yaml') as f:\n    data = yaml.safe_load(f)\n\nwith open('schemas/hypothesis.schema.json') as f:\n    schema = json.load(f)\n\nerrors = []\nfor req in schema['required']:\n    if req not in data:\n        errors.append(f'Missing required: {req}')\n\nif 'id' in data:\n    pat = schema['properties']['id']['pattern']\n    if not re.match(pat, data['id']):\n        errors.append(f'id {data[\\\"id\\\"]} does not match {pat}')\n\nif 'title' in data and len(data['title']) < schema['properties']['title']['minLength']:\n    errors.append(f'title too short: {len(data[\\\"title\\\"])} < {schema[\\\"properties\\\"][\\\"title\\\"][\\\"minLength\\\"]}')\n\nif 'category' in data and data['category'] not in schema['properties']['category']['enum']:\n    errors.append(f'category {data[\\\"category\\\"]} not in {schema[\\\"properties\\\"][\\\"category\\\"][\\\"enum\\\"]}')\n\nif 'motivation' in data and len(data['motivation']) < schema['properties']['motivation']['minLength']:\n    errors.append(f'motivation too short: {len(data[\\\"motivation\\\"])}')\n\nif 'hypothesis' in data and len(data['hypothesis']) < schema['properties']['hypothesis']['minLength']:\n    errors.append(f'hypothesis too short: {len(data[\\\"hypothesis\\\"])}')\n\nif 'expected_impact' in data:\n    ei = data['expected_impact']\n    if not isinstance(ei, dict):\n        errors.append('expected_impact must be object')\n    else:\n        if 'fitness_delta_pct' not in ei:\n            errors.append('missing fitness_delta_pct')\n        elif not isinstance(ei['fitness_delta_pct'], int):\n            errors.append(f'fitness_delta_pct must be int, got {type(ei[\\\"fitness_delta_pct\\\"])}')\n        if 'confidence' not in ei:\n            errors.append('missing confidence')\n        elif ei['confidence'] not in ['low','medium','high']:\n            errors.append(f'confidence {ei[\\\"confidence\\\"]} not in [low,medium,high]')\nelse:\n    errors.append('missing expected_impact')\n\nif 'changes' in data:\n    if not isinstance(data['changes'], list) or len(data['changes']) == 0:\n        errors.append('changes must be non-empty array')\n    else:\n        fpat = re.compile(schema['properties']['changes']['items']['properties']['file']['pattern'])\n        for i, ch in enumerate(data['changes']):\n            if 'file' not in ch:\n                errors.append(f'changes[{i}] missing file')\n            elif not fpat.match(ch['file']):\n                errors.append(f'changes[{i}].file \\\"{ch[\\\"file\\\"]}\\\" does not match {fpat.pattern}')\n            if 'description' not in ch:\n                errors.append(f'changes[{i}] missing description')\nelse:\n    errors.append('missing changes')\n\nif errors:\n    for e in errors:\n        print(f'ERROR: {e}')\n    sys.exit(1)\nelse:\n    print('VALID: all checks passed')\n\"\n","description":"Validate hypothesis YAML against schema"},"output":"VALID: all checks passed\n","metadata":{"output":"VALID: all checks passed\n","exit":0,"description":"Validate hypothesis YAML against schema","truncated":false},"title":"Validate hypothesis YAML against schema","time":{"start":1777747784253,"end":1777747784255}},"id":"prt_dea0628700016ir78ywmPmp7WD","sessionID":"ses_216060a9cffexhkFr5DZTait0t","messageID":"msg_dea0602590012C7jbOLbRQEBNB"}}
