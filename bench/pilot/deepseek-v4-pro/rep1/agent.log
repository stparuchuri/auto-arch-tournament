{"type":"tool_use","timestamp":1777750939426,"sessionID":"ses_215d71c34ffe46SeBKU0HYPVyC","part":{"type":"tool","tool":"write","callID":"call_00_z983bZWRcYmmUddMQjVE4412","state":{"status":"completed","input":{"filePath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep1/cores/bench/worktrees/hyp-20260502-003-r2s2/cores/bench/rtl/branch_predictor.sv","content":"// rtl/branch_predictor.sv\n//\n// Bimodal branch predictor with 64-entry PHT of 2-bit saturating counters\n// (indexed by PC[7:2]) and 16-entry direct-mapped BTB ({valid, tag[31:6],\n// target[31:0]}). Combinational lookup; synchronous training on resolved\n// conditional branches at EX-stage completion.\n//\n// Lookup:  predict_taken = PHT[PC[7:2]][1] && BTB_hit\n//          predict_target = BTB target (valid only when BTB_hit)\n// Train:   PHT counter incremented on taken, decremented on not-taken\n//          BTB written on taken (caches target address)\nmodule branch_predictor (\n  input  logic        clock,\n  input  logic        reset,\n  // Combinational lookup port\n  input  logic [31:0] lookup_pc,\n  output logic        predict_taken,\n  output logic [31:0] predict_target,\n  // Synchronous training port (strobed on resolved conditional branches)\n  input  logic        train_valid,\n  input  logic [31:0] train_pc,\n  input  logic        train_taken,\n  input  logic [31:0] train_target\n);\n\n  // PHT: 64 entries of 2-bit saturating counters (00=strong not-taken …\n  // 11=strong taken), indexed by PC[7:2].\n  logic [1:0] pht [0:63];\n\n  // BTB: 16-entry direct-mapped. Each entry is {valid, tag[31:6], target[31:0]}.\n  // Indexed by PC[5:2].\n  logic        btb_valid [0:15];\n  logic [25:0] btb_tag   [0:15];  // PC[31:6]\n  logic [31:0] btb_target[0:15];\n\n  // ── Combinational lookup ───────────────────────────────────────────────\n  logic [5:0]  pht_idx;\n  logic [3:0]  btb_idx;\n  logic        btb_hit;\n\n  always_comb begin\n    pht_idx = lookup_pc[7:2];\n    btb_idx = lookup_pc[5:2];\n    btb_hit = btb_valid[btb_idx] && (btb_tag[btb_idx] == lookup_pc[31:6]);\n\n    predict_taken  = (pht[pht_idx][1] == 1'b1) && btb_hit;\n    predict_target = btb_hit ? btb_target[btb_idx] : 32'b0;\n  end\n\n  // ── Synchronous training ───────────────────────────────────────────────\n  logic [5:0]  train_pht_idx;\n  logic [3:0]  train_btb_idx;\n\n  always_comb begin\n    train_pht_idx = train_pc[7:2];\n    train_btb_idx = train_pc[5:2];\n  end\n\n  always_ff @(posedge clock) begin\n    if (reset) begin\n      for (int i = 0; i < 64; i++) pht[i] <= 2'b01;  // weak not-taken init\n      for (int i = 0; i < 16; i++) begin\n        btb_valid[i]  <= 1'b0;\n        btb_tag[i]    <= 26'b0;\n        btb_target[i] <= 32'b0;\n      end\n    end else if (train_valid) begin\n      // PHT update: 2-bit saturating counter\n      if (train_taken && pht[train_pht_idx] != 2'b11)\n        pht[train_pht_idx] <= pht[train_pht_idx] + 2'd1;\n      else if (!train_taken && pht[train_pht_idx] != 2'b00)\n        pht[train_pht_idx] <= pht[train_pht_idx] - 2'd1;\n\n      // BTB fill on taken branches\n      if (train_taken) begin\n        btb_valid[train_btb_idx]  <= 1'b1;\n        btb_tag[train_btb_idx]    <= train_pc[31:6];\n        btb_target[train_btb_idx] <= train_target;\n      end\n    end\n  end\n\nendmodule\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/bonetto/bonetto/auto-arch-tournament/.claude/bench-runs-pilot/deepseek-v4-pro-rep1/cores/bench/worktrees/hyp-20260502-003-r2s2/cores/bench/rtl/branch_predictor.sv","exists":false,"truncated":false},"title":"cores/bench/rtl/branch_predictor.sv","time":{"start":1777750939415,"end":1777750939424}},"id":"prt_dea361d96001XjYESNb037sAhb","sessionID":"ses_215d71c34ffe46SeBKU0HYPVyC","messageID":"msg_dea36022d001H7R1iCcfQWLcrv"}}
