fidence\": \"medium\"}, \"changes\": [{\"file\": \"rtl/branch_predictor.sv\", \"description\": \"New module: gshare predictor with GHR, PHT of 2-bit saturating counters, and direct-mapped BTB. Provides predict_taken and predict_target outputs, acc... (line truncated to 2000 chars)","truncated":false,"loaded":[]},"title":"cores/bench/experiments/log.jsonl","time":{"start":1777749911104,"end":1777749911113}},"id":"prt_dea26df8b0021GrKQNlkpd2ezy","sessionID":"ses_215dc42d9ffeBdy0cqVRfweyKm","messageID":"msg_dea26d38f001myBY5EPeRHb0Xh"}}
