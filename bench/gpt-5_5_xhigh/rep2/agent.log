n: \"Stop treating raw io_imemReady as a backend stall source; let IF emit invalid bubbles when the queue is empty while backend hazards still gate decode consumption.\"\n+  - file: rtl/core.sv\n+    description: \"Wire the revised IF/hazard handshake so backend stalls prevent queue pops but do not prevent independent instruction prefetch when queue space is available.\"\n+  - file: rtl/core_pkg.sv\n+    description: \"Add only the minimal fetch-queue metadata or valid/ready bundle fields needed for the decoupled IF-to-ID interface, preserving the existing RVFI payload semantics.\"\n","additions":35,"deletions":0}],"diagnostics":{},"truncated":false},"title":"Success. Updated the following files:\nA cores/bench/experiments/hypotheses/hyp-20260512-002-r2s1.yaml","time":{"start":1778596707174,"end":1778596707178}},"metadata":{"openai":{"itemId":"fc_0d54943162870398016a033b4e0170819583f402c79d4e9808"}},"id":"prt_e1c9fa933001OIjBT8H0fUbixj","sessionID":"ses_1e36402c1ffeWw0UF74O8zUKWR","messageID":"msg_e1c9f81b0001ufTEB3YdRtNNFb"}}
