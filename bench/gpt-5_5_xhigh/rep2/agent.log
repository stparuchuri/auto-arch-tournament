e/mux in IF, so the expected gain is","truncated":false,"loaded":[]},"title":"cores/bench/experiments/hypotheses/hyp-20260512-003-r2s2.yaml","time":{"start":1778596599616,"end":1778596599622}},"metadata":{"openai":{"itemId":"fc_0c5b6692c1a8662a016a033af5d7e0819695cc20fa10d2b1a8"}},"id":"prt_e1c9e50d0001ELL49rPM0ii59s","sessionID":"ses_1e3640253ffeuoshWxDIE4GW39","messageID":"msg_e1c9df390001ioG4R1FUXlwsF2"}}
